module contracts
import std::json
import std::result

struct ServiceInfo {
  service: String
  version: String
  profile: String
  request_id: String
  unix_ms: Int
}

struct EchoRequest {
  message: String
}

struct EchoResponse {
  message: String
  service: String
  request_id: String
}

struct ConfigValue {
  kind: String
  string_value: String
  bool_value: Bool
  int_value: Int
}

struct ConfigPutRequest {
  description: String
  value: ConfigValue
}

struct ConfigEntry {
  project: String
  environment: String
  key: String
  description: String
  value: ConfigValue
  revision_id: Int
  updated_by: String
  updated_unix_ms: Int
}

struct ConfigEntryEnvelope {
  entry: ConfigEntry
  request_id: String
  unix_ms: Int
}

struct ConfigListEnvelope {
  project: String
  environment: String
  entries: Json
  request_id: String
  unix_ms: Int
}

struct ConfigDeleteEnvelope {
  project: String
  environment: String
  key: String
  deleted: Bool
  deleted_revision_id: Int
  request_id: String
  unix_ms: Int
}

struct ConfigRevision {
  revision_id: Int
  project: String
  environment: String
  key: String
  action: String
  description: String
  value: ConfigValue
  updated_by: String
  updated_unix_ms: Int
}

struct ConfigHistoryEnvelope {
  project: String
  environment: String
  key: String
  revisions: Json
  request_id: String
  unix_ms: Int
}

struct WhoAmIEnvelope {
  auth_enabled: Bool
  actor: String
  role: String
  request_id: String
  unix_ms: Int
}

struct ConfigScopeFields {
  project: String
  environment: String
}

struct ConfigIdentityFields {
  project: String
  environment: String
  key: String
}

struct ConfigEntryPayloadFields {
  description: String
  value: ConfigValue
  revision_id: Int
  updated_by: String
  updated_unix_ms: Int
}

struct ConfigEntryStateFields {
  revision_id: Int
  updated_by: String
  updated_unix_ms: Int
}

struct ConfigRevisionPayloadFields {
  description: String
  value: ConfigValue
  updated_by: String
  updated_unix_ms: Int
}

struct EnvelopeMetadata {
  request_id: String
  unix_ms: Int
}

fn config_string_value(text: String) -> ConfigValue {
  return ConfigValue("string", text, false, 0)
}

fn config_bool_value(value: Bool) -> ConfigValue {
  return ConfigValue("bool", "", value, 0)
}

fn config_int_value(value: Int) -> ConfigValue {
  return ConfigValue("int", "", false, value)
}

fn ServiceInfo_as_json(self: ServiceInfo) -> Json {
  return object5(
    "service",
    string_value(self.service),
    "version",
    string_value(self.version),
    "profile",
    string_value(self.profile),
    "request_id",
    string_value(self.request_id),
    "unix_ms",
    int_value(self.unix_ms)
  )
}

fn EchoRequest_as_json(self: EchoRequest) -> Json {
  return object1("message", string_value(self.message))
}

fn EchoResponse_as_json(self: EchoResponse) -> Json {
  return object3(
    "message",
    string_value(self.message),
    "service",
    string_value(self.service),
    "request_id",
    string_value(self.request_id)
  )
}

fn ConfigValue_as_json(self: ConfigValue) -> Json {
  return object4(
    "kind",
    string_value(self.kind),
    "string_value",
    string_value(self.string_value),
    "bool_value",
    bool_value(self.bool_value),
    "int_value",
    int_value(self.int_value)
  )
}

fn ConfigPutRequest_as_json(self: ConfigPutRequest) -> Json {
  return object2(
    "description",
    string_value(self.description),
    "value",
    self.value.as_json()
  )
}

fn ConfigEntry_as_json(self: ConfigEntry) -> Json {
  return object7(
    "project",
    string_value(self.project),
    "environment",
    string_value(self.environment),
    "key",
    string_value(self.key),
    "description",
    string_value(self.description),
    "value",
    self.value.as_json(),
    "revision_id",
    int_value(self.revision_id),
    "meta",
    object2(
      "updated_by",
      string_value(self.updated_by),
      "updated_unix_ms",
      int_value(self.updated_unix_ms)
    )
  )
}

fn ConfigEntryEnvelope_as_json(self: ConfigEntryEnvelope) -> Json {
  return object3(
    "entry",
    self.entry.as_json(),
    "request_id",
    string_value(self.request_id),
    "unix_ms",
    int_value(self.unix_ms)
  )
}

fn ConfigListEnvelope_as_json(self: ConfigListEnvelope) -> Json {
  return object5(
    "project",
    string_value(self.project),
    "environment",
    string_value(self.environment),
    "entries",
    self.entries,
    "request_id",
    string_value(self.request_id),
    "unix_ms",
    int_value(self.unix_ms)
  )
}

fn ConfigDeleteEnvelope_as_json(self: ConfigDeleteEnvelope) -> Json {
  return object7(
    "project",
    string_value(self.project),
    "environment",
    string_value(self.environment),
    "key",
    string_value(self.key),
    "deleted",
    bool_value(self.deleted),
    "deleted_revision_id",
    int_value(self.deleted_revision_id),
    "request_id",
    string_value(self.request_id),
    "unix_ms",
    int_value(self.unix_ms)
  )
}

fn ConfigRevision_as_json(self: ConfigRevision) -> Json {
  return object7(
    "revision_id",
    int_value(self.revision_id),
    "project",
    string_value(self.project),
    "environment",
    string_value(self.environment),
    "key",
    string_value(self.key),
    "action",
    string_value(self.action),
    "description",
    string_value(self.description),
    "value",
    object3(
      "payload",
      self.value.as_json(),
      "updated_by",
      string_value(self.updated_by),
      "updated_unix_ms",
      int_value(self.updated_unix_ms)
    )
  )
}

fn ConfigHistoryEnvelope_as_json(self: ConfigHistoryEnvelope) -> Json {
  return object6(
    "project",
    string_value(self.project),
    "environment",
    string_value(self.environment),
    "key",
    string_value(self.key),
    "revisions",
    self.revisions,
    "request_id",
    string_value(self.request_id),
    "unix_ms",
    int_value(self.unix_ms)
  )
}

fn WhoAmIEnvelope_as_json(self: WhoAmIEnvelope) -> Json {
  return object5(
    "auth_enabled",
    bool_value(self.auth_enabled),
    "actor",
    string_value(self.actor),
    "role",
    string_value(self.role),
    "request_id",
    string_value(self.request_id),
    "unix_ms",
    int_value(self.unix_ms)
  )
}

fn service_info_from_json(value: Json) -> Result<ServiceInfo, String> {
  let service = get_string(value, "service")?
  let version = get_string(value, "version")?
  let profile = get_string(value, "profile")?
  let request_id = get_string(value, "request_id")?
  let unix_ms = get_int(value, "unix_ms")?
  return Ok(ServiceInfo(service, version, profile, request_id, unix_ms))
}

fn echo_request_from_json(value: Json) -> Result<EchoRequest, String> {
  let message = get_string(value, "message")?
  return Ok(EchoRequest(message))
}

fn echo_response_from_json(value: Json) -> Result<EchoResponse, String> {
  let message = get_string(value, "message")?
  let service = get_string(value, "service")?
  let request_id = get_string(value, "request_id")?
  return Ok(EchoResponse(message, service, request_id))
}

fn config_value_from_json(value: Json) -> Result<ConfigValue, String> {
  let kind = get_string(value, "kind")?
  let string_value_text = get_string(value, "string_value")?
  let bool_value_flag = get_bool(value, "bool_value")?
  let int_value_number = get_int(value, "int_value")?
  return Ok(ConfigValue(kind, string_value_text, bool_value_flag, int_value_number))
}

fn config_put_request_from_json(value: Json) -> Result<ConfigPutRequest, String> {
  let description = get_string(value, "description")?
  let config_value_json = get_value(value, "value")?
  let config_value = config_value_from_json(config_value_json)?
  return Ok(ConfigPutRequest(description, config_value))
}

fn config_scope_fields_from_json(value: Json) -> Result<ConfigScopeFields, String> {
  let project = get_string(value, "project")?
  let environment = get_string(value, "environment")?
  return Ok(ConfigScopeFields(project, environment))
}

fn config_identity_fields_from_json(value: Json) -> Result<ConfigIdentityFields, String> {
  let scope = config_scope_fields_from_json(value)?
  let key = get_string(value, "key")?
  return Ok(ConfigIdentityFields(scope.project, scope.environment, key))
}

fn config_entry_meta_fields_from_json(value: Json) -> Result<ConfigEntryStateFields, String> {
  let meta = get_value(value, "meta")?
  let revision_id = get_int(value, "revision_id")?
  let updated_by = get_string(meta, "updated_by")?
  let updated_unix_ms = get_int(meta, "updated_unix_ms")?
  return Ok(ConfigEntryStateFields(revision_id, updated_by, updated_unix_ms))
}

fn config_entry_payload_fields_from_json(value: Json) -> Result<ConfigEntryPayloadFields, String> {
  let description = get_string(value, "description")?
  let config_value_json = get_value(value, "value")?
  let config_value = config_value_from_json(config_value_json)?
  let meta_fields = config_entry_meta_fields_from_json(value)?
  return Ok(ConfigEntryPayloadFields(description,
                                     config_value,
                                     meta_fields.revision_id,
                                     meta_fields.updated_by,
                                     meta_fields.updated_unix_ms))
}

fn envelope_metadata_from_json(value: Json) -> Result<EnvelopeMetadata, String> {
  let request_id = get_string(value, "request_id")?
  let unix_ms = get_int(value, "unix_ms")?
  return Ok(EnvelopeMetadata(request_id, unix_ms))
}

fn config_entry_from_json(value: Json) -> Result<ConfigEntry, String> {
  let identity = config_identity_fields_from_json(value)?
  let payload = config_entry_payload_fields_from_json(value)?
  return Ok(ConfigEntry(identity.project,
                        identity.environment,
                        identity.key,
                        payload.description,
                        payload.value,
                        payload.revision_id,
                        payload.updated_by,
                        payload.updated_unix_ms))
}

fn config_entry_envelope_from_json(value: Json) -> Result<ConfigEntryEnvelope, String> {
  let entry_json = get_value(value, "entry")?
  let entry = config_entry_from_json(entry_json)?
  let metadata = envelope_metadata_from_json(value)?
  return Ok(ConfigEntryEnvelope(entry, metadata.request_id, metadata.unix_ms))
}

fn validate_config_entries_array(entries: Json) -> Result<Bool, String> {
  let count = array_len(entries)?
  let index = 0
  while index < count {
    let entry_json = array_get(entries, index)?
    let entry = config_entry_from_json(entry_json)?
    if entry.key == "" {
      return Err("config list entry is missing key")
    }
    index += 1
  }
  return Ok(true)
}

fn config_list_envelope_from_json(value: Json) -> Result<ConfigListEnvelope, String> {
  let scope = config_scope_fields_from_json(value)?
  let entries = get_value(value, "entries")?
  validate_config_entries_array(entries)?
  let metadata = envelope_metadata_from_json(value)?
  return Ok(ConfigListEnvelope(scope.project, scope.environment, entries, metadata.request_id, metadata.unix_ms))
}

fn config_delete_envelope_from_json(value: Json) -> Result<ConfigDeleteEnvelope, String> {
  let identity = config_identity_fields_from_json(value)?
  let deleted = get_bool(value, "deleted")?
  let deleted_revision_id = get_int(value, "deleted_revision_id")?
  let metadata = envelope_metadata_from_json(value)?
  return Ok(ConfigDeleteEnvelope(identity.project,
                                 identity.environment,
                                 identity.key,
                                 deleted,
                                 deleted_revision_id,
                                 metadata.request_id,
                                 metadata.unix_ms))
}

fn config_revision_value_from_payload(payload: Json) -> Result<ConfigValue, String> {
  let config_value_json = get_value(payload, "payload")?
  return config_value_from_json(config_value_json)
}

fn config_revision_metadata_from_payload(value: Json,
                                         payload: Json,
                                         config_value: ConfigValue) -> Result<ConfigRevisionPayloadFields, String> {
  let updated_by = get_string(payload, "updated_by")?
  let updated_unix_ms = get_int(payload, "updated_unix_ms")?
  let description = get_string(value, "description")?
  return Ok(ConfigRevisionPayloadFields(description, config_value, updated_by, updated_unix_ms))
}

fn config_revision_payload_fields_from_json(value: Json) -> Result<ConfigRevisionPayloadFields, String> {
  let payload = get_value(value, "value")?
  let config_value = config_revision_value_from_payload(payload)?
  return config_revision_metadata_from_payload(value, payload, config_value)
}

fn config_revision_from_json(value: Json) -> Result<ConfigRevision, String> {
  let revision_id = get_int(value, "revision_id")?
  let identity = config_identity_fields_from_json(value)?
  let action = get_string(value, "action")?
  let payload = config_revision_payload_fields_from_json(value)?
  return Ok(ConfigRevision(revision_id,
                           identity.project,
                           identity.environment,
                           identity.key,
                           action,
                           payload.description,
                           payload.value,
                           payload.updated_by,
                           payload.updated_unix_ms))
}

fn validate_config_revisions_array(revisions: Json) -> Result<Bool, String> {
  let count = array_len(revisions)?
  let index = 0
  while index < count {
    let revision_json = array_get(revisions, index)?
    let revision = config_revision_from_json(revision_json)?
    if revision.revision_id < 0 {
      return Err("config history revision_id must be non-negative")
    }
    index += 1
  }
  return Ok(true)
}

fn config_history_envelope_from_json(value: Json) -> Result<ConfigHistoryEnvelope, String> {
  let identity = config_identity_fields_from_json(value)?
  let revisions = get_value(value, "revisions")?
  validate_config_revisions_array(revisions)?
  let metadata = envelope_metadata_from_json(value)?
  return Ok(ConfigHistoryEnvelope(identity.project,
                                  identity.environment,
                                  identity.key,
                                  revisions,
                                  metadata.request_id,
                                  metadata.unix_ms))
}

fn whoami_envelope_from_json(value: Json) -> Result<WhoAmIEnvelope, String> {
  let auth_enabled = get_bool(value, "auth_enabled")?
  let actor = get_string(value, "actor")?
  let role = get_string(value, "role")?
  let metadata = envelope_metadata_from_json(value)?
  return Ok(WhoAmIEnvelope(auth_enabled, actor, role, metadata.request_id, metadata.unix_ms))
}

@test
fn test_service_info_roundtrip() -> Void {
  let info = ServiceInfo("svc", "0.1.0", "linux-backend-ga", "req-1", 42)
  match service_info_from_json(info.as_json()) {
    Ok(parsed) => {
      assert(parsed.service == info.service, "service mismatch")
      assert(parsed.version == info.version, "version mismatch")
      assert(parsed.profile == info.profile, "profile mismatch")
      assert(parsed.request_id == info.request_id, "request id mismatch")
      expect_eq(parsed.unix_ms, info.unix_ms)
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_echo_response_roundtrip() -> Void {
  let echo = EchoResponse("hello", "svc", "req-2")
  match echo_response_from_json(echo.as_json()) {
    Ok(parsed) => {
      assert(parsed.message == echo.message, "echo message mismatch")
      assert(parsed.service == echo.service, "echo service mismatch")
      assert(parsed.request_id == echo.request_id, "echo request id mismatch")
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_config_value_roundtrip() -> Void {
  let config_value = config_string_value("enabled")
  match config_value_from_json(config_value.as_json()) {
    Ok(parsed) => {
      assert(parsed.kind == "string", "config value kind mismatch")
      assert(parsed.string_value == "enabled", "config value string mismatch")
      assert(parsed.bool_value == false, "config value bool mismatch")
      expect_eq(parsed.int_value, 0)
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_config_put_request_roundtrip() -> Void {
  let put_request = ConfigPutRequest("feature gate", config_bool_value(true))
  match config_put_request_from_json(put_request.as_json()) {
    Ok(parsed) => {
      assert(parsed.description == "feature gate", "config put description mismatch")
      assert(parsed.value.kind == "bool", "config put kind mismatch")
      assert(parsed.value.bool_value == true, "config put bool mismatch")
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_config_entry_roundtrip() -> Void {
  let entry = ConfigEntry("proj", "prod", "flag", "feature gate", config_int_value(7), 3, "writer", 99)
  match config_entry_from_json(entry.as_json()) {
    Ok(parsed) => {
      assert(parsed.project == entry.project, "config entry project mismatch")
      assert(parsed.environment == entry.environment, "config entry environment mismatch")
      assert(parsed.key == entry.key, "config entry key mismatch")
      assert(parsed.description == entry.description, "config entry description mismatch")
      assert(parsed.value.kind == "int", "config entry value kind mismatch")
      expect_eq(parsed.revision_id, 3)
      assert(parsed.updated_by == "writer", "config entry updated_by mismatch")
      expect_eq(parsed.value.int_value, 7)
      expect_eq(parsed.updated_unix_ms, 99)
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_config_entry_envelope_roundtrip() -> Void {
  let entry = ConfigEntry("proj", "prod", "flag", "feature gate", config_int_value(7), 3, "writer", 99)
  let envelope = ConfigEntryEnvelope(entry, "req-3", 101)
  match config_entry_envelope_from_json(envelope.as_json()) {
    Ok(parsed) => {
      assert(parsed.entry.key == "flag", "config entry envelope key mismatch")
      expect_eq(parsed.entry.revision_id, 3)
      assert(parsed.request_id == "req-3", "config entry envelope request id mismatch")
      expect_eq(parsed.unix_ms, 101)
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_config_list_envelope_roundtrip() -> Void {
  let entry = ConfigEntry("proj", "prod", "flag", "feature gate", config_int_value(7), 3, "writer", 99)
  let builder = array_builder()
  builder = array_push(builder, entry.as_json())
  let list_envelope = ConfigListEnvelope("proj", "prod", array_build(builder), "req-4", 202)
  match config_list_envelope_from_json(list_envelope.as_json()) {
    Ok(parsed) => {
      assert(parsed.project == "proj", "config list project mismatch")
      assert(parsed.environment == "prod", "config list environment mismatch")
      assert(parsed.request_id == "req-4", "config list request id mismatch")
      expect_eq(parsed.unix_ms, 202)
      match array_len(parsed.entries) {
        Ok(count) => {
          expect_eq(count, 1)
        }
        Err(msg) => {
          panic(msg)
        }
      }
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_config_history_envelope_roundtrip() -> Void {
  let revision = ConfigRevision(1,
                                "proj",
                                "prod",
                                "flag",
                                "put",
                                "feature gate",
                                config_bool_value(true),
                                "writer",
                                404)
  let builder = array_builder()
  builder = array_push(builder, revision.as_json())
  let envelope = ConfigHistoryEnvelope("proj", "prod", "flag", array_build(builder), "req-6", 505)
  match config_history_envelope_from_json(envelope.as_json()) {
    Ok(parsed) => {
      assert(parsed.project == "proj", "config history project mismatch")
      assert(parsed.environment == "prod", "config history environment mismatch")
      assert(parsed.key == "flag", "config history key mismatch")
      assert(parsed.request_id == "req-6", "config history request id mismatch")
      expect_eq(parsed.unix_ms, 505)
      match array_len(parsed.revisions) {
        Ok(count) => {
          expect_eq(count, 1)
        }
        Err(msg) => {
          panic(msg)
        }
      }
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_config_delete_envelope_roundtrip() -> Void {
  let deleted = ConfigDeleteEnvelope("proj", "prod", "flag", true, 4, "req-5", 303)
  match config_delete_envelope_from_json(deleted.as_json()) {
    Ok(parsed) => {
      assert(parsed.project == "proj", "config delete project mismatch")
      assert(parsed.environment == "prod", "config delete environment mismatch")
      assert(parsed.key == "flag", "config delete key mismatch")
      assert(parsed.deleted == true, "config delete flag mismatch")
      expect_eq(parsed.deleted_revision_id, 4)
      assert(parsed.request_id == "req-5", "config delete request id mismatch")
      expect_eq(parsed.unix_ms, 303)
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_whoami_envelope_roundtrip() -> Void {
  let envelope = WhoAmIEnvelope(true, "admin", "admin", "req-7", 606)
  match whoami_envelope_from_json(envelope.as_json()) {
    Ok(parsed) => {
      assert(parsed.auth_enabled == true, "whoami auth_enabled mismatch")
      assert(parsed.actor == "admin", "whoami actor mismatch")
      assert(parsed.role == "admin", "whoami role mismatch")
      assert(parsed.request_id == "req-7", "whoami request id mismatch")
      expect_eq(parsed.unix_ms, 606)
    }
    Err(msg) => {
      panic(msg)
    }
  }
}
