module args
import core::app
import core::validate
import std::env
import std::result

struct ParsedArgs {
  url_override: String
  token_override: String
  ca_file_override: String
  json_mode: Bool
  command: String
  subcommand: String
  ping_message: String
  project: String
  environment: String
  key: String
  if_match_text: String
  description: String
  value_kind: String
  value_text: String
}

struct ParseProgress {
  parsed: ParsedArgs
  next_index: Int
}

fn usage() -> Void {
  print("usage: ctl [--url http://host:port[/prefix]] [--token TOKEN] [--ca-file PATH] [--json] <status|info|ping|config-validate|config|auth> ...")
  print("config put/delete support --if-match REVISION for optimistic concurrency")
}

fn empty_text() -> String {
  return text_concat("", "")
}

fn default_args() -> ParsedArgs {
  return ParsedArgs(empty_text(),
                    empty_text(),
                    empty_text(),
                    false,
                    empty_text(),
                    empty_text(),
                    empty_text(),
                    empty_text(),
                    empty_text(),
                    empty_text(),
                    empty_text(),
                    empty_text(),
                    empty_text(),
                    empty_text())
}

fn rebuild_args(url_override: String,
                token_override: String,
                ca_file_override: String,
                json_mode: Bool,
                command: String,
                subcommand: String,
                ping_message: String,
                project: String,
                environment: String,
                key: String,
                if_match_text: String,
                description: String,
                value_kind: String,
                value_text: String) -> ParsedArgs {
  return ParsedArgs(url_override,
                    token_override,
                    ca_file_override,
                    json_mode,
                    command,
                    subcommand,
                    ping_message,
                    project,
                    environment,
                    key,
                    if_match_text,
                    description,
                    value_kind,
                    value_text)
}

fn with_url_override(parsed: ParsedArgs, value: String) -> ParsedArgs {
  return rebuild_args(value,
                      parsed.token_override,
                      parsed.ca_file_override,
                      parsed.json_mode,
                      parsed.command,
                      parsed.subcommand,
                      parsed.ping_message,
                      parsed.project,
                      parsed.environment,
                      parsed.key,
                      parsed.if_match_text,
                      parsed.description,
                      parsed.value_kind,
                      parsed.value_text)
}

fn with_token_override(parsed: ParsedArgs, value: String) -> ParsedArgs {
  return rebuild_args(parsed.url_override,
                      value,
                      parsed.ca_file_override,
                      parsed.json_mode,
                      parsed.command,
                      parsed.subcommand,
                      parsed.ping_message,
                      parsed.project,
                      parsed.environment,
                      parsed.key,
                      parsed.if_match_text,
                      parsed.description,
                      parsed.value_kind,
                      parsed.value_text)
}

