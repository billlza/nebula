  return rebuild_args(parsed.url_override,
                      parsed.token_override,
                      value,
                      parsed.json_mode,
                      parsed.command,
                      parsed.subcommand,
                      parsed.ping_message,
                      parsed.project,
                      parsed.environment,
                      parsed.key,
                      parsed.if_match_text,
                      parsed.description,
                      parsed.value_kind,
                      parsed.value_text)
}

fn with_json_mode(parsed: ParsedArgs) -> ParsedArgs {
  return rebuild_args(parsed.url_override,
                      parsed.token_override,
                      parsed.ca_file_override,
                      true,
                      parsed.command,
                      parsed.subcommand,
                      parsed.ping_message,
                      parsed.project,
                      parsed.environment,
                      parsed.key,
                      parsed.if_match_text,
                      parsed.description,
                      parsed.value_kind,
                      parsed.value_text)
}

