                      parsed.environment,
                      parsed.key,
                      parsed.if_match_text,
                      value,
                      parsed.value_kind,
                      parsed.value_text)
}

fn with_value(parsed: ParsedArgs, kind: String, value: String) -> Result<ParsedArgs, String> {
  if parsed.value_kind != "" {
    return Err("config put requires exactly one of --string/--bool/--int")
  }
  return Ok(rebuild_args(parsed.url_override,
                         parsed.token_override,
                         parsed.ca_file_override,
                         parsed.json_mode,
                         parsed.command,
                         parsed.subcommand,
                         parsed.ping_message,
                         parsed.project,
                         parsed.environment,
                         parsed.key,
                         parsed.if_match_text,
                         parsed.description,
                         kind,
                         value))
}

fn selected_base_url(url_override: String) -> String {
  if url_override != "" {
    return url_override
  }
  let env_url = get_or_default("APP_URL", "")
  if env_url != "" {
    return env_url
  }
  return default_base_url()
}

fn selected_token(token_override: String) -> String {
  if token_override != "" {
    return token_override
  }
  return get_or_default("APP_TOKEN", "")
}

fn selected_ca_file(ca_file_override: String) -> String {
  if ca_file_override != "" {
    return ca_file_override
  }
  return get_or_default("APP_CA_FILE", "")
}

fn next_arg_value(index: Int, flag: String) -> Result<String, String> {
  if index + 1 >= argc() {
    return Err(text_concat("missing value for ", flag))
  }
  return Ok(argv(index + 1))
}

fn parsed_progress(parsed: ParsedArgs, index: Int) -> ParseProgress {
  return ParseProgress(parsed, index)
}

fn config_flag_progress(parsed: ParsedArgs, index: Int, arg: String) -> Result<ParseProgress, String> {
  let value = next_arg_value(index, arg)?
  if arg == "--project" {
    return Ok(parsed_progress(with_project(parsed, value), index + 2))
  }
  if arg == "--env" {
    return Ok(parsed_progress(with_environment(parsed, value), index + 2))
  }
  if arg == "--key" {
    return Ok(parsed_progress(with_key(parsed, value), index + 2))
  }
  if arg == "--if-match" {
    return Ok(parsed_progress(with_if_match_text(parsed, value), index + 2))
  }
  if arg == "--description" {
    return Ok(parsed_progress(with_description(parsed, value), index + 2))
  }
  return Err("unexpected argument")
}

fn config_typed_value_progress(parsed: ParsedArgs,
                               index: Int,
                               arg: String,
                               kind: String) -> Result<ParseProgress, String> {
  let value = next_arg_value(index, arg)?
  let next = with_value(parsed, kind, value)?
  return Ok(parsed_progress(next, index + 2))
}

fn parse_config_value_option(parsed: ParsedArgs, index: Int, arg: String) -> Result<ParseProgress, String> {
  if arg == "--string" {
    return config_typed_value_progress(parsed, index, arg, "string")
  }
  if arg == "--bool" {
    return config_typed_value_progress(parsed, index, arg, "bool")
  }
  if arg == "--int" {
    return config_typed_value_progress(parsed, index, arg, "int")
  }
  return Err("unexpected argument")
}

fn parse_config_option(parsed: ParsedArgs, index: Int, arg: String) -> Result<ParseProgress, String> {
  if arg == "--project" || arg == "--env" || arg == "--key" || arg == "--if-match" || arg == "--description" {
    return config_flag_progress(parsed, index, arg)
  }
  return parse_config_value_option(parsed, index, arg)
}

fn parse_global_option(parsed: ParsedArgs, index: Int, arg: String) -> Result<ParseProgress, String> {
  if arg == "--url" {
    let value = next_arg_value(index, "--url")?
    return Ok(parsed_progress(with_url_override(parsed, value), index + 2))
  }
  if arg == "--token" {
    let value = next_arg_value(index, "--token")?
    return Ok(parsed_progress(with_token_override(parsed, value), index + 2))
  }
  if arg == "--ca-file" {
    let value = next_arg_value(index, "--ca-file")?
    return Ok(parsed_progress(with_ca_file_override(parsed, value), index + 2))
  }
  if arg == "--json" {
    return Ok(parsed_progress(with_json_mode(parsed), index + 1))
  }
  return Err("not a global option")
}

fn parse_command_token(parsed: ParsedArgs, index: Int, arg: String) -> Result<ParseProgress, String> {
  if parsed.command == "" {
    return Ok(parsed_progress(with_command(parsed, arg), index + 1))
  }
  if parsed.command == "ping" && parsed.ping_message == "" {
    return Ok(parsed_progress(with_ping_message(parsed, arg), index + 1))
  }
  if (parsed.command == "config" || parsed.command == "auth") && parsed.subcommand == "" {
    return Ok(parsed_progress(with_subcommand(parsed, arg), index + 1))
  }
  return Err("not a command token")
}

fn advance_parse(parsed: ParsedArgs, index: Int, arg: String) -> Result<ParseProgress, String> {
  match parse_global_option(parsed, index, arg) {
    Ok(progress) => {
      return Ok(progress)
    }
    Err(_) => {}
  }
  match parse_command_token(parsed, index, arg) {
    Ok(progress) => {
      return Ok(progress)
    }
    Err(_) => {}
  }
  if parsed.command == "config" {
    return parse_config_option(parsed, index, arg)
  }
  return Err("unexpected argument")
}

fn require_flag_value(value: String, label: String) -> Result<Bool, String> {
  if value == "" {
    return Err(text_concat(label, " is required"))
  }
  return Ok(true)
}

fn reject_flag_value(value: String, label: String) -> Result<Bool, String> {
  if value != "" {
    return Err(text_concat(label, " is not allowed for this subcommand"))
  }
  return Ok(true)
}

fn require_config_scope(parsed: ParsedArgs) -> Result<Bool, String> {
  require_flag_value(parsed.project, "--project")?
  require_flag_value(parsed.environment, "--env")?
  return Ok(true)
}

fn require_config_identity(parsed: ParsedArgs) -> Result<Bool, String> {
  require_config_scope(parsed)?
  require_flag_value(parsed.key, "--key")?
  return Ok(true)
}

fn reject_config_optional_value(parsed: ParsedArgs) -> Result<Bool, String> {
  reject_flag_value(parsed.if_match_text, "--if-match")?
  reject_flag_value(parsed.description, "--description")?
  reject_flag_value(parsed.value_kind, "one of --string/--bool/--int")?
  reject_flag_value(parsed.value_text, "one of --string/--bool/--int")?
  return Ok(true)
}

fn finalize_config_list_args(parsed: ParsedArgs) -> Result<ParsedArgs, String> {
  require_config_scope(parsed)?
  reject_flag_value(parsed.key, "--key")?
  reject_config_optional_value(parsed)?
  return Ok(parsed)
}

fn finalize_config_get_args(parsed: ParsedArgs) -> Result<ParsedArgs, String> {
  require_config_identity(parsed)?
  reject_config_optional_value(parsed)?
  return Ok(parsed)
}

fn finalize_config_put_args(parsed: ParsedArgs) -> Result<ParsedArgs, String> {
  require_config_identity(parsed)?
  require_flag_value(parsed.value_kind, "one of --string/--bool/--int")?
  return Ok(parsed)
}

fn finalize_config_delete_args(parsed: ParsedArgs) -> Result<ParsedArgs, String> {
  require_config_identity(parsed)?
  require_flag_value(parsed.if_match_text, "--if-match")?
  reject_flag_value(parsed.description, "--description")?
  reject_flag_value(parsed.value_kind, "one of --string/--bool/--int")?
  reject_flag_value(parsed.value_text, "one of --string/--bool/--int")?
  return Ok(parsed)
}

fn finalize_auth_args(parsed: ParsedArgs) -> Result<ParsedArgs, String> {
  if parsed.subcommand != "whoami" {
    return Err("unknown auth subcommand")
  }
  reject_flag_value(parsed.ping_message, "ping message")?
  reject_flag_value(parsed.project, "--project")?
  reject_flag_value(parsed.environment, "--env")?
  reject_flag_value(parsed.key, "--key")?
  reject_config_optional_value(parsed)?
  return Ok(parsed)
}

fn finalize_config_args(parsed: ParsedArgs) -> Result<ParsedArgs, String> {
  if parsed.subcommand == "" {
    return Err("missing config subcommand")
  }
  if parsed.subcommand == "list" {
    return finalize_config_list_args(parsed)
  }
  if parsed.subcommand == "get" || parsed.subcommand == "history" {
    return finalize_config_get_args(parsed)
  }
  if parsed.subcommand == "put" {
    return finalize_config_put_args(parsed)
  }
  if parsed.subcommand == "delete" {
    return finalize_config_delete_args(parsed)
  }
  return Err("unknown config subcommand")
}

fn finalize_args(parsed: ParsedArgs) -> Result<ParsedArgs, String> {
  if parsed.command == "" {
    return Err("missing command")
  }
  if parsed.command == "ping" && parsed.ping_message == "" {
    return Err("missing ping message")
  }
  if parsed.command == "config" {
    return finalize_config_args(parsed)
  }
  if parsed.command == "auth" {
    return finalize_auth_args(parsed)
  }
  return Ok(parsed)
}

fn parse_args() -> Result<ParsedArgs, String> {
  let parsed = default_args()
  let index = 1
  while index < argc() {
    let arg = argv(index)
    match advance_parse(parsed, index, arg) {
      Ok(progress) => {
        parsed = progress.parsed
        index = progress.next_index
      }
      Err(msg) => {
        return Err(msg)
      }
    }
  }
  return finalize_args(parsed)
}
