module main
import std::json
import ui::headless
import ui::ui

struct DashboardState {
  title: String
  ready: Bool
}

ui Dashboard(state: DashboardState) {
  view Window(title = state.title) {
    view Column(spacing = 12) {
      view Text(text = state.title)
      view Button(text = "Refresh", action = "targets.refresh")
    }
  }
}

fn main() -> Void {
  let state = DashboardState("Local Ops", true)
  print(stringify(Dashboard(state)))
  match render(Dashboard(state)) {
    Ok(text) => {
      print(text)
    }
    Err(msg) => {
      print(msg)
    }
  }
  match dispatch_action(Dashboard(state), "targets.refresh") {
    Ok(action) => {
      print(action)
    }
    Err(msg) => {
      print(msg)
    }
  }
}
