module server
import crypto::hash
import crypto::pqc.kem
import crypto::pqc.sign
import pqc::channel
import service::health
import std::bytes
import std::env
import std::http
import std::http_json
import std::json
import std::result

fn service_name() -> String {
  return "pqc-secure-service"
}

fn load_hex_env(name: String) -> Result<Bytes, String> {
  match get(name) {
    Ok(value) => {
      return from_hex(value)
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

fn load_kem_public_key_env(name: String) -> Result<MlKem768PublicKey, String> {
  match load_hex_env(name) {
    Ok(bytes) => {
      return ml_kem_768_public_key_from_bytes(bytes)
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

fn load_kem_secret_key_env(name: String) -> Result<MlKem768SecretKey, String> {
  match load_hex_env(name) {
    Ok(bytes) => {
      return ml_kem_768_secret_key_from_bytes(bytes)
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

fn load_sign_public_key_env(name: String) -> Result<MlDsa65PublicKey, String> {
  match load_hex_env(name) {
    Ok(bytes) => {
      return ml_dsa_65_public_key_from_bytes(bytes)
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

fn load_sign_secret_key_env(name: String) -> Result<MlDsa65SecretKey, String> {
  match load_hex_env(name) {
    Ok(bytes) => {
      return ml_dsa_65_secret_key_from_bytes(bytes)
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

fn demo_server_signer() -> Result<ChannelSigner, String> {
  match load_sign_public_key_env("PQC_SECURE_SERVICE_SIGN_PUBLIC_KEY_HEX") {
    Ok(public_key) => {
      match load_sign_secret_key_env("PQC_SECURE_SERVICE_SIGN_SECRET_KEY_HEX") {
        Ok(secret_key) => {
          return Ok(ChannelSigner(public_key, secret_key))
        }
        Err(msg) => {
          return Err(msg)
        }
      }
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

fn bootstrap_response() -> Result<Response, String> {
  match get("PQC_SECURE_SERVICE_KEM_PUBLIC_KEY_HEX") {
    Ok(kem_public_key_hex) => {
      match get("PQC_SECURE_SERVICE_SIGN_PUBLIC_KEY_HEX") {
        Ok(sign_public_key_hex) => {
          return Ok(ok_json(object2(
            "kem_public_key_hex",
            string_value(kem_public_key_hex),
            "sign_public_key_hex",
            string_value(sign_public_key_hex)
          )))
        }
        Err(msg) => {
          return Err(msg)
        }
      }
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

fn secure_echo_response(server_accept: ServerAccept, plaintext: Bytes) -> Result<Response, String> {
  match seal_next(server_accept.session(), plaintext, from_string("nebula-http-response")) {
    Ok(sent) => {
      return Ok(ok_json(object1(
        "ciphertext_text",
        string_value(to_string(sent.ciphertext()))
      )))
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

async fn handle_health(request: Request) -> Response {
  return live_response(service_name())
}

async fn handle_request(request: Request) -> Response {
  if path_matches("/healthz", request) {
    if method_matches(Get, request.method) {
      return await handle_health(request)
    }
    return method_not_allowed_text("method not allowed")
  }
  if path_matches("/secure/bootstrap", request) {
    if method_matches(Get, request.method) {
      return await handle_bootstrap(request)
    }
    return method_not_allowed_text("method not allowed")
  }
  if path_matches("/secure/open", request) {
    if method_matches(Post, request.method) {
      return await handle_open(request)
    }
    return method_not_allowed_text("method not allowed")
  }
  if path_matches("/secure/echo", request) {
    if method_matches(Post, request.method) {
      return await handle_secure_echo(request)
    }
    return method_not_allowed_text("method not allowed")
  }
  return not_found_text("not found")
}

async fn handle_bootstrap(request: Request) -> Response {
  match bootstrap_response() {
    Ok(response) => {
      return response
    }
    Err(msg) => {
      return internal_error_text(msg)
    }
  }
}

async fn handle_open(request: Request) -> Response {
  match parse_json_body(request.body) {
    Ok(value) => {
      match get_string(value, "hello_text") {
        Ok(hello_text) => {
          match client_hello_from_json_text(hello_text) {
            Ok(hello) => {
              match load_kem_secret_key_env("PQC_SECURE_SERVICE_KEM_SECRET_KEY_HEX") {
                Ok(kem_secret_key) => {
                  match demo_server_signer() {
                    Ok(server_signer) => {
                      match accept(kem_secret_key, signed(server_signer), hello) {
                        Ok(server_accept) => {
                          return ok_json(object1(
                            "accept_text",
                            string_value(stringify(server_accept.message().as_json()))
                          ))
                        }
                        Err(msg) => {
                          return bad_request_text(msg)
                        }
                      }
                    }
                    Err(msg) => {
                      return internal_error_text(msg)
                    }
                  }
                }
                Err(msg) => {
                  return internal_error_text(msg)
                }
              }
            }
            Err(msg) => {
              return bad_request_text(msg)
            }
          }
        }
        Err(msg) => {
          return bad_request_text(msg)
        }
      }
    }
    Err(msg) => {
      return bad_request_text(msg)
    }
  }
}

async fn handle_secure_echo(request: Request) -> Response {
  match parse_json_body(request.body) {
    Ok(value) => {
      match get_string(value, "hello_text") {
        Ok(hello_text) => {
          match get_string(value, "ciphertext_text") {
            Ok(ciphertext_text) => {
              match client_hello_from_json_text(hello_text) {
                Ok(hello) => {
                  match load_kem_secret_key_env("PQC_SECURE_SERVICE_KEM_SECRET_KEY_HEX") {
                    Ok(kem_secret_key) => {
                      match demo_server_signer() {
                        Ok(server_signer) => {
                          match accept(kem_secret_key, signed(server_signer), hello) {
                            Ok(server_accept) => {
                              match open_next(server_accept.session(),
                                              from_string(ciphertext_text),
                                              from_string("nebula-http-request")) {
                                Ok(opened) => {
                                  match secure_echo_response(ServerAccept(server_accept.message(), opened.session()),
                                                             opened.plaintext()) {
                                    Ok(response) => {
                                      return response
                                    }
                                    Err(msg) => {
                                      return internal_error_text(msg)
                                    }
                                  }
                                }
                                Err(msg) => {
                                  return bad_request_text(msg)
                                }
                              }
                            }
                            Err(msg) => {
                              return bad_request_text(msg)
                            }
                          }
                        }
                        Err(msg) => {
                          return internal_error_text(msg)
                        }
                      }
                    }
                    Err(msg) => {
                      return internal_error_text(msg)
                    }
                  }
                }
                Err(msg) => {
                  return bad_request_text(msg)
                }
              }
            }
            Err(msg) => {
              return bad_request_text(msg)
            }
          }
        }
        Err(msg) => {
          return bad_request_text(msg)
        }
      }
    }
    Err(msg) => {
      return bad_request_text(msg)
    }
  }
}
