module server
import std::http
import std::net
import std::result

async fn handle_request(request: Request) -> Response {
  return await dispatch2(
    request,
    Get,
    "/hello",
    handle_hello,
    Post,
    "/echo",
    handle_echo,
    not_found_text("not found")
  )
}

async fn handle_hello(request: Request) -> Response {
  return ok_text("hello from nebula")
}

async fn handle_echo(request: Request) -> Response {
  return bad_request_text("unsupported")
}

async fn serve_once(listener: TcpListener) -> Void {
  match await serve_n(listener, 1, handle_request) {
    Ok(_) => {}
    Err(msg) => {
      print(msg)
    }
  }
}
