module counter_core
import bridge::host_bridge
import std::json
import std::result

struct CounterState {
  counter: Int,
  last_command: String,
  revision: Int
}

struct CounterStep {
  state: CounterState,
  should_exit: Bool,
  event_kind: String,
  correlation_id: String
}

enum CounterCommand {
  Increment(Void)
  Decrement(Void)
  Quit(Void)
}

struct CounterCommandEnvelope {
  kind: String,
  correlation_id: String,
  state_revision: Int
}

struct CounterCommandCodeEnvelope {
  kind_code: Int,
  correlation_id: String,
  state_revision: Int
}

struct CounterPayloadDelta {
  delta: Int,
  label: String
}

fn initial_state() -> CounterState {
  return CounterState(0, "boot", 0)
}

fn CounterStep_state(self: CounterStep) -> CounterState {
  return self.state
}

fn CounterStep_should_exit_value(self: CounterStep) -> Bool {
  return self.should_exit
}

fn CounterState_revision(self: CounterState) -> Int {
  return self.revision
}

fn counter_status(counter: Int) -> String {
  if counter <= 0 {
    return "idle"
  }
  if counter == 1 {
    return "active"
  }
  return "busy"
}

fn counter_payload(state: CounterState) -> Json {
  return object4("counter",
                 int_value(state.counter),
                 "can_decrement",
                 bool_value(state.counter > 0),
                 "status",
                 string_value(counter_status(state.counter)),
                 "last_command",
                 string_value(state.last_command))
}

fn counter_payload_text(state: CounterState) -> String {
  return object4_text("counter",
                      int_value(state.counter),
                      "can_decrement",
                      bool_value(state.counter > 0),
                      "status",
                      string_value(counter_status(state.counter)),
                      "last_command",
                      string_value(state.last_command))
}

fn query_snapshot_text(state: CounterState) -> String {
  return encode_snapshot_payload_text_unchecked_with_revision("counter", counter_payload_text(state), state.revision)
}

fn boot_event_text(state: CounterState) -> String {
  return encode_event_payload_text_unchecked_with_context("booted", counter_payload_text(state), false, "boot", state.revision)
}

fn command_rejected_event_text(state: CounterState, correlation_id: String, reason: String) -> String {
  return encode_event_text_with_context("command_rejected",
                                        object5("counter",
                                                int_value(state.counter),
                                                "can_decrement",
                                                bool_value(state.counter > 0),
                                                "status",
                                                string_value(counter_status(state.counter)),
                                                "last_command",
                                                string_value(state.last_command),
                                                "reason",
                                                string_value(reason)),
                                        false,
                                        correlation_id,
                                        state.revision)
}

fn CounterStep_event_text(self: CounterStep) -> String {
  return encode_event_payload_text_unchecked_with_context(self.event_kind,
                                                          counter_payload_text(self.state),
                                                          self.should_exit,
                                                          self.correlation_id,
                                                          self.state.revision)
}

fn increment_command_text() -> String {
  return encode_command_text_with_context("increment", "cmd-increment", 0)
}

fn decrement_command_text() -> String {
  return encode_command_text_with_context("decrement", "cmd-decrement", 0)
}

fn quit_command_text() -> String {
  return encode_command_text_with_context("quit", "cmd-quit", 0)
}

fn command_text_at_revision(kind: String, correlation_id: String, state_revision: Int) -> String {
  return encode_command_text_with_context(kind, correlation_id, state_revision)
}

fn command_at_revision(kind: String, correlation_id: String, state_revision: Int) -> CounterCommandEnvelope {
  return CounterCommandEnvelope(kind, correlation_id, state_revision)
}

fn command_code_at_revision(kind_code: Int, correlation_id: String, state_revision: Int) -> CounterCommandCodeEnvelope {
  return CounterCommandCodeEnvelope(kind_code, correlation_id, state_revision)
}

fn payload_delta_command_text_at_revision(correlation_id: String,
                                          state_revision: Int,
                                          delta: Int,
                                          label: String) -> String {
  let payload_text = object4_text("delta",
                                  int_value(delta),
                                  "label",
                                  string_value(label),
                                  "trace_id",
                                  string_value(correlation_id),
                                  "allow_negative",
                                  bool_value(false))
  return encode_command_payload_text_unchecked_with_context("apply_delta", payload_text, correlation_id, state_revision)
}

fn increment_command_code() -> Int {
  return 1
}

fn decrement_command_code() -> Int {
  return 2
}

fn quit_command_code() -> Int {
  return 3
}

fn decode_command(value: String) -> Result<CounterCommand, String> {
  if value == "increment" {
    return Ok(Increment)
  }
  if value == "decrement" {
    return Ok(Decrement)
  }
  if value == "quit" {
    return Ok(Quit)
  }
  return Err("unknown thin-host command kind")
}

fn reduce_command_with_correlation(state: CounterState, command: CounterCommand, correlation_id: String) -> Result<CounterStep, String> {
  match command {
    Increment => {
      return Ok(CounterStep(CounterState(state.counter + 1, "increment", state.revision + 1),
                            false,
                            "increment_applied",
                            correlation_id))
    }
    Decrement => {
      if state.counter <= 0 {
        return Err("invalid counter transition: cannot decrement below zero")
      }
      return Ok(CounterStep(CounterState(state.counter - 1, "decrement", state.revision + 1),
                            false,
                            "decrement_applied",
                            correlation_id))
    }
    Quit => {
      return Ok(CounterStep(CounterState(state.counter, "quit", state.revision + 1),
                            true,
                            "quit_requested",
                            correlation_id))
    }
  }
}

fn reduce_command(state: CounterState, command: CounterCommand) -> Result<CounterStep, String> {
  return reduce_command_with_correlation(state, command, "local-reduce")
}

fn reduce_command_code_with_correlation(state: CounterState, kind_code: Int, correlation_id: String) -> Result<CounterStep, String> {
  if kind_code == increment_command_code() {
    return Ok(CounterStep(CounterState(state.counter + 1, "increment", state.revision + 1),
                          false,
                          "increment_applied",
                          correlation_id))
  }
  if kind_code == decrement_command_code() {
    if state.counter <= 0 {
      return Err("invalid counter transition: cannot decrement below zero")
    }
    return Ok(CounterStep(CounterState(state.counter - 1, "decrement", state.revision + 1),
                          false,
                          "decrement_applied",
                          correlation_id))
  }
  if kind_code == quit_command_code() {
    return Ok(CounterStep(CounterState(state.counter, "quit", state.revision + 1),
                          true,
                          "quit_requested",
                          correlation_id))
  }
  return Err("unknown thin-host command kind")
}

fn reduce_command_code_state(state: CounterState, kind_code: Int) -> Result<CounterState, String> {
  if kind_code == increment_command_code() {
    return Ok(CounterState(state.counter + 1, "increment", state.revision + 1))
  }
  if kind_code == decrement_command_code() {
    if state.counter <= 0 {
      return Err("invalid counter transition: cannot decrement below zero")
    }
    return Ok(CounterState(state.counter - 1, "decrement", state.revision + 1))
  }
  if kind_code == quit_command_code() {
    return Ok(CounterState(state.counter, "quit", state.revision + 1))
  }
  return Err("unknown thin-host command kind")
}

fn apply_command_envelope(state: CounterState, command: CounterCommandEnvelope) -> Result<CounterStep, String> {
  if command.state_revision != state.revision {
    return Err("stale thin-host command state_revision")
  }
  return reduce_command_with_correlation(state, decode_command(command.kind)?, command.correlation_id)
}

fn apply_command_code_envelope(state: CounterState, command: CounterCommandCodeEnvelope) -> Result<CounterStep, String> {
  if command.state_revision != state.revision {
    return Err("stale thin-host command state_revision")
  }
  return reduce_command_code_with_correlation(state, command.kind_code, command.correlation_id)
}

fn apply_command_code_state_envelope(state: CounterState, command: CounterCommandCodeEnvelope) -> Result<CounterState, String> {
  if command.state_revision != state.revision {
    return Err("stale thin-host command state_revision")
  }
  return reduce_command_code_state(state, command.kind_code)
}

fn reduce_payload_delta_state(state: CounterState, delta: Int, label: String) -> Result<CounterState, String> {
  let next_counter = state.counter + delta
  if next_counter < 0 {
    return Err("invalid counter transition: cannot apply negative payload below zero")
  }
  return Ok(CounterState(next_counter, label, state.revision + 1))
}

fn payload_command_envelope_for_state(state: CounterState, command_text: String) -> Result<ThinHostCommand, String> {
  let command = decode_command_text(command_text)?
  if command.kind() != "apply_delta" {
    return Err("unknown payload command kind")
  }
  if command.state_revision() != state.revision {
    return Err("stale thin-host command state_revision")
  }
  return Ok(command)
}

fn payload_delta_fields(command_text: String) -> Result<CounterPayloadDelta, String> {
  let delta = command_payload_int(command_text, "delta")?
  let label = command_payload_string(command_text, "label")?
  return Ok(CounterPayloadDelta(delta, label))
}

fn validate_payload_delta_contract(command: ThinHostCommand, command_text: String) -> Result<Bool, String> {
  let trace_id = command_payload_string(command_text, "trace_id")?
  if trace_id != command.correlation_id() {
    return Err("payload trace_id mismatch")
  }
  if command_payload_bool(command_text, "allow_negative")? {
    return Err("payload allow_negative is not enabled in this lane")
  }
  return Ok(true)
}

fn payload_delta_from_command(command: ThinHostCommand, command_text: String) -> Result<CounterPayloadDelta, String> {
  validate_payload_delta_contract(command, command_text)?
  return payload_delta_fields(command_text)
}

fn apply_payload_command_text_state(state: CounterState, command_text: String) -> Result<CounterState, String> {
  let command = payload_command_envelope_for_state(state, command_text)?
  let payload_delta = payload_delta_from_command(command, command_text)?
  return reduce_payload_delta_state(state, payload_delta.delta, payload_delta.label)
}

fn apply_command_text(state: CounterState, command_text: String) -> Result<CounterStep, String> {
  let command = decode_command_text(command_text)?
  return apply_command_envelope(state, command_at_revision(command.kind(), command.correlation_id(), command.state_revision()))
}
