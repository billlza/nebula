module counter_core
import bridge::host_bridge
import std::json
import std::result

struct CounterState {
  counter: Int,
  last_command: String
}

struct CounterStep {
  state: CounterState,
  should_exit: Bool,
  event_kind: String
}

enum CounterCommand {
  Increment(Void)
  Decrement(Void)
  Quit(Void)
  Unknown(Void)
}

fn initial_state() -> CounterState {
  return CounterState(0, "boot")
}

fn CounterStep_state(self: CounterStep) -> CounterState {
  return self.state
}

fn CounterStep_should_exit_value(self: CounterStep) -> Bool {
  return self.should_exit
}

fn counter_status(counter: Int) -> String {
  if counter <= 0 {
    return "idle"
  }
  if counter == 1 {
    return "active"
  }
  return "busy"
}

fn counter_payload(state: CounterState) -> Json {
  return object4("counter",
                 int_value(state.counter),
                 "can_decrement",
                 bool_value(state.counter > 0),
                 "status",
                 string_value(counter_status(state.counter)),
                 "last_command",
                 string_value(state.last_command))
}

fn query_snapshot_text(state: CounterState) -> String {
  return encode_snapshot_text("counter", counter_payload(state))
}

fn boot_event_text(state: CounterState) -> String {
  return encode_event_text("booted", counter_payload(state), false)
}

fn command_rejected_event_text(state: CounterState, reason: String) -> String {
  return encode_event_text("command_rejected",
                           object5("counter",
                                   int_value(state.counter),
                                   "can_decrement",
                                   bool_value(state.counter > 0),
                                   "status",
                                   string_value(counter_status(state.counter)),
                                   "last_command",
                                   string_value(state.last_command),
                                   "reason",
                                   string_value(reason)),
                           false)
}

fn CounterStep_event_text(self: CounterStep) -> String {
  return encode_event_text(self.event_kind, counter_payload(self.state), self.should_exit)
}

fn increment_command_text() -> String {
  return encode_command_text("increment")
}

fn decrement_command_text() -> String {
  return encode_command_text("decrement")
}

fn quit_command_text() -> String {
  return encode_command_text("quit")
}

fn decode_command(value: String) -> CounterCommand {
  if value == "increment" {
    return Increment
  }
  if value == "decrement" {
    return Decrement
  }
  if value == "quit" {
    return Quit
  }
  return Unknown
}

fn reduce_command(state: CounterState, command: CounterCommand) -> CounterStep {
  match command {
    Increment => {
      return CounterStep(CounterState(state.counter + 1, "increment"), false, "increment_applied")
    }
    Decrement => {
      return CounterStep(CounterState(state.counter - 1, "decrement"), false, "decrement_applied")
    }
    Quit => {
      return CounterStep(CounterState(state.counter, "quit"), true, "quit_requested")
    }
    Unknown => {
      return CounterStep(CounterState(state.counter, "unknown"), false, "unknown_command_ignored")
    }
  }
}

fn apply_command_text(state: CounterState, command_text: String) -> Result<CounterStep, String> {
  match decode_command_kind(command_text) {
    Ok(kind) => {
      return Ok(reduce_command(state, decode_command(kind)))
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}
