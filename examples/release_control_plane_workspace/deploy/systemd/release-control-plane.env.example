# Non-secret service-runtime knobs
NEBULA_BIND_HOST=127.0.0.1
NEBULA_PORT=40480
NEBULA_MAX_HEADER_BYTES=16384
NEBULA_MAX_BODY_BYTES=1048576
NEBULA_REQUEST_TIMEOUT_MS=15000
NEBULA_HANDLER_TIMEOUT_MS=5000
NEBULA_WRITE_TIMEOUT_MS=5000
NEBULA_KEEP_ALIVE=1
NEBULA_KEEP_ALIVE_IDLE_TIMEOUT_MS=1000
NEBULA_KEEP_ALIVE_MAX_REQUESTS=32
NEBULA_PANIC_TO_500=1
NEBULA_DRAIN_FILE=/run/release-control-plane/drain
NEBULA_SHUTDOWN_FILE=/run/release-control-plane/shutdown

# App-owned state/config
APP_DATA_BACKEND=sqlite
APP_STATE_DIR=/var/lib/release-control-plane
APP_AUTH_REQUIRED=1

# Optional JWT resource-server preview. Leave APP_AUTH_MODE unset for static token auth.
# APP_AUTH_MODE=jwt
# APP_AUTH_JWT_PREVIEW=1
# APP_AUTH_JWT_ISSUER=https://issuer.example
# APP_AUTH_JWT_AUDIENCE=release-control-plane
# APP_AUTH_JWKS_FILE=/run/release-control-plane-secrets/jwks.json

# Optional Postgres preview data plane. Leave disabled for the default SQLite deployment.
# APP_DATA_BACKEND=postgres
# APP_POSTGRES_PREVIEW=1
# APP_POSTGRES_DSN=postgresql://user:pass@127.0.0.1:5432/release_control_plane
# APP_POSTGRES_DSN_FILE=/run/release-control-plane-secrets/postgres.dsn

# Mounted secret files. Prefer these over raw APP_*_TOKEN values.
# These are read at startup and then treated as a process-local snapshot.
# Rotate the files and restart the service to apply new token values.
APP_READ_TOKEN_FILE=/run/release-control-plane-secrets/read.token
APP_WRITE_TOKEN_FILE=/run/release-control-plane-secrets/write.token
APP_ADMIN_TOKEN_FILE=/run/release-control-plane-secrets/admin.token
