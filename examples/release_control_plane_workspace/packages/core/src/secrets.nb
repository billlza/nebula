module secrets
import std::result

extern fn __release_control_plane_core_secret_value(env_name: String,
                                                    file_env_name: String) -> Result<String, String>

fn secret_value(env_name: String, file_env_name: String) -> Result<String, String> {
  return __release_control_plane_core_secret_value(env_name, file_env_name)
}
