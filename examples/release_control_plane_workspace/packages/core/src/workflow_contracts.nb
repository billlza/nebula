@test
fn test_workflow_definition_envelope_roundtrip() -> Void {
  let stages = array_build(array_push(array_builder(),
                                      WorkflowStageSpec("gate", "approval_gate", "", 0, 0).as_json()))
  let definition = WorkflowDefinition("control-plane",
                                      "prod",
                                      "internal_event",
                                      "release_apply_requested",
                                      stages,
                                      1,
                                      "admin",
                                      123)
  let envelope = WorkflowDefinitionEnvelope(definition, "req-workflow", 456)
  match workflow_definition_envelope_from_json(envelope.as_json()) {
    Ok(decoded) => {
      assert(decoded.definition.app == "control-plane", "workflow definition app drifted")
      assert(decoded.definition.channel == "prod", "workflow definition channel drifted")
      assert(decoded.definition.revision_id == 1, "workflow definition revision drifted")
      assert(decoded.request_id == "req-workflow", "workflow definition request_id drifted")
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_workflow_run_envelope_roundtrip() -> Void {
  let stage_runs = array_builder()
  stage_runs = array_push(stage_runs,
                          WorkflowStageRun(0, "gate", "approval_gate", "", "completed", 0, "", "", 0, 0, 10, "", null_value()).as_json())
  stage_runs = array_push(stage_runs,
                          WorkflowStageRun(1, "apply", "leased_task", "apply_release", "ready", 1, "", "", 0, 0, 0, "", null_value()).as_json())
  let run = WorkflowRun(9,
                        "control-plane",
                        "prod",
                        1,
                        "evt-1",
                        "release_apply_requested",
                        2,
                        "ready",
                        1,
                        "writer",
                        100,
                        0,
                        "",
                        array_build(stage_runs))
  let envelope = WorkflowRunEnvelope(run, "req-run", 200)
  match workflow_run_envelope_from_json(envelope.as_json()) {
    Ok(decoded) => {
      assert(decoded.run.run_id == 9, "workflow run id drifted")
      assert(decoded.run.status == "ready", "workflow run status drifted")
      assert(decoded.run.event_id == "evt-1", "workflow run event_id drifted")
      assert(decoded.request_id == "req-run", "workflow run request_id drifted")
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_worker_claim_envelope_roundtrip() -> Void {
  let lease = WorkerLease("lease-1",
                          9,
                          "control-plane",
                          "prod",
                          1,
                          "apply",
                          "apply_release",
                          2,
                          object1("config_revision", int_value(7)),
                          300)
  let envelope = WorkerClaimEnvelope("claimed", lease, "req-claim", 400)
  match worker_claim_envelope_from_json(envelope.as_json()) {
    Ok(decoded) => {
      assert(decoded.outcome == "claimed", "worker claim outcome drifted")
      assert(decoded.lease.lease_id == "lease-1", "worker claim lease drifted")
      assert(decoded.lease.run_id == 9, "worker claim run drifted")
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_workflow_event_submit_existing_roundtrip() -> Void {
  let stages = array_builder()
  stages = array_push(stages,
                      WorkflowStageRun(0, "approval", "approval_gate", "", "completed", 0, "", "", 0, 0, 10, "approval gate passed", null_value()).as_json())
  stages = array_push(stages,
                      WorkflowStageRun(1, "apply", "leased_task", "apply_release", "ready", 1, "", "", 0, 0, 0, "", null_value()).as_json())
  let run = WorkflowRun(12,
                        "control-plane",
                        "prod",
                        2,
                        "event-release-2",
                        "release_apply_requested",
                        3,
                        "ready",
                        1,
                        "writer",
                        100,
                        0,
                        "",
                        array_build(stages))
  let envelope = WorkflowEventSubmitEnvelope("existing", run, "req-event-existing", 500)
  match workflow_event_submit_envelope_from_json(envelope.as_json()) {
    Ok(decoded) => {
      assert(decoded.outcome == "existing", "workflow event existing outcome drifted")
      assert(decoded.run.run_id == 12, "workflow event existing run_id drifted")
      assert(decoded.run.release_revision_id == 3, "workflow event existing release revision drifted")
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_worker_complete_envelope_roundtrip() -> Void {
  let stages = array_builder()
  stages = array_push(stages,
                      WorkflowStageRun(0, "approval", "approval_gate", "", "completed", 0, "", "", 0, 0, 10, "approval gate passed", null_value()).as_json())
  stages = array_push(stages,
                      WorkflowStageRun(1,
                                       "apply",
                                       "leased_task",
                                       "apply_release",
                                       "completed",
                                       1,
                                       "lease-1-1",
                                       "ops-worker",
                                       130,
                                       120,
                                       125,
                                       "release applied locally",
                                       null_value()).as_json())
  let run = WorkflowRun(13,
                        "control-plane",
                        "prod",
                        2,
                        "event-release-3",
                        "release_apply_requested",
                        4,
                        "completed",
                        1,
                        "writer",
                        110,
                        125,
                        "workflow completed",
                        array_build(stages))
  let envelope = WorkerCompleteEnvelope(run, "req-complete", 600)
  match worker_complete_envelope_from_json(envelope.as_json()) {
    Ok(decoded) => {
      assert(decoded.run.status == "completed", "worker complete run status drifted")
      assert(decoded.run.finished_unix_ms == 125, "worker complete finished_unix_ms drifted")
      assert(decoded.request_id == "req-complete", "worker complete request_id drifted")
    }
    Err(msg) => {
      panic(msg)
    }
  }
}
