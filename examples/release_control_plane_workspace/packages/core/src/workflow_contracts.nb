fn idle_worker_lease() -> WorkerLease {
  return WorkerLease("", 0, "", "", 0, "", "", 0, null_value(), 0)
}

fn WorkflowStageSpec_as_json(self: WorkflowStageSpec) -> Json {
  return object5("name",
                 string_value(self.name),
                 "kind",
                 string_value(self.kind),
                 "task_kind",
                 string_value(self.task_kind),
                 "timeout_s",
                 int_value(self.timeout_s),
                 "max_attempts",
                 int_value(self.max_attempts))
}

fn WorkflowPutRequest_as_json(self: WorkflowPutRequest) -> Json {
  return object3("trigger_kind",
                 string_value(self.trigger_kind),
                 "event_kind",
                 string_value(self.event_kind),
                 "stages",
                 self.stages)
}

fn WorkflowDefinition_as_json(self: WorkflowDefinition) -> Json {
  return object7("app",
                 string_value(self.app),
                 "channel",
                 string_value(self.channel),
                 "trigger_kind",
                 string_value(self.trigger_kind),
                 "event_kind",
                 string_value(self.event_kind),
                 "stages",
                 self.stages,
                 "revision_id",
                 int_value(self.revision_id),
                 "meta",
                 object2("updated_by",
                         string_value(self.updated_by),
                         "updated_unix_ms",
                         int_value(self.updated_unix_ms)))
}

fn WorkflowDefinitionEnvelope_as_json(self: WorkflowDefinitionEnvelope) -> Json {
  return object3("definition",
                 self.definition.as_json(),
                 "request_id",
                 string_value(self.request_id),
                 "unix_ms",
                 int_value(self.unix_ms))
}

