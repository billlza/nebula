fn optional_result_payload(value: Json) -> Json {
  match get_value(value, "result_payload") {
    Ok(payload) => {
      return payload
    }
    Err(_) => {
      return null_value()
    }
  }
}

fn workflow_stage_spec_from_json(value: Json) -> Result<WorkflowStageSpec, String> {
  return Ok(WorkflowStageSpec(get_string(value, "name")?,
                              get_string(value, "kind")?,
                              get_string(value, "task_kind")?,
                              get_int(value, "timeout_s")?,
                              get_int(value, "max_attempts")?))
}

fn workflow_stage_run_meta_from_json(value: Json) -> Result<WorkflowStageRunMetaFields, String> {
  return Ok(WorkflowStageRunMetaFields(get_string(value, "worker_id")?,
                                       get_int(value, "lease_expires_unix_ms")?,
                                       get_int(value, "started_unix_ms")?,
                                       get_int(value, "finished_unix_ms")?,
                                       get_string(value, "result_message")?,
                                       optional_result_payload(value)))
}

fn workflow_stage_run_fields_from_json(value: Json) -> Result<WorkflowStageRunFields, String> {
  return Ok(WorkflowStageRunFields(get_int(value, "stage_index")?,
                                   get_string(value, "stage_name")?,
                                   get_string(value, "kind")?,
                                   get_string(value, "task_kind")?,
                                   get_string(value, "status")?,
                                   get_int(value, "attempt")?,
                                   get_string(value, "lease_id")?))
}

fn workflow_stage_run_from_json(value: Json) -> Result<WorkflowStageRun, String> {
  let fields = workflow_stage_run_fields_from_json(value)?
  let meta = workflow_stage_run_meta_from_json(get_value(value, "meta")?)?
  return Ok(WorkflowStageRun(fields.stage_index,
                             fields.stage_name,
                             fields.kind,
                             fields.task_kind,
                             fields.status,
                             fields.attempt,
                             fields.lease_id,
                             meta.worker_id,
                             meta.lease_expires_unix_ms,
                             meta.started_unix_ms,
                             meta.finished_unix_ms,
                             meta.result_message,
                             meta.result_payload))
}

