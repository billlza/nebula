module workflow_contracts
import std::json
import std::result

struct WorkflowStageSpec {
  name: String
  kind: String
  task_kind: String
  timeout_s: Int
  max_attempts: Int
}

struct WorkflowPutRequest {
  trigger_kind: String
  event_kind: String
  stages: Json
}

struct WorkflowDefinition {
  app: String
  channel: String
  trigger_kind: String
  event_kind: String
  stages: Json
  revision_id: Int
  updated_by: String
  updated_unix_ms: Int
}

struct WorkflowDefinitionEnvelope {
  definition: WorkflowDefinition
