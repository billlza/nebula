  request_id: String
  unix_ms: Int
}

struct AuditEvent {
  event_id: Int
  app: String
  channel: String
  event_kind: String
  actor: String
  release_revision_id: Int
  apply_run_id: Int
  message: String
  payload: Json
  unix_ms: Int
}

struct AuditListEnvelope {
  app: String
  channel: String
  events: Json
  request_id: String
  unix_ms: Int
}

struct ReleaseIdentityFields {
  app: String
  channel: String
}

struct ReleaseStateFields {
  revision_id: Int
