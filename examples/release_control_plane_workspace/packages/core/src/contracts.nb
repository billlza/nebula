  decision: String
  reason: String
  decided_by: String
  decided_unix_ms: Int
}

struct ApprovalDecisionEnvelope {
  decision: ApprovalDecision
  request_id: String
  unix_ms: Int
}

struct ApplyRun {
  run_id: Int
  app: String
  channel: String
  release_revision_id: Int
  status: String
  requested_by: String
  requested_unix_ms: Int
  started_unix_ms: Int
  finished_unix_ms: Int
  runner_id: String
  result_message: String
}

struct ApplyRunEnvelope {
  run: ApplyRun
  request_id: String
  unix_ms: Int
}

struct ApplyRunnerOnceEnvelope {
  outcome: String
