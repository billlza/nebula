fn service_info_from_json(value: Json) -> Result<ServiceInfo, String> {
  let service = get_string(value, "service")?
  let version = get_string(value, "version")?
  let profile = get_string(value, "profile")?
  let request_id = get_string(value, "request_id")?
  let unix_ms = get_int(value, "unix_ms")?
  return Ok(ServiceInfo(service, version, profile, request_id, unix_ms))
}

fn whoami_envelope_from_json(value: Json) -> Result<WhoAmIEnvelope, String> {
  let auth_enabled = get_bool(value, "auth_enabled")?
  let actor = get_string(value, "actor")?
  let role = get_string(value, "role")?
  let request_id = get_string(value, "request_id")?
  let unix_ms = get_int(value, "unix_ms")?
  return Ok(WhoAmIEnvelope(auth_enabled, actor, role, request_id, unix_ms))
}

fn release_put_request_from_json(value: Json) -> Result<ReleasePutRequest, String> {
  let version = get_string(value, "version")?
  let config_revision = get_int(value, "config_revision")?
  let description = get_string(value, "description")?
  return Ok(ReleasePutRequest(version, config_revision, description))
}

fn approval_decision_request_from_json(value: Json) -> Result<ApprovalDecisionRequest, String> {
  let decision = get_string(value, "decision")?
  let reason = get_string(value, "reason")?
  return Ok(ApprovalDecisionRequest(decision, reason))
}

fn release_identity_fields_from_json(value: Json) -> Result<ReleaseIdentityFields, String> {
  let app = get_string(value, "app")?
  let channel = get_string(value, "channel")?
  return Ok(ReleaseIdentityFields(app, channel))
}

fn release_state_fields_from_json(value: Json) -> Result<ReleaseStateFields, String> {
  let meta = get_value(value, "meta")?
  let revision_id = get_int(value, "revision_id")?
  let updated_by = get_string(meta, "updated_by")?
  let updated_unix_ms = get_int(meta, "updated_unix_ms")?
  return Ok(ReleaseStateFields(revision_id, updated_by, updated_unix_ms))
}

fn apply_run_timing_meta_from_json(value: Json) -> Result<Json, String> {
  return get_value(value, "meta")
}

fn apply_run_timing_fields_from_meta(meta: Json) -> Result<ApplyRunTimingFields, String> {
  let requested_unix_ms = get_int(meta, "requested_unix_ms")?
  let started_unix_ms = get_int(meta, "started_unix_ms")?
  let finished_unix_ms = get_int(meta, "finished_unix_ms")?
  let runner_id = get_string(meta, "runner_id")?
  let result_message = get_string(meta, "result_message")?
  return Ok(ApplyRunTimingFields(requested_unix_ms,
                                 started_unix_ms,
                                 finished_unix_ms,
                                 runner_id,
                                 result_message))
}

fn apply_run_timing_fields_from_json(value: Json) -> Result<ApplyRunTimingFields, String> {
  let meta = apply_run_timing_meta_from_json(value)?
  return apply_run_timing_fields_from_meta(meta)
}

fn approval_decision_body_fields_from_json(value: Json) -> Result<ApprovalDecisionBodyFields, String> {
  let release_revision_id = get_int(value, "release_revision_id")?
  let decision = get_string(value, "decision")?
  let reason = get_string(value, "reason")?
  return Ok(ApprovalDecisionBodyFields(release_revision_id, decision, reason))
}

fn approval_decision_meta_fields_from_json(value: Json) -> Result<ApprovalDecisionMetaFields, String> {
  let meta = get_value(value, "meta")?
  let decided_by = get_string(meta, "decided_by")?
  let decided_unix_ms = get_int(meta, "decided_unix_ms")?
  return Ok(ApprovalDecisionMetaFields(decided_by, decided_unix_ms))
}

fn apply_run_core_fields_from_json(value: Json) -> Result<ApplyRunCoreFields, String> {
  let run_id = get_int(value, "run_id")?
  let release_revision_id = get_int(value, "release_revision_id")?
  let status = get_string(value, "status")?
  let requested_by = get_string(value, "requested_by")?
  return Ok(ApplyRunCoreFields(run_id, release_revision_id, status, requested_by))
}

fn audit_event_core_fields_from_json(value: Json) -> Result<AuditEventCoreFields, String> {
  let event_id = get_int(value, "event_id")?
  let event_kind = get_string(value, "event_kind")?
  let message = get_string(value, "message")?
  let payload = get_value(value, "payload")?
  return Ok(AuditEventCoreFields(event_id, event_kind, message, payload))
}

fn audit_event_meta_fields_from_json(value: Json) -> Result<AuditEventMetaFields, String> {
  let meta = get_value(value, "meta")?
  let actor = get_string(meta, "actor")?
  let release_revision_id = get_int(meta, "release_revision_id")?
  let apply_run_id = get_int(meta, "apply_run_id")?
  let unix_ms = get_int(meta, "unix_ms")?
  return Ok(AuditEventMetaFields(actor, release_revision_id, apply_run_id, unix_ms))
}

fn envelope_metadata_from_json(value: Json) -> Result<EnvelopeMetadata, String> {
  let request_id = get_string(value, "request_id")?
  let unix_ms = get_int(value, "unix_ms")?
  return Ok(EnvelopeMetadata(request_id, unix_ms))
}

fn release_entry_from_json(value: Json) -> Result<ReleaseEntry, String> {
  let identity = release_identity_fields_from_json(value)?
  let version = get_string(value, "version")?
  let config_revision = get_int(value, "config_revision")?
  let description = get_string(value, "description")?
  let state = release_state_fields_from_json(value)?
  return Ok(ReleaseEntry(identity.app,
                         identity.channel,
                         version,
                         config_revision,
                         description,
                         state.revision_id,
                         state.updated_by,
                         state.updated_unix_ms))
}

fn release_entry_envelope_from_json(value: Json) -> Result<ReleaseEntryEnvelope, String> {
  let entry_json = get_value(value, "entry")?
  let entry = release_entry_from_json(entry_json)?
  let metadata = envelope_metadata_from_json(value)?
  return Ok(ReleaseEntryEnvelope(entry, metadata.request_id, metadata.unix_ms))
}

fn release_list_envelope_from_json(value: Json) -> Result<ReleaseListEnvelope, String> {
  let app = get_string(value, "app")?
  let releases = get_value(value, "releases")?
  let metadata = envelope_metadata_from_json(value)?
  return Ok(ReleaseListEnvelope(app, releases, metadata.request_id, metadata.unix_ms))
}

fn approval_decision_from_fields(identity: ReleaseIdentityFields,
                                 body: ApprovalDecisionBodyFields,
                                 meta: ApprovalDecisionMetaFields) -> ApprovalDecision {
  return ApprovalDecision(identity.app,
                          identity.channel,
                          body.release_revision_id,
                          body.decision,
                          body.reason,
                          meta.decided_by,
                          meta.decided_unix_ms)
}

fn approval_decision_from_json(value: Json) -> Result<ApprovalDecision, String> {
  let identity = release_identity_fields_from_json(value)?
  let body = approval_decision_body_fields_from_json(value)?
  let meta = approval_decision_meta_fields_from_json(value)?
  return Ok(approval_decision_from_fields(identity, body, meta))
}

fn approval_decision_envelope_from_json(value: Json) -> Result<ApprovalDecisionEnvelope, String> {
  let decision_json = get_value(value, "decision")?
  let decision = approval_decision_from_json(decision_json)?
  let metadata = envelope_metadata_from_json(value)?
  return Ok(ApprovalDecisionEnvelope(decision, metadata.request_id, metadata.unix_ms))
}

fn apply_run_from_fields(identity: ReleaseIdentityFields,
                         core: ApplyRunCoreFields,
                         timing: ApplyRunTimingFields) -> ApplyRun {
  return ApplyRun(core.run_id,
                  identity.app,
                  identity.channel,
                  core.release_revision_id,
                  core.status,
                  core.requested_by,
                  timing.requested_unix_ms,
                  timing.started_unix_ms,
                  timing.finished_unix_ms,
                  timing.runner_id,
                  timing.result_message)
}

fn apply_run_from_json(value: Json) -> Result<ApplyRun, String> {
  let identity = release_identity_fields_from_json(value)?
  let core = apply_run_core_fields_from_json(value)?
  let timing = apply_run_timing_fields_from_json(value)?
  return Ok(apply_run_from_fields(identity, core, timing))
}

fn apply_run_envelope_from_json(value: Json) -> Result<ApplyRunEnvelope, String> {
  let run_json = get_value(value, "run")?
  let run = apply_run_from_json(run_json)?
  let metadata = envelope_metadata_from_json(value)?
  return Ok(ApplyRunEnvelope(run, metadata.request_id, metadata.unix_ms))
}

fn apply_runner_once_envelope_from_json(value: Json) -> Result<ApplyRunnerOnceEnvelope, String> {
  let outcome = get_string(value, "outcome")?
  let run_json = get_value(value, "run")?
  let run = apply_run_from_json(run_json)?
  let metadata = envelope_metadata_from_json(value)?
  return Ok(ApplyRunnerOnceEnvelope(outcome, run, metadata.request_id, metadata.unix_ms))
}

fn audit_event_from_fields(identity: ReleaseIdentityFields,
                           core: AuditEventCoreFields,
                           meta: AuditEventMetaFields) -> AuditEvent {
  return AuditEvent(core.event_id,
                    identity.app,
                    identity.channel,
                    core.event_kind,
                    meta.actor,
                    meta.release_revision_id,
                    meta.apply_run_id,
                    core.message,
                    core.payload,
                    meta.unix_ms)
}

fn audit_event_from_json(value: Json) -> Result<AuditEvent, String> {
  let identity = release_identity_fields_from_json(value)?
  let core = audit_event_core_fields_from_json(value)?
  let meta = audit_event_meta_fields_from_json(value)?
  return Ok(audit_event_from_fields(identity, core, meta))
}

fn audit_list_envelope_from_json(value: Json) -> Result<AuditListEnvelope, String> {
  let identity = release_identity_fields_from_json(value)?
  let events = get_value(value, "events")?
  let metadata = envelope_metadata_from_json(value)?
  return Ok(AuditListEnvelope(identity.app,
                              identity.channel,
                              events,
                              metadata.request_id,
                              metadata.unix_ms))
}

@test
fn test_release_entry_envelope_roundtrip() -> Void {
  let entry = ReleaseEntry("control-plane", "prod", "2026.04.21", 7, "initial", 1, "writer", 123)
  let envelope = ReleaseEntryEnvelope(entry, "req-1", 456)
  match release_entry_envelope_from_json(envelope.as_json()) {
    Ok(decoded) => {
      assert(decoded.entry.app == "control-plane", "release entry app drifted")
      assert(decoded.entry.channel == "prod", "release entry channel drifted")
      assert(decoded.entry.version == "2026.04.21", "release entry version drifted")
      assert(decoded.entry.config_revision == 7, "release entry config revision drifted")
      assert(decoded.entry.revision_id == 1, "release entry revision drifted")
      assert(decoded.entry.updated_by == "writer", "release entry actor drifted")
      assert(decoded.request_id == "req-1", "release entry request_id drifted")
      assert(decoded.unix_ms == 456, "release entry unix_ms drifted")
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_release_list_envelope_roundtrip() -> Void {
  let builder = array_builder()
  builder = array_push(builder, ReleaseEntry("control-plane", "prod", "2026.04.21", 7, "", 1, "writer", 123).as_json())
  builder = array_push(builder, ReleaseEntry("control-plane", "staging", "2026.04.22", 8, "", 2, "writer", 124).as_json())
  let envelope = ReleaseListEnvelope("control-plane", array_build(builder), "req-2", 789)
  match release_list_envelope_from_json(envelope.as_json()) {
    Ok(decoded) => {
      match array_len(decoded.releases) {
        Ok(count) => {
          assert(decoded.app == "control-plane", "release list app drifted")
          assert(decoded.request_id == "req-2", "release list request_id drifted")
          assert(decoded.unix_ms == 789, "release list unix_ms drifted")
          assert(count == 2, "release list count drifted")
        }
        Err(msg) => {
          panic(msg)
        }
      }
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_approval_decision_envelope_roundtrip() -> Void {
  let decision = ApprovalDecision("control-plane", "prod", 2, "approved", "ship it", "admin", 222)
  let envelope = ApprovalDecisionEnvelope(decision, "req-3", 333)
  match approval_decision_envelope_from_json(envelope.as_json()) {
    Ok(decoded) => {
      assert(decoded.decision.app == "control-plane", "approval app drifted")
      assert(decoded.decision.channel == "prod", "approval channel drifted")
      assert(decoded.decision.release_revision_id == 2, "approval release revision drifted")
      assert(decoded.decision.decision == "approved", "approval decision drifted")
      assert(decoded.decision.reason == "ship it", "approval reason drifted")
      assert(decoded.decision.decided_by == "admin", "approval actor drifted")
      assert(decoded.request_id == "req-3", "approval request_id drifted")
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_apply_run_envelope_roundtrip() -> Void {
  let run = ApplyRun(4, "control-plane", "prod", 2, "applied", "writer", 10, 11, 12, "local-runner", "release applied locally")
  let envelope = ApplyRunEnvelope(run, "req-4", 444)
  match apply_run_envelope_from_json(envelope.as_json()) {
    Ok(decoded) => {
      assert(decoded.run.run_id == 4, "apply run id drifted")
      assert(decoded.run.status == "applied", "apply status drifted")
      assert(decoded.run.requested_by == "writer", "apply requested_by drifted")
      assert(decoded.run.runner_id == "local-runner", "apply runner_id drifted")
      assert(decoded.run.result_message == "release applied locally", "apply result drifted")
      assert(decoded.request_id == "req-4", "apply request_id drifted")
    }
    Err(msg) => {
      panic(msg)
    }
  }
}

@test
fn test_audit_list_envelope_roundtrip() -> Void {
  let builder = array_builder()
  builder = array_push(builder,
                       AuditEvent(1,
                                  "control-plane",
                                  "prod",
                                  "release_upserted",
                                  "writer",
                                  2,
                                  0,
                                  "release desired state updated",
                                  object1("version", string_value("2026.04.21")),
                                  555).as_json())
  let envelope = AuditListEnvelope("control-plane", "prod", array_build(builder), "req-5", 666)
  match audit_list_envelope_from_json(envelope.as_json()) {
    Ok(decoded) => {
      match array_len(decoded.events) {
        Ok(count) => {
          assert(decoded.app == "control-plane", "audit app drifted")
          assert(decoded.channel == "prod", "audit channel drifted")
          assert(decoded.request_id == "req-5", "audit request_id drifted")
          assert(count == 1, "audit count drifted")
        }
        Err(msg) => {
          panic(msg)
        }
      }
    }
    Err(msg) => {
      panic(msg)
    }
  }
}
