module contracts
import std::json
import std::result

struct ServiceInfo {
  service: String
  version: String
  profile: String
  request_id: String
  unix_ms: Int
}

struct WhoAmIEnvelope {
  auth_enabled: Bool
  actor: String
  role: String
  request_id: String
  unix_ms: Int
}

struct ReleasePutRequest {
  version: String
  config_revision: Int
  description: String
}

struct ReleaseEntry {
  app: String
  channel: String
  version: String
  config_revision: Int
  description: String
  revision_id: Int
  updated_by: String
  updated_unix_ms: Int
}

struct ReleaseEntryEnvelope {
  entry: ReleaseEntry
  request_id: String
  unix_ms: Int
}

struct ReleaseListEnvelope {
