module args
import core::app
import core::validate
import std::env
import std::json
import std::result

struct ParsedArgs {
  url_override: String
  token_override: String
  ca_file_override: String
  json_mode: Bool
  command: String
  subcommand: String
  command_argv: JsonArrayBuilder
  app_name: String
  channel: String
  key: String
  if_match_text: String
  version_text: String
  config_revision_text: String
  description: String
  decision_text: String
  reason_text: String
  value_kind: String
  value_text: String
}

struct ParseProgress {
  parsed: ParsedArgs
  next_index: Int
}

fn usage() -> Void {
  print("usage: ctl [--url http://host:port[/prefix]] [--token TOKEN] [--ca-file PATH] [--json] <status|info|control-plane-validate|release|config|workflow|worker|schedule|broker|webhook|shell|deploy|approval|audit|auth|runner|platform> ...")
  print("release put/apply, approval decide, config put/delete support --if-match REVISION for optimistic concurrency")
}

fn empty_text() -> String {
  return text_concat("", "")
}

fn empty_command_argv() -> JsonArrayBuilder {
  return array_builder()
}

fn default_args() -> ParsedArgs {
  return ParsedArgs(empty_text(),
                    empty_text(),
                    empty_text(),
                    false,
                    empty_text(),
                    empty_text(),
                    empty_command_argv(),
                    empty_text(),
                    empty_text(),
                    empty_text(),
                    empty_text(),
                    empty_text(),
                    empty_text(),
                    empty_text(),
                    empty_text(),
                    empty_text(),
                    empty_text(),
                    empty_text())
}

fn rebuild_args(url_override: String,
                token_override: String,
                ca_file_override: String,
                json_mode: Bool,
                command: String,
                subcommand: String,
                command_argv: JsonArrayBuilder,
                app_name: String,
                channel: String,
                key: String,
                if_match_text: String,
                version_text: String,
                config_revision_text: String,
                description: String,
                decision_text: String,
                reason_text: String,
                value_kind: String,
                value_text: String) -> ParsedArgs {
  return ParsedArgs(url_override,
                    token_override,
                    ca_file_override,
                    json_mode,
                    command,
                    subcommand,
                    command_argv,
                    app_name,
                    channel,
                    key,
                    if_match_text,
                    version_text,
                    config_revision_text,
                    description,
                    decision_text,
                    reason_text,
                    value_kind,
                    value_text)
}

fn with_url_override(parsed: ParsedArgs, value: String) -> ParsedArgs {
  return rebuild_args(value,
                      parsed.token_override,
                      parsed.ca_file_override,
                      parsed.json_mode,
                      parsed.command,
                      parsed.subcommand,
                      parsed.command_argv,
                      parsed.app_name,
                      parsed.channel,
                      parsed.key,
                      parsed.if_match_text,
                      parsed.version_text,
                      parsed.config_revision_text,
                      parsed.description,
                      parsed.decision_text,
                      parsed.reason_text,
                      parsed.value_kind,
                      parsed.value_text)
}

