module schedule
import args
import client
import core::schedule_contracts
import core::validate
import errors
import std::fs
import std::json
import std::result

struct ScheduleCliArgs {
  subcommand: String
  app_name: String
  channel: String
  schedule_id: String
  event_kind_text: String
  release_revision_text: String
  interval_ms_text: String
  next_due_unix_ms_text: String
  now_unix_ms_text: String
  payload_file: String
}

struct ScheduleParseProgress {
  parsed: ScheduleCliArgs
  next_index: Int
}

fn default_schedule_args() -> ScheduleCliArgs {
  return ScheduleCliArgs("", "", "", "", "", "", "", "", "", "")
}

fn rebuild_schedule_args(subcommand: String,
                         app_name: String,
                         channel: String,
                         schedule_id: String,
                         event_kind_text: String,
                         release_revision_text: String,
                         interval_ms_text: String,
                         next_due_unix_ms_text: String,
                         now_unix_ms_text: String,
                         payload_file: String) -> ScheduleCliArgs {
  return ScheduleCliArgs(subcommand,
                         app_name,
                         channel,
                         schedule_id,
                         event_kind_text,
                         release_revision_text,
                         interval_ms_text,
                         next_due_unix_ms_text,
                         now_unix_ms_text,
                         payload_file)
}

fn schedule_with_subcommand(parsed: ScheduleCliArgs, value: String) -> ScheduleCliArgs {
  return rebuild_schedule_args(value,
                               parsed.app_name,
                               parsed.channel,
                               parsed.schedule_id,
                               parsed.event_kind_text,
                               parsed.release_revision_text,
                               parsed.interval_ms_text,
                               parsed.next_due_unix_ms_text,
                               parsed.now_unix_ms_text,
                               parsed.payload_file)
}

