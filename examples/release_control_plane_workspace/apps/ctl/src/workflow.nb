module workflow
import args
import client
import core::validate
import core::workflow_contracts
import core::workflow_validate
import errors
import std::fs
import std::json
import std::result

struct WorkflowCliArgs {
  subcommand: String
  detail_subcommand: String
  app_name: String
  channel: String
  if_match_text: String
  run_id_text: String
  event_id_text: String
  event_kind_text: String
  release_revision_text: String
  spec_file: String
  payload_file: String
}

struct WorkflowParseProgress {
  parsed: WorkflowCliArgs
  next_index: Int
}

fn workflow_args() -> WorkflowCliArgs {
  return WorkflowCliArgs("", "", "", "", "", "", "", "", "", "", "")
}

fn workflow_rebuild_args(subcommand: String,
                         detail_subcommand: String,
                         app_name: String,
                         channel: String,
                         if_match_text: String,
                         run_id_text: String,
                         event_id_text: String,
                         event_kind_text: String,
                         release_revision_text: String,
                         spec_file: String,
                         payload_file: String) -> WorkflowCliArgs {
  return WorkflowCliArgs(subcommand,
                         detail_subcommand,
                         app_name,
                         channel,
                         if_match_text,
                         run_id_text,
                         event_id_text,
                         event_kind_text,
                         release_revision_text,
                         spec_file,
                         payload_file)
}

fn workflow_with_subcommand(parsed: WorkflowCliArgs, value: String) -> WorkflowCliArgs {
  return workflow_rebuild_args(value,
                               parsed.detail_subcommand,
                               parsed.app_name,
                               parsed.channel,
                               parsed.if_match_text,
                               parsed.run_id_text,
                               parsed.event_id_text,
                               parsed.event_kind_text,
                               parsed.release_revision_text,
                               parsed.spec_file,
                               parsed.payload_file)
}

fn workflow_with_detail_subcommand(parsed: WorkflowCliArgs, value: String) -> WorkflowCliArgs {
  return workflow_rebuild_args(parsed.subcommand,
                               value,
                               parsed.app_name,
                               parsed.channel,
                               parsed.if_match_text,
                               parsed.run_id_text,
                               parsed.event_id_text,
                               parsed.event_kind_text,
                               parsed.release_revision_text,
                               parsed.spec_file,
                               parsed.payload_file)
}

