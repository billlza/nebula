module deploy
import args
import client
import core::validate
import core::workflow_contracts
import core::workflow_validate
import errors
import std::fs
import std::json
import std::result

struct DeployCliArgs {
  subcommand: String
  detail_subcommand: String
  file: String
  app_name: String
  channel: String
  target: String
  event_id: String
  release_revision_text: String
  target_file: String
  command_id: String
}

struct DeployParseProgress {
  parsed: DeployCliArgs
  next_index: Int
}

struct DeployTargetEntry {
  id: String
  command_id: String
  args: Json
}

fn deploy_args() -> DeployCliArgs {
  return DeployCliArgs("", "", "", "", "", "", "", "", "", "")
}

fn deploy_rebuild_args(subcommand: String,
                       detail_subcommand: String,
                       file: String,
                       app_name: String,
                       channel: String,
                       target: String,
                       event_id: String,
                       release_revision_text: String,
                       target_file: String,
                       command_id: String) -> DeployCliArgs {
  return DeployCliArgs(subcommand,
                       detail_subcommand,
                       file,
                       app_name,
                       channel,
                       target,
                       event_id,
                       release_revision_text,
                       target_file,
                       command_id)
}

fn deploy_with_subcommand(parsed: DeployCliArgs, value: String) -> DeployCliArgs {
  return deploy_rebuild_args(value,
                             parsed.detail_subcommand,
                             parsed.file,
                             parsed.app_name,
                             parsed.channel,
                             parsed.target,
                             parsed.event_id,
                             parsed.release_revision_text,
                             parsed.target_file,
                             parsed.command_id)
}

fn deploy_with_detail(parsed: DeployCliArgs, value: String) -> DeployCliArgs {
  return deploy_rebuild_args(parsed.subcommand,
                             value,
                             parsed.file,
                             parsed.app_name,
                             parsed.channel,
                             parsed.target,
                             parsed.event_id,
                             parsed.release_revision_text,
                             parsed.target_file,
                             parsed.command_id)
}

