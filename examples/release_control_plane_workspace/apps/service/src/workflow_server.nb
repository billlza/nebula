fn worker_complete_request_from_http(ctx: RequestContext,
                                     request: Request,
                                     lease_id: String) -> Result<WorkerCompleteRequest, Response> {
  let payload = workflow_json_body(ctx, request)?
  match worker_complete_request_from_payload(ctx, payload) {
    Ok(value) => {
      match validate_worker_complete_request_for_lease(lease_id, value) {
        Ok(_) => {
          return Ok(value)
        }
        Err(msg) => {
          return Err(for_request(400, ctx, "invalid_worker_complete", msg))
        }
      }
    }
    Err(response) => {
      return Err(response)
    }
  }
}

fn lease_id_from_pattern(ctx: RequestContext, request: Request, pattern: String) -> Result<String, Response> {
  match route_param1(pattern, request) {
    Ok(lease_id) => {
      if lease_id == "" {
        return Err(for_request(400, ctx, "invalid_worker_lease", "worker lease_id must be non-empty"))
      }
      return Ok(lease_id)
    }
    Err(msg) => {
      return Err(for_request(400, ctx, "invalid_worker_route", msg))
    }
  }
}

fn workflow_definition_put_input_from_request(ctx: RequestContext, request: Request) -> Result<WorkflowDefinitionPutInput, Response> {
  let identity = workflow_scope_identity_from_request(ctx, request, workflow_definition_pattern())?
  let expected_revision_id = workflow_expected_revision_from_request(ctx, request)?
  let put_request = workflow_put_request_from_http(ctx, request)?
  return Ok(WorkflowDefinitionPutInput(identity, expected_revision_id, put_request))
}

fn workflow_event_submit_input_from_request(ctx: RequestContext, request: Request) -> Result<WorkflowEventSubmitInput, Response> {
  let identity = workflow_scope_identity_from_request(ctx, request, workflow_events_pattern())?
  let submit_request = workflow_event_submit_request_from_http(ctx, request)?
  return Ok(WorkflowEventSubmitInput(identity, submit_request))
}

fn worker_heartbeat_input_from_request(ctx: RequestContext, request: Request) -> Result<WorkerHeartbeatInput, Response> {
  let lease_id = lease_id_from_pattern(ctx, request, worker_heartbeat_pattern())?
  let heartbeat_request = worker_heartbeat_request_from_http(ctx, request)?
  return Ok(WorkerHeartbeatInput(lease_id, heartbeat_request))
}

fn worker_complete_input_from_request(ctx: RequestContext, request: Request) -> Result<WorkerCompleteInput, Response> {
  let lease_id = lease_id_from_pattern(ctx, request, worker_complete_pattern())?
  let complete_request = worker_complete_request_from_http(ctx, request, lease_id)?
  return Ok(WorkerCompleteInput(lease_id, complete_request))
}

fn workflow_event_submit_error_response(ctx: RequestContext,
                                        input: WorkflowEventSubmitInput,
                                        msg: String) -> Result<Response, String> {
  if msg == "workflow definition not found" {
    return missing_workflow_definition(ctx, input.identity.app, input.identity.channel)
  }
  if msg == "release revision not found" {
    return missing_release_revision(ctx,
                                    input.identity.app,
                                    input.identity.channel,
                                    input.submit_request.release_revision_id)
  }
  if msg == "workflow event kind is not enabled for this definition" {
    return invalid_workflow_request(ctx, "workflow_event_not_enabled", msg)
  }
  return Err(msg)
}

fn worker_lease_route_error_response(ctx: RequestContext, lease_id: String, msg: String) -> Result<Response, String> {
  if msg == "worker lease not found" {
    return missing_worker_lease(ctx, lease_id)
  }
  if msg == "worker lease belongs to a different worker" {
    return conflicted_worker_lease(ctx, "worker_lease_owner_mismatch", msg)
  }
  if msg == "worker lease is not active" {
    return conflicted_worker_lease(ctx, "worker_lease_not_active", msg)
  }
  return Err(msg)
}

async fn handle_workflow_definition_get_route(ctx: RequestContext, request: Request) -> Result<Response, String> {
  return await reject_when_draining_result(ctx, request, handle_workflow_definition_get_route_authorized)
}

async fn handle_workflow_definition_get_route_authorized(ctx: RequestContext, request: Request) -> Result<Response, String> {
  return await authorize_permission_result(ctx, request, jobs_definition_read_permission(), handle_workflow_definition_get_route_inner)
}

async fn handle_workflow_definition_get_route_inner(ctx: RequestContext, request: Request) -> Result<Response, String> {
  match workflow_scope_identity_from_request(ctx, request, workflow_definition_pattern()) {
    Ok(identity) => {
      match ensure_workflow_permission_scope(ctx, jobs_definition_read_permission(), identity.app, identity.channel) {
        Ok(_) => {}
        Err(response) => { return Ok(response) }
      }
      match load_workflow_definition(identity.app, identity.channel) {
        Ok(definition) => {
          return workflow_definition_response(ctx, definition)
        }
        Err(msg) => {
          if msg == "workflow definition not found" {
            return missing_workflow_definition(ctx, identity.app, identity.channel)
          }
          return Err(msg)
        }
      }
    }
    Err(response) => {
      return Ok(response)
    }
  }
}

async fn handle_workflow_definition_put_route(ctx: RequestContext, request: Request) -> Result<Response, String> {
  return await reject_when_draining_result(ctx, request, handle_workflow_definition_put_route_authorized)
}

async fn handle_workflow_definition_put_route_authorized(ctx: RequestContext, request: Request) -> Result<Response, String> {
  return await authorize_permission_result(ctx, request, jobs_definition_write_permission(), handle_workflow_definition_put_route_inner)
}

async fn handle_workflow_definition_put_route_inner(ctx: RequestContext, request: Request) -> Result<Response, String> {
  let updated_by = updated_by_actor(ctx)?
  match workflow_definition_put_input_from_request(ctx, request) {
    Ok(input) => {
      match ensure_workflow_permission_scope(ctx,
                                             jobs_definition_write_permission(),
                                             input.identity.app,
                                             input.identity.channel) {
        Ok(_) => {}
        Err(response) => { return Ok(response) }
      }
      let outcome = write_workflow_definition(input.identity.app,
                                             input.identity.channel,
                                             input.put_request,
                                             input.expected_revision_id,
                                             updated_by)?
      return workflow_definition_outcome_response(ctx, outcome)
    }
    Err(response) => {
      return Ok(response)
    }
  }
}

async fn handle_workflow_runs_route(ctx: RequestContext, request: Request) -> Result<Response, String> {
  return await reject_when_draining_result(ctx, request, handle_workflow_runs_route_authorized)
}

async fn handle_workflow_runs_route_authorized(ctx: RequestContext, request: Request) -> Result<Response, String> {
  return await authorize_permission_result(ctx, request, jobs_run_read_permission(), handle_workflow_runs_route_inner)
}

async fn handle_workflow_runs_route_inner(ctx: RequestContext, request: Request) -> Result<Response, String> {
  match workflow_scope_identity_from_request(ctx, request, workflow_runs_pattern()) {
    Ok(identity) => {
      match ensure_workflow_permission_scope(ctx, jobs_run_read_permission(), identity.app, identity.channel) {
        Ok(_) => {}
        Err(response) => { return Ok(response) }
      }
      let runs = load_workflow_runs(identity.app, identity.channel)?
      return workflow_run_list_response(ctx, identity.app, identity.channel, runs)
    }
    Err(response) => {
      return Ok(response)
    }
  }
}

async fn handle_workflow_run_route(ctx: RequestContext, request: Request) -> Result<Response, String> {
  return await reject_when_draining_result(ctx, request, handle_workflow_run_route_authorized)
}

async fn handle_workflow_run_route_authorized(ctx: RequestContext, request: Request) -> Result<Response, String> {
  return await authorize_permission_result(ctx, request, jobs_run_read_permission(), handle_workflow_run_route_inner)
}

async fn handle_workflow_run_route_inner(ctx: RequestContext, request: Request) -> Result<Response, String> {
  match workflow_run_identity_from_request(ctx, request) {
    Ok(identity) => {
      match ensure_workflow_permission_scope(ctx, jobs_run_read_permission(), identity.app, identity.channel) {
        Ok(_) => {}
        Err(response) => { return Ok(response) }
      }
      match load_workflow_run(identity.app, identity.channel, identity.run_id) {
        Ok(run) => {
          return workflow_run_response(ctx, run)
        }
        Err(msg) => {
          if msg == "workflow run not found" {
            return missing_workflow_run(ctx, identity.app, identity.channel, identity.run_id)
          }
          return Err(msg)
        }
      }
    }
    Err(response) => {
      return Ok(response)
    }
  }
}

async fn handle_workflow_event_submit_route(ctx: RequestContext, request: Request) -> Result<Response, String> {
  return await reject_when_draining_result(ctx, request, handle_workflow_event_submit_route_authorized)
}

async fn handle_workflow_event_submit_route_authorized(ctx: RequestContext, request: Request) -> Result<Response, String> {
  return await authorize_permission_result(ctx, request, jobs_run_trigger_permission(), handle_workflow_event_submit_route_inner)
}

async fn handle_workflow_event_submit_route_inner(ctx: RequestContext, request: Request) -> Result<Response, String> {
  let requested_by = updated_by_actor(ctx)?
  match workflow_event_submit_input_from_request(ctx, request) {
    Ok(input) => {
      match ensure_workflow_permission_scope(ctx, jobs_run_trigger_permission(), input.identity.app, input.identity.channel) {
        Ok(_) => {}
        Err(response) => { return Ok(response) }
      }
      match submit_workflow_event(input.identity.app, input.identity.channel, input.submit_request, requested_by) {
        Ok(outcome) => {
          return workflow_event_submit_response(ctx, outcome)
        }
        Err(msg) => {
          return workflow_event_submit_error_response(ctx, input, msg)
        }
      }
    }
    Err(response) => {
      return Ok(response)
    }
  }
}

async fn handle_worker_claim_route(ctx: RequestContext, request: Request) -> Result<Response, String> {
  return await reject_when_draining_result(ctx, request, handle_worker_claim_route_authorized)
}

async fn handle_worker_claim_route_authorized(ctx: RequestContext, request: Request) -> Result<Response, String> {
  return await authorize_permission_result(ctx, request, jobs_worker_execute_permission(), handle_worker_claim_route_inner)
}

async fn handle_worker_claim_route_inner(ctx: RequestContext, request: Request) -> Result<Response, String> {
  let claim_request = WorkerClaimRequest("", "")
  match worker_claim_request_from_http(ctx, request) {
    Ok(value) => {
      claim_request = value
    }
    Err(response) => {
      return Ok(response)
    }
  }
  let app_scope = principal_app_scope_from_ctx(ctx)?
  let channel_scope = principal_channel_scope_from_ctx(ctx)?
  let outcome = claim_worker_lease_scoped(claim_request.worker_id,
                                          claim_request.task_kind,
                                          app_scope,
                                          channel_scope)?
  return worker_claim_response(ctx, outcome)
}

