  return await authorize_permission_result(ctx, request, jobs_worker_execute_permission(), handle_worker_complete_route_inner)
}

async fn handle_worker_complete_route_inner(ctx: RequestContext, request: Request) -> Result<Response, String> {
  match worker_complete_input_from_request(ctx, request) {
    Ok(input) => {
      let app_scope = principal_app_scope_from_ctx(ctx)?
      let channel_scope = principal_channel_scope_from_ctx(ctx)?
      match complete_worker_lease_scoped(input.lease_id,
                                         input.complete_request.worker_id,
                                         input.complete_request.status,
                                         input.complete_request.result_message,
                                         input.complete_request.result_payload,
                                         app_scope,
                                         channel_scope) {
        Ok(outcome) => {
          return worker_complete_response(ctx, outcome)
        }
        Err(msg) => {
          return worker_lease_route_error_response(ctx, input.lease_id, msg)
        }
      }
    }
    Err(response) => {
      return Ok(response)
    }
  }
}

async fn handle_workflow_route(ctx: RequestContext, request: Request) -> Result<Response, String> {
  if path_matches(workflow_events_pattern(), request) {
    if method_matches(Post, request.method) {
      return await handle_workflow_event_submit_route(ctx, request)
    }
    return workflow_method_not_allowed()
  }
  if path_matches(workflow_run_pattern(), request) {
    if method_matches(Get, request.method) {
      return await handle_workflow_run_route(ctx, request)
    }
    return workflow_method_not_allowed()
  }
  if path_matches(workflow_runs_pattern(), request) {
    if method_matches(Get, request.method) {
      return await handle_workflow_runs_route(ctx, request)
    }
    return workflow_method_not_allowed()
  }
  if method_matches(Get, request.method) {
    return await handle_workflow_definition_get_route(ctx, request)
  }
  if method_matches(Put, request.method) {
    return await handle_workflow_definition_put_route(ctx, request)
  }
  return workflow_method_not_allowed()
}

async fn handle_worker_route(ctx: RequestContext, request: Request) -> Result<Response, String> {
  if path_matches(worker_claim_path(), request) {
    if method_matches(Post, request.method) {
      return await handle_worker_claim_route(ctx, request)
    }
    return workflow_method_not_allowed()
  }
  if path_matches(worker_heartbeat_pattern(), request) {
    if method_matches(Post, request.method) {
      return await handle_worker_heartbeat_route(ctx, request)
    }
    return workflow_method_not_allowed()
  }
  if method_matches(Post, request.method) {
    return await handle_worker_complete_route(ctx, request)
  }
  return workflow_method_not_allowed()
}
