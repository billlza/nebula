      let channel_scope = principal_channel_scope_from_ctx(ctx)?
      match heartbeat_worker_lease_scoped(input.lease_id,
                                          input.heartbeat_request.worker_id,
                                          app_scope,
                                          channel_scope) {
        Ok(outcome) => {
