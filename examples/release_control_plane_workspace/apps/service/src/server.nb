async fn handle_approval_put_route_inner(ctx: RequestContext, request: Request) -> Result<Response, String> {
  let decided_by = updated_by_actor(ctx)?
  match approval_put_route_input_from_request(ctx, request) {
    Ok(input) => {
      match ensure_release_permission_scope(ctx,
                                            approval_decide_permission(),
                                            input.mutation.identity.app,
                                            input.mutation.identity.channel) {
        Ok(_) => {}
        Err(response) => { return Ok(response) }
      }
      let outcome = write_approval_decision(input.mutation.identity.app,
                                            input.mutation.identity.channel,
                                            input.approval_request,
                                            input.mutation.expected_revision_id,
                                            decided_by)?
      post_approval_put_outcome(outcome)?
      return approval_put_outcome_response(ctx, outcome)
    }
    Err(response) => {
      return Ok(response)
    }
  }
}

