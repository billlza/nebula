async fn handle_release_apply_route(ctx: RequestContext, request: Request) -> Result<Response, String> {
  return await reject_when_draining_result(ctx, request, handle_release_apply_route_authorized)
}

async fn handle_release_apply_route_authorized(ctx: RequestContext, request: Request) -> Result<Response, String> {
  return await authorize_permission_result(ctx, request, release_apply_permission(), handle_release_apply_route_inner)
}

async fn handle_release_apply_route_inner(ctx: RequestContext, request: Request) -> Result<Response, String> {
  let requested_by = updated_by_actor(ctx)?
  let mutation = ReleaseMutationInput(ReleaseIdentityFields("", ""), -1)
  match release_mutation_input_from_pattern(ctx, request, apply_pattern()) {
    Ok(value) => {
      mutation = value
    }
    Err(response) => {
      return Ok(response)
    }
  }
  match ensure_release_permission_scope(ctx, release_apply_permission(), mutation.identity.app, mutation.identity.channel) {
    Ok(_) => {}
    Err(response) => { return Ok(response) }
  }
  let outcome = request_release_apply_workflow(mutation.identity.app,
                                               mutation.identity.channel,
                                               mutation.expected_revision_id,
                                               requested_by)?
  return release_apply_outcome_response(ctx, outcome)
}

