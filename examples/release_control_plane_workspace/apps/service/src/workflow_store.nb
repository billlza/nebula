  builder = builder_with_workflow_stage_state(builder, stage)
  builder = array_push(builder, int_value(run_id))
  builder = array_push(builder, int_value(stage.stage_index))
  return array_build(builder)
}

fn workflow_stage_run_active_update_params(run_id: Int, stage: WorkflowStageRun) -> Json {
