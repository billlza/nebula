fn workflow_stage_runs_json_tx(tx: Transaction, run_id: Int) -> Result<Json, String> {
  let rows = tx.query(list_workflow_stage_runs_sql(), one_int_param(run_id))?
  let builder = array_builder()
  let count = rows.len()?
  let index = 0
  while index < count {
    let stage = workflow_stage_run_from_row(rows.row(index)?)?
    builder = array_push(builder, stage.as_json())
    index += 1
  }
  return Ok(array_build(builder))
}

fn one_int_param(value: Int) -> Json {
  let builder = array_builder()
  builder = array_push(builder, int_value(value))
  return array_build(builder)
}

fn three_workflow_text_params(first: String, second: String, third: String) -> Json {
  let builder = array_builder()
  builder = array_push(builder, string_value(first))
  builder = array_push(builder, string_value(second))
  builder = array_push(builder, string_value(third))
  return array_build(builder)
}

fn workflow_run_from_row_tx(tx: Transaction, row: Row) -> Result<WorkflowRun, String> {
  let fields = workflow_run_row_fields(row)?
  let stages = workflow_stage_runs_json_tx(tx, fields.run_id)?
  return Ok(WorkflowRun(fields.run_id,
                        row.get_string("app")?,
                        row.get_string("channel")?,
                        fields.workflow_revision_id,
                        fields.event_id,
                        fields.event_kind,
                        fields.release_revision_id,
                        fields.status,
                        fields.current_stage_index,
                        fields.requested_by,
                        fields.requested_unix_ms,
                        fields.finished_unix_ms,
                        fields.result_message,
                        stages))
}

fn workflow_run_not_found() -> WorkflowRun {
  return WorkflowRun(0, "", "", 0, "", "", 0, "failed", 0, "", 0, 0, "", array_build(array_builder()))
}

fn workflow_definition_lookup_tx(tx: Transaction, app_name: String, channel: String) -> Result<WorkflowDefinitionLookup, String> {
  let rows = tx.query(select_workflow_definition_sql(), two_string_params(app_name, channel))?
  if rows.len()? == 0 {
    return Ok(WorkflowDefinitionLookup(false, workflow_definition_placeholder()))
  }
  let definition = workflow_definition_from_row(rows.row(0)?)?
  return Ok(WorkflowDefinitionLookup(true, definition))
}

fn workflow_run_lookup_tx(tx: Transaction, app_name: String, channel: String, run_id: Int) -> Result<WorkflowRunLookup, String> {
  let rows = tx.query(select_workflow_run_sql(), three_release_params(app_name, channel, run_id))?
  if rows.len()? == 0 {
    return Ok(WorkflowRunLookup(false, workflow_run_not_found()))
  }
  let run = workflow_run_from_row_tx(tx, rows.row(0)?)?
  return Ok(WorkflowRunLookup(true, run))
}

fn workflow_run_lookup_by_id_tx(tx: Transaction, run_id: Int) -> Result<WorkflowRunLookup, String> {
  let rows = tx.query(select_workflow_run_by_id_sql(), one_int_param(run_id))?
  if rows.len()? == 0 {
    return Ok(WorkflowRunLookup(false, workflow_run_not_found()))
  }
  let run = workflow_run_from_row_tx(tx, rows.row(0)?)?
  return Ok(WorkflowRunLookup(true, run))
}

fn latest_release_apply_run_tx(tx: Transaction,
                               app_name: String,
                               channel: String,
                               release_revision_id: Int) -> Result<WorkflowRunLookup, String> {
  let rows = tx.query(select_latest_release_apply_run_sql(), three_release_params(app_name, channel, release_revision_id))?
  if rows.len()? == 0 {
    return Ok(WorkflowRunLookup(false, workflow_run_not_found()))
  }
  let run = workflow_run_from_row_tx(tx, rows.row(0)?)?
  return Ok(WorkflowRunLookup(true, run))
}

fn workflow_stage_run_tx(tx: Transaction, run_id: Int, stage_index: Int) -> Result<WorkflowStageRun, String> {
  let builder = array_builder()
  builder = array_push(builder, int_value(run_id))
  builder = array_push(builder, int_value(stage_index))
  let rows = tx.query(select_workflow_stage_run_sql(), array_build(builder))?
  if rows.len()? == 0 {
    return Err("workflow stage run not found")
  }
  return workflow_stage_run_from_row(rows.row(0)?)
}

fn event_receipt_run_id_tx(tx: Transaction, app_name: String, channel: String, event_id: String) -> Result<Int, String> {
  let builder = array_builder()
  builder = array_push(builder, string_value(app_name))
  builder = array_push(builder, string_value(channel))
  builder = array_push(builder, string_value(event_id))
  let rows = tx.query(select_event_receipt_sql(), array_build(builder))?
  if rows.len()? == 0 {
    return Ok(0)
  }
  return rows.row(0)?.get_int("run_id")
}

fn workflow_definition_applied_outcome(definition: WorkflowDefinition) -> Json {
  return object2("kind", string_value("applied"), "definition", definition.as_json())
}

fn workflow_definition_precondition_required_outcome(current_revision_id: Int) -> Json {
  return object2("kind", string_value("precondition_required"), "current_revision_id", int_value(current_revision_id))
}

fn workflow_definition_conflict_outcome(expected_revision_id: Int, current_revision_id: Int) -> Json {
  return object3("kind",
                 string_value("conflict"),
                 "expected_revision_id",
                 int_value(expected_revision_id),
                 "current_revision_id",
                 int_value(current_revision_id))
}

fn workflow_event_submit_outcome(kind: String, run: WorkflowRun) -> Json {
  return object2("kind", string_value(kind), "run", run.as_json())
}

fn worker_claim_outcome(kind: String, lease: WorkerLease) -> Json {
  return object2("kind", string_value(kind), "lease", lease.as_json())
}

fn worker_complete_outcome(run: WorkflowRun) -> Json {
  return object2("kind", string_value("completed"), "run", run.as_json())
}

fn workflow_idle_claim_outcome() -> Json {
  return worker_claim_outcome("idle", idle_worker_lease())
}

fn default_workflow_event_payload(release_entry: ReleaseEntry) -> Json {
  return object4("app",
                 string_value(release_entry.app),
                 "channel",
                 string_value(release_entry.channel),
                 "release_revision_id",
                 int_value(release_entry.revision_id),
                 "config_revision",
                 int_value(release_entry.config_revision))
}

fn shell_workflow_event_payload(release_entry: ReleaseEntry, event_payload: Json) -> Result<Json, String> {
  return Ok(object3("release",
                    release_entry.as_json(),
                    "event_payload",
                    event_payload,
                    "shell_command",
                    get_value(event_payload, "shell_command")?))
}

fn workflow_event_received_audit_event(app_name: String,
                                       channel: String,
                                       actor: String,
                                       release_revision_id: Int,
                                       event_id: String,
                                       event_kind: String) -> AuditEvent {
  return audit_event_record(app_name,
                            channel,
                            "workflow_event_received",
                            actor,
                            release_revision_id,
                            0,
                            "workflow event received",
                            object2("event_id", string_value(event_id), "event_kind", string_value(event_kind)))
}

