fn workflow_state_store_path() -> String {
  return release_store_path()
}

fn validate_workflow_scope(app_name: String, channel: String) -> Result<Bool, String> {
  validate_app_segment(app_name)?
  validate_channel_segment(channel)?
  return Ok(true)
}

fn workflow_scope_matches(app_scope: Json,
                          channel_scope: Json,
                          app_name: String,
                          channel: String) -> Result<Bool, String> {
  if !scope_allows_app(app_scope, app_name)? {
    return Ok(false)
  }
  return scope_allows_channel(channel_scope, channel)
}

fn workflow_stages_contain_task_kind(stages: Json, task_kind: String) -> Result<Bool, String> {
  let count = array_len(stages)?
  let index = 0
  while index < count {
    let stage = workflow_stage_spec_from_json(array_get(stages, index)?)?
    if stage.task_kind == task_kind {
      return Ok(true)
    }
    index += 1
  }
  return Ok(false)
}

fn shell_tasks_preview_enabled() -> Result<Bool, String> {
  return preview_env_enabled("APP_SHELL_TASKS_PREVIEW")
}

fn validate_shell_task_definition_enabled(stages: Json) -> Result<Bool, String> {
  if !workflow_stages_contain_task_kind(stages, "shell_command")? {
    return Ok(true)
  }
  if shell_tasks_preview_enabled()? {
    return Ok(true)
  }
  return Err("shell_command workflow stages require APP_SHELL_TASKS_PREVIEW=1")
}

fn validate_shell_command_args(args: Json) -> Result<Bool, String> {
  let count = array_len(args)?
  let index = 0
  while index < count {
    as_string(array_get(args, index)?)?
    index += 1
  }
  return Ok(true)
}

fn validate_shell_command_event_payload(payload: Json) -> Result<Bool, String> {
  let shell = get_value(payload, "shell_command")?
  validate_actor_segment(get_string(shell, "command_id")?)?
  return validate_shell_command_args(get_value(shell, "args")?)
}

fn validate_shell_task_event_enabled(definition: WorkflowDefinition,
                                     request: WorkflowEventSubmitRequest) -> Result<Bool, String> {
  if !workflow_stages_contain_task_kind(definition.stages, "shell_command")? {
    return Ok(true)
  }
  validate_shell_task_definition_enabled(definition.stages)?
  return validate_shell_command_event_payload(request.payload)
}

fn validate_shell_task_claim_enabled(task_kind: String) -> Result<Bool, String> {
  if task_kind != "shell_command" {
    return Ok(true)
  }
  if shell_tasks_preview_enabled()? {
    return Ok(true)
  }
  return Err("shell_command worker claims require APP_SHELL_TASKS_PREVIEW=1")
}

fn deploy_preview_enabled() -> Result<Bool, String> {
  return preview_env_enabled("APP_DISTRIBUTED_DEPLOY_PREVIEW")
}

fn validate_deploy_payload_shape(payload: Json) -> Result<Bool, String> {
  let deploy = get_value(payload, "deploy")?
  validate_actor_segment(get_string(deploy, "target")?)?
  validate_actor_segment(get_string(deploy, "command_id")?)?
  get_value(payload, "shell_command")?
  return Ok(true)
}

fn validate_deploy_event_enabled(definition: WorkflowDefinition,
                                 request: WorkflowEventSubmitRequest) -> Result<Bool, String> {
  match get_value(request.payload, "deploy") {
    Ok(_) => {
      if !deploy_preview_enabled()? {
        return Err("deploy workflow events require APP_DISTRIBUTED_DEPLOY_PREVIEW=1")
      }
      if !workflow_stages_contain_task_kind(definition.stages, "shell_command")? {
        return Err("deploy workflow events require a shell_command workflow stage")
      }
      return validate_deploy_payload_shape(request.payload)
    }
    Err(_) => {
      return Ok(true)
    }
  }
}

fn open_workflow_tx() -> Result<Transaction, String> {
  let conn = open(workflow_state_store_path())?
  return conn.begin_transaction()
}

fn workflow_migrations() -> Json {
  let builder = array_builder()
  let create_release_revisions_sql = "CREATE TABLE IF NOT EXISTS release_revisions (app TEXT NOT NULL, channel TEXT NOT NULL, version TEXT NOT NULL, config_revision INTEGER NOT NULL, description TEXT NOT NULL, revision_id INTEGER NOT NULL, updated_by TEXT NOT NULL, updated_unix_ms INTEGER NOT NULL, PRIMARY KEY (app, channel, revision_id))"
  builder = array_push(builder, migration(7, "create_release_revisions", create_release_revisions_sql))
  let create_workflow_definitions_sql = "CREATE TABLE IF NOT EXISTS workflow_definitions (app TEXT NOT NULL, channel TEXT NOT NULL, trigger_kind TEXT NOT NULL, event_kind TEXT NOT NULL, stages TEXT NOT NULL, revision_id INTEGER NOT NULL, updated_by TEXT NOT NULL, updated_unix_ms INTEGER NOT NULL, PRIMARY KEY (app, channel))"
  builder = array_push(builder, migration(8, "create_workflow_definitions", create_workflow_definitions_sql))
  let create_workflow_runs_sql = "CREATE TABLE IF NOT EXISTS workflow_runs (run_id INTEGER PRIMARY KEY AUTOINCREMENT, app TEXT NOT NULL, channel TEXT NOT NULL, workflow_revision_id INTEGER NOT NULL, event_id TEXT NOT NULL, event_kind TEXT NOT NULL, release_revision_id INTEGER NOT NULL, status TEXT NOT NULL, current_stage_index INTEGER NOT NULL, requested_by TEXT NOT NULL, requested_unix_ms INTEGER NOT NULL, finished_unix_ms INTEGER NOT NULL, result_message TEXT NOT NULL)"
  builder = array_push(builder, migration(9, "create_workflow_runs", create_workflow_runs_sql))
  let create_workflow_stage_runs_sql = "CREATE TABLE IF NOT EXISTS workflow_stage_runs (run_id INTEGER NOT NULL, stage_index INTEGER NOT NULL, stage_name TEXT NOT NULL, kind TEXT NOT NULL, task_kind TEXT NOT NULL, status TEXT NOT NULL, attempt INTEGER NOT NULL, lease_id TEXT NOT NULL, worker_id TEXT NOT NULL, lease_expires_unix_ms INTEGER NOT NULL, started_unix_ms INTEGER NOT NULL, finished_unix_ms INTEGER NOT NULL, result_message TEXT NOT NULL, PRIMARY KEY (run_id, stage_index))"
  builder = array_push(builder, migration(10, "create_workflow_stage_runs", create_workflow_stage_runs_sql))
  let create_workflow_event_receipts_sql = "CREATE TABLE IF NOT EXISTS workflow_event_receipts (app TEXT NOT NULL, channel TEXT NOT NULL, event_id TEXT NOT NULL, run_id INTEGER NOT NULL, event_kind TEXT NOT NULL, payload TEXT NOT NULL, received_unix_ms INTEGER NOT NULL, PRIMARY KEY (app, channel, event_id))"
  builder = array_push(builder, migration(11, "create_workflow_event_receipts", create_workflow_event_receipts_sql))
  return array_build(builder)
}

fn backfill_release_revisions_sql() -> String {
  return "INSERT INTO release_revisions(app, channel, version, config_revision, description, revision_id, updated_by, updated_unix_ms) SELECT s.app, s.channel, s.version, s.config_revision, s.description, s.revision_id, s.updated_by, s.updated_unix_ms FROM release_states s WHERE NOT EXISTS (SELECT 1 FROM release_revisions r WHERE r.app = s.app AND r.channel = s.channel AND r.revision_id = s.revision_id)"
}

fn initialize_workflow_store() -> Result<Bool, String> {
  let conn = open(workflow_state_store_path())?
  conn.run_migrations(workflow_migrations())?
  conn.execute0(backfill_release_revisions_sql())?
  return Ok(true)
}

fn default_workflow_stage_specs_json() -> Json {
  let stages = array_builder()
  stages = array_push(stages, WorkflowStageSpec("approval", "approval_gate", "", 0, 0).as_json())
  stages = array_push(stages, WorkflowStageSpec("apply", "leased_task", "apply_release", 30, 3).as_json())
  return array_build(stages)
}

fn default_workflow_definition(app_name: String, channel: String, updated_by: String) -> WorkflowDefinition {
  return WorkflowDefinition(app_name,
                            channel,
                            "internal_event",
                            "release_apply_requested",
                            default_workflow_stage_specs_json(),
                            1,
                            updated_by,
                            unix_millis())
}

fn workflow_definition_placeholder() -> WorkflowDefinition {
  return WorkflowDefinition("", "", "", "", array_build(array_builder()), 0, "", 0)
}

fn workflow_text_json(value: Json) -> String {
  return stringify(value)
}

fn builder_with_workflow_definition_identity(builder: JsonArrayBuilder,
                                             app_name: String,
                                             channel: String) -> JsonArrayBuilder {
  builder = array_push(builder, string_value(app_name))
  builder = array_push(builder, string_value(channel))
  return builder
}

fn builder_with_workflow_definition_state(builder: JsonArrayBuilder,
                                          definition: WorkflowDefinition) -> JsonArrayBuilder {
  builder = array_push(builder, string_value(definition.trigger_kind))
  builder = array_push(builder, string_value(definition.event_kind))
  builder = array_push(builder, string_value(workflow_text_json(definition.stages)))
  builder = array_push(builder, int_value(definition.revision_id))
  builder = array_push(builder, string_value(definition.updated_by))
  builder = array_push(builder, int_value(definition.updated_unix_ms))
  return builder
}

fn workflow_definition_params(definition: WorkflowDefinition) -> Json {
  let builder = array_builder()
  builder = builder_with_workflow_definition_identity(builder, definition.app, definition.channel)
  builder = builder_with_workflow_definition_state(builder, definition)
  return array_build(builder)
}

fn workflow_definition_update_params(definition: WorkflowDefinition) -> Json {
  let builder = array_builder()
  builder = builder_with_workflow_definition_state(builder, definition)
  builder = builder_with_workflow_definition_identity(builder, definition.app, definition.channel)
  return array_build(builder)
}

fn builder_with_workflow_run_identity(builder: JsonArrayBuilder, run: WorkflowRun) -> JsonArrayBuilder {
  builder = array_push(builder, string_value(run.app))
  builder = array_push(builder, string_value(run.channel))
  builder = array_push(builder, int_value(run.workflow_revision_id))
  builder = array_push(builder, string_value(run.event_id))
  builder = array_push(builder, string_value(run.event_kind))
  builder = array_push(builder, int_value(run.release_revision_id))
  return builder
}

fn builder_with_workflow_run_state(builder: JsonArrayBuilder, run: WorkflowRun) -> JsonArrayBuilder {
  builder = array_push(builder, string_value(run.status))
  builder = array_push(builder, int_value(run.current_stage_index))
  builder = array_push(builder, string_value(run.requested_by))
  builder = array_push(builder, int_value(run.requested_unix_ms))
  builder = array_push(builder, int_value(run.finished_unix_ms))
  builder = array_push(builder, string_value(run.result_message))
  return builder
}

fn workflow_run_params(run: WorkflowRun) -> Json {
  let builder = array_builder()
  builder = builder_with_workflow_run_identity(builder, run)
  builder = builder_with_workflow_run_state(builder, run)
  return array_build(builder)
}

fn workflow_run_update_params(run: WorkflowRun) -> Json {
  let builder = array_builder()
  builder = array_push(builder, string_value(run.status))
  builder = array_push(builder, int_value(run.current_stage_index))
  builder = array_push(builder, int_value(run.finished_unix_ms))
  builder = array_push(builder, string_value(run.result_message))
  builder = array_push(builder, int_value(run.run_id))
  return array_build(builder)
}

fn builder_with_workflow_stage_identity(builder: JsonArrayBuilder,
                                        run_id: Int,
                                        stage: WorkflowStageRun) -> JsonArrayBuilder {
  builder = array_push(builder, int_value(run_id))
  builder = array_push(builder, int_value(stage.stage_index))
  builder = array_push(builder, string_value(stage.stage_name))
  builder = array_push(builder, string_value(stage.kind))
  builder = array_push(builder, string_value(stage.task_kind))
  builder = array_push(builder, string_value(stage.status))
  return builder
}

fn builder_with_workflow_stage_state(builder: JsonArrayBuilder, stage: WorkflowStageRun) -> JsonArrayBuilder {
  builder = array_push(builder, int_value(stage.attempt))
  builder = array_push(builder, string_value(stage.lease_id))
  builder = array_push(builder, string_value(stage.worker_id))
  builder = array_push(builder, int_value(stage.lease_expires_unix_ms))
  builder = array_push(builder, int_value(stage.started_unix_ms))
  builder = array_push(builder, int_value(stage.finished_unix_ms))
  builder = array_push(builder, string_value(stage.result_message))
  return builder
}

fn workflow_stage_run_insert_params(run_id: Int, stage: WorkflowStageRun) -> Json {
  let builder = array_builder()
  builder = builder_with_workflow_stage_identity(builder, run_id, stage)
  builder = builder_with_workflow_stage_state(builder, stage)
  return array_build(builder)
}

