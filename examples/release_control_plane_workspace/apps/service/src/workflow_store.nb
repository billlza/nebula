fn workflow_event_receipt_params(app_name: String,
                                 channel: String,
                                 event_id: String,
                                 run_id: Int,
                                 event_kind: String,
                                 payload: Json,
                                 received_unix_ms: Int) -> Json {
  let builder = array_builder()
  builder = array_push(builder, string_value(app_name))
  builder = array_push(builder, string_value(channel))
  builder = array_push(builder, string_value(event_id))
  builder = array_push(builder, int_value(run_id))
  builder = array_push(builder, string_value(event_kind))
  builder = array_push(builder, string_value(workflow_text_json(payload)))
  builder = array_push(builder, int_value(received_unix_ms))
  return array_build(builder)
}

fn select_workflow_definition_sql() -> String {
  return "SELECT app, channel, trigger_kind, event_kind, stages, revision_id, updated_by, updated_unix_ms FROM workflow_definitions WHERE app = ? AND channel = ?"
}

fn insert_workflow_definition_sql() -> String {
  return "INSERT INTO workflow_definitions(app, channel, trigger_kind, event_kind, stages, revision_id, updated_by, updated_unix_ms) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"
}

fn update_workflow_definition_sql() -> String {
  return "UPDATE workflow_definitions SET trigger_kind = ?, event_kind = ?, stages = ?, revision_id = ?, updated_by = ?, updated_unix_ms = ? WHERE app = ? AND channel = ?"
}

fn insert_workflow_run_sql() -> String {
  return "INSERT INTO workflow_runs(app, channel, workflow_revision_id, event_id, event_kind, release_revision_id, status, current_stage_index, requested_by, requested_unix_ms, finished_unix_ms, result_message) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)"
}

fn update_workflow_run_sql() -> String {
  return "UPDATE workflow_runs SET status = ?, current_stage_index = ?, finished_unix_ms = ?, result_message = ? WHERE run_id = ?"
}

fn lock_workflow_run_sql() -> String {
  return "UPDATE workflow_runs SET status = status WHERE run_id = ?"
}

fn insert_workflow_stage_run_sql() -> String {
  return "INSERT INTO workflow_stage_runs(run_id, stage_index, stage_name, kind, task_kind, status, attempt, lease_id, worker_id, lease_expires_unix_ms, started_unix_ms, finished_unix_ms, result_message) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)"
}

fn update_workflow_stage_run_sql() -> String {
  return "UPDATE workflow_stage_runs SET status = ?, attempt = ?, lease_id = ?, worker_id = ?, lease_expires_unix_ms = ?, started_unix_ms = ?, finished_unix_ms = ?, result_message = ? WHERE run_id = ? AND stage_index = ?"
}

fn claim_ready_workflow_stage_run_sql() -> String {
  return "UPDATE workflow_stage_runs SET status = ?, attempt = ?, lease_id = ?, worker_id = ?, lease_expires_unix_ms = ?, started_unix_ms = ?, finished_unix_ms = ?, result_message = ? WHERE run_id = ? AND stage_index = ? AND status = 'ready' AND attempt = ? AND lease_id = ''"
}

fn update_active_workflow_stage_run_sql() -> String {
  return "UPDATE workflow_stage_runs SET status = ?, attempt = ?, lease_id = ?, worker_id = ?, lease_expires_unix_ms = ?, started_unix_ms = ?, finished_unix_ms = ?, result_message = ? WHERE run_id = ? AND stage_index = ? AND status = 'leased' AND lease_id = ? AND worker_id = ?"
}

fn upsert_workflow_stage_result_payload_sql() -> String {
  return "INSERT INTO workflow_stage_result_payloads(run_id, stage_index, result_payload) VALUES (?, ?, ?) ON CONFLICT(run_id, stage_index) DO UPDATE SET result_payload = excluded.result_payload"
}

fn workflow_stage_result_payload_params(run_id: Int, stage_index: Int, result_payload: Json) -> Json {
  let builder = array_builder()
  builder = array_push(builder, int_value(run_id))
  builder = array_push(builder, int_value(stage_index))
  builder = array_push(builder, string_value(workflow_text_json(result_payload)))
  return array_build(builder)
}

fn workflow_stage_select_columns() -> String {
  return "s.run_id, s.stage_index, s.stage_name, s.kind, s.task_kind, s.status, s.attempt, s.lease_id, s.worker_id, s.lease_expires_unix_ms, s.started_unix_ms, s.finished_unix_ms, s.result_message, COALESCE(p.result_payload, 'null') AS result_payload"
}

fn workflow_stage_join_sql() -> String {
  return " FROM workflow_stage_runs s LEFT JOIN workflow_stage_result_payloads p ON p.run_id = s.run_id AND p.stage_index = s.stage_index "
}

fn list_workflow_runs_sql() -> String {
  return "SELECT run_id, app, channel, workflow_revision_id, event_id, event_kind, release_revision_id, status, current_stage_index, requested_by, requested_unix_ms, finished_unix_ms, result_message FROM workflow_runs WHERE app = ? AND channel = ? ORDER BY run_id DESC"
}

fn select_workflow_run_sql() -> String {
  return "SELECT run_id, app, channel, workflow_revision_id, event_id, event_kind, release_revision_id, status, current_stage_index, requested_by, requested_unix_ms, finished_unix_ms, result_message FROM workflow_runs WHERE app = ? AND channel = ? AND run_id = ?"
}

fn select_workflow_run_by_id_sql() -> String {
  return "SELECT run_id, app, channel, workflow_revision_id, event_id, event_kind, release_revision_id, status, current_stage_index, requested_by, requested_unix_ms, finished_unix_ms, result_message FROM workflow_runs WHERE run_id = ?"
}

fn select_latest_release_apply_run_sql() -> String {
  return "SELECT run_id, app, channel, workflow_revision_id, event_id, event_kind, release_revision_id, status, current_stage_index, requested_by, requested_unix_ms, finished_unix_ms, result_message FROM workflow_runs WHERE app = ? AND channel = ? AND event_kind = 'release_apply_requested' AND release_revision_id = ? ORDER BY run_id DESC LIMIT 1"
}

fn list_workflow_stage_runs_sql() -> String {
  return text_concat3("SELECT ", workflow_stage_select_columns(), text_concat(workflow_stage_join_sql(), "WHERE s.run_id = ? ORDER BY s.stage_index ASC"))
}

fn select_workflow_stage_run_sql() -> String {
  return text_concat3("SELECT ", workflow_stage_select_columns(), text_concat(workflow_stage_join_sql(), "WHERE s.run_id = ? AND s.stage_index = ?"))
}

fn select_worker_lease_sql() -> String {
  return text_concat3("SELECT ", workflow_stage_select_columns(), text_concat(workflow_stage_join_sql(), "WHERE s.lease_id = ?"))
}

fn select_event_receipt_sql() -> String {
  return "SELECT run_id FROM workflow_event_receipts WHERE app = ? AND channel = ? AND event_id = ?"
}

fn select_event_receipt_payload_sql() -> String {
  return "SELECT payload FROM workflow_event_receipts WHERE app = ? AND channel = ? AND event_id = ?"
}

fn insert_event_receipt_sql() -> String {
  return "INSERT INTO workflow_event_receipts(app, channel, event_id, run_id, event_kind, payload, received_unix_ms) VALUES (?, ?, ?, ?, ?, ?, ?)"
}

fn ready_stage_claim_sql() -> String {
  return "SELECT s.run_id, s.stage_index FROM workflow_stage_runs s JOIN workflow_runs r ON r.run_id = s.run_id WHERE s.kind = 'leased_task' AND s.status = 'ready' AND (r.status = 'ready' OR r.status = 'leased') ORDER BY r.requested_unix_ms ASC, s.run_id ASC, s.stage_index ASC LIMIT 1"
}

fn ready_stage_claim_with_task_sql() -> String {
  return "SELECT s.run_id, s.stage_index FROM workflow_stage_runs s JOIN workflow_runs r ON r.run_id = s.run_id WHERE s.kind = 'leased_task' AND s.status = 'ready' AND (r.status = 'ready' OR r.status = 'leased') AND s.task_kind = ? ORDER BY r.requested_unix_ms ASC, s.run_id ASC, s.stage_index ASC LIMIT 1"
}

fn list_active_run_ids_sql() -> String {
  return "SELECT run_id FROM workflow_runs WHERE app = ? AND channel = ? AND status != 'completed' AND status != 'failed' ORDER BY run_id ASC"
}

fn list_active_release_run_ids_sql() -> String {
  return "SELECT run_id FROM workflow_runs WHERE app = ? AND channel = ? AND release_revision_id = ? AND status != 'completed' AND status != 'failed' ORDER BY run_id ASC"
}

fn list_expired_leases_sql() -> String {
  return "SELECT s.run_id, s.stage_index FROM workflow_stage_runs s JOIN workflow_runs r ON r.run_id = s.run_id WHERE r.app = ? AND r.channel = ? AND s.status = 'leased' AND s.lease_expires_unix_ms > 0 AND s.lease_expires_unix_ms < ? ORDER BY s.run_id ASC, s.stage_index ASC"
}

fn workflow_definition_identity_fields(row: Row) -> Result<WorkflowDefinitionIdentityFields, String> {
  return Ok(WorkflowDefinitionIdentityFields(row.get_string("app")?, row.get_string("channel")?))
}

fn workflow_definition_state_fields(row: Row) -> Result<WorkflowDefinitionStateFields, String> {
  return Ok(WorkflowDefinitionStateFields(row.get_string("trigger_kind")?,
                                          row.get_string("event_kind")?,
                                          row.get_string("stages")?,
                                          row.get_int("revision_id")?,
                                          row.get_string("updated_by")?,
                                          row.get_int("updated_unix_ms")?))
}

fn workflow_definition_row_fields(row: Row) -> Result<WorkflowDefinitionRowFields, String> {
  let identity = workflow_definition_identity_fields(row)?
  let state = workflow_definition_state_fields(row)?
  return Ok(WorkflowDefinitionRowFields(identity.app,
                                        identity.channel,
                                        state.trigger_kind,
                                        state.event_kind,
                                        state.stages_text,
                                        state.revision_id,
                                        state.updated_by,
                                        state.updated_unix_ms))
}

fn workflow_definition_from_row(row: Row) -> Result<WorkflowDefinition, String> {
  let fields = workflow_definition_row_fields(row)?
  let stages = parse(fields.stages_text)?
  return Ok(WorkflowDefinition(fields.app,
                               fields.channel,
                               fields.trigger_kind,
                               fields.event_kind,
                               stages,
                               fields.revision_id,
                               fields.updated_by,
                               fields.updated_unix_ms))
}

fn workflow_run_identity_fields(row: Row) -> Result<WorkflowRunIdentityFields, String> {
  return Ok(WorkflowRunIdentityFields(row.get_int("run_id")?,
                                      row.get_int("workflow_revision_id")?,
                                      row.get_string("event_id")?,
                                      row.get_string("event_kind")?,
                                      row.get_int("release_revision_id")?))
}

fn workflow_run_state_fields(row: Row) -> Result<WorkflowRunStateFields, String> {
  return Ok(WorkflowRunStateFields(row.get_string("status")?,
                                   row.get_int("current_stage_index")?,
                                   row.get_string("requested_by")?,
                                   row.get_int("requested_unix_ms")?,
                                   row.get_int("finished_unix_ms")?,
                                   row.get_string("result_message")?))
}

fn workflow_run_row_fields(row: Row) -> Result<WorkflowRunRowFields, String> {
  let identity = workflow_run_identity_fields(row)?
  let state = workflow_run_state_fields(row)?
  return Ok(WorkflowRunRowFields(identity.run_id,
                                 identity.workflow_revision_id,
                                 identity.event_id,
                                 identity.event_kind,
                                 identity.release_revision_id,
                                 state.status,
                                 state.current_stage_index,
                                 state.requested_by,
                                 state.requested_unix_ms,
                                 state.finished_unix_ms,
                                 state.result_message))
}

fn workflow_stage_run_identity_fields(row: Row) -> Result<WorkflowStageRunIdentityFields, String> {
  return Ok(WorkflowStageRunIdentityFields(row.get_int("stage_index")?,
                                           row.get_string("stage_name")?,
                                           row.get_string("kind")?,
                                           row.get_string("task_kind")?))
}

fn workflow_stage_run_lease_fields(row: Row) -> Result<WorkflowStageRunLeaseFields, String> {
  return Ok(WorkflowStageRunLeaseFields(row.get_string("status")?,
                                        row.get_int("attempt")?,
                                        row.get_string("lease_id")?,
