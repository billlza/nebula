module main
import app_local::substrate
import bridge::host_bridge
import std::bytes
import std::json
import std::result
import ui::ui

extern fn host_shell_begin() -> Void
extern fn host_shell_open() -> Bool
extern fn host_shell_next_command_text() -> String
extern fn host_shell_publish_event(event: String) -> Void
extern fn host_shell_publish_snapshot(snapshot: String) -> Void
extern fn host_shell_render_tree(tree: String) -> Void
extern fn host_shell_end() -> Void

struct ShellState {
  filter_text: String,
  refresh_count: Int,
  last_action: String,
  revision: Int
}

struct ShellStep {
  state: ShellState,
  terminal: Bool,
  event_kind: String,
  command_id: String,
  previous_revision: Int,
  correlation_id: String
}

struct ShellCommandOutcome {
  state: ShellState,
  terminal: Bool
}

struct ShellRuntime {
  config: AppLocalConfig,
  preflight: AppLocalPreflight
}

fn text_join(lhs: String, rhs: String) -> String {
  return to_string(concat(from_string(lhs), from_string(rhs)))
}

fn int_text(value: Int) -> String {
  return stringify(int_value(value))
}

fn receipt_db_path() -> String {
  return "work/thin_host_gui_host_shell/app-local-receipts.db"
}

fn app_id() -> String {
  return "thin-host-gui-host-shell"
}

fn observe_service() -> String {
  return "thin-host-gui-host-shell"
}

fn runtime_session_id() -> String {
  return "thin-host-gui-preview-session-0001"
}

fn shell_runtime() -> Result<ShellRuntime, String> {
  let config_value = config_from_env(app_id(), receipt_db_path(), "local-operator", observe_service())?
  let report = preflight(config_value)?
  return Ok(ShellRuntime(config_value, report))
}

fn initial_state() -> ShellState {
  return ShellState("targets", 0, "boot", 0)
}

fn state_payload(state: ShellState) -> Json {
  return object4("filter",
                 string_value(state.filter_text),
                 "refresh_count",
                 int_value(state.refresh_count),
                 "last_action",
                 string_value(state.last_action),
                 "revision",
                 int_value(state.revision))
}

fn shell_principal(runtime: ShellRuntime) -> AppLocalPrincipal {
  return AppLocalPrincipal(runtime.config.principal_subject, "app.local.gui", runtime.config.auth_mode)
}

fn app_local_context(runtime: ShellRuntime, command_id: String, correlation_id: String, revision: Int) -> Result<AppLocalCommandContext, String> {
  return command_context(command_id, correlation_id, revision, shell_principal(runtime), 1777431000000)
}

fn app_local_command_id(kind: String, correlation_id: String) -> String {
  return text_join(kind, text_join(":", correlation_id))
}

fn app_local_snapshot_id(correlation_id: String) -> String {
  return text_join("snapshot:", correlation_id)
}

fn publish_app_local_context(context: AppLocalCommandContext) -> Void {
  print(text_join("app-local-context:", stringify(context.as_json())))
}

fn publish_app_local_event(event: AppLocalEvent) -> Void {
  print(text_join("app-local-event:", stringify(event.as_json())))
}

fn publish_app_local_recovery(marker: AppLocalRecoveryMarker) -> Void {
  print(text_join("app-local-recovery:", stringify(marker.as_json())))
}

fn publish_app_local_update(marker: AppLocalUpdateMarker) -> Void {
  print(text_join("app-local-update:", stringify(marker.as_json())))
}

fn publish_app_local_lifecycle(marker: AppLocalLifecycleMarker) -> Void {
  print(text_join("app-local-lifecycle:", stringify(marker.as_json())))
}

fn publish_app_local_preflight(report: AppLocalPreflight) -> Void {
  print(text_join("app-local-preflight:", stringify(report.as_json())))
}

fn publish_app_local_startup_policy(policy: AppLocalStartupRecoveryPolicy) -> Void {
  print(text_join("app-local-startup-policy:", stringify(policy.as_json())))
}

fn publish_app_local_error(msg: String) -> Void {
  print(text_join("app-local-error:", msg))
}

fn publish_runtime_preflight(runtime: ShellRuntime) -> Result<Bool, String> {
  publish_app_local_preflight(runtime.preflight)
  emit_preflight_observe(runtime.config, runtime.preflight)
  return Ok(true)
}

fn publish_startup_recovery_policy(runtime: ShellRuntime) -> Result<Bool, String> {
  let policy = startup_recovery_policy(runtime.config.sqlite_path, runtime.config.app_id, 10)?
  publish_app_local_startup_policy(policy)
  return Ok(true)
}

fn publish_lifecycle_marker(runtime: ShellRuntime, status: String, reason: String, revision: Int) -> Result<Bool, String> {
  let marker = lifecycle_marker(runtime.config.app_id,
                                runtime_session_id(),
                                runtime_session_id(),
                                revision,
                                status,
                                reason)?
  publish_app_local_lifecycle(marker)
  record_lifecycle_marker_receipt(runtime.config.sqlite_path, marker, 1777431000000)?
  return Ok(true)
}

fn publish_app_local_accepted(runtime: ShellRuntime,
                              command_id: String,
                              correlation_id: String,
                              previous_revision: Int,
                              event_kind: String,
                              message: String) -> Result<Bool, String> {
  let context = app_local_context(runtime, command_id, correlation_id, previous_revision)?
  publish_app_local_context(context)
  record_command_context_receipt(runtime.config.sqlite_path, runtime.config.app_id, context, 1777431000000)?
  let event_value = command_accepted_event(context, event_kind, message)?
  publish_app_local_event(event_value)
  record_event_receipt(runtime.config.sqlite_path, runtime.config.app_id, event_value, 1777431000000)?
  return Ok(true)
}

fn publish_app_local_rejected(runtime: ShellRuntime,
                              command_id: String,
                              correlation_id: String,
                              revision: Int,
                              reason: String) -> Result<Bool, String> {
  let context = app_local_context(runtime, command_id, correlation_id, revision)?
  publish_app_local_context(context)
  record_command_context_receipt(runtime.config.sqlite_path, runtime.config.app_id, context, 1777431000000)?
  let event_value = command_rejected_event(context, reason)?
  publish_app_local_event(event_value)
  record_event_receipt(runtime.config.sqlite_path, runtime.config.app_id, event_value, 1777431000000)?
  return Ok(true)
}

fn publish_app_local_shutdown(runtime: ShellRuntime, correlation_id: String, revision: Int) -> Result<Bool, String> {
  let recovery = recovery_marker(runtime.config.app_id,
                                 correlation_id,
                                 revision,
                                 "manual-preview",
                                 "logs/thin-host-gui-host-shell.ndjson")?
  publish_app_local_recovery(recovery)
  record_recovery_marker_receipt(runtime.config.sqlite_path, recovery, 1777431000000)?
  let update = update_marker(runtime.config.app_id,
                             correlation_id,
                             revision,
                             "staged-preview",
                             "deploy/update/manifest.preview.json",
                             "52457a884a25b45c67e40519907515393af3b7c6ac451baca974285987a4766c")?
  publish_app_local_update(update)
  record_update_marker_receipt(runtime.config.sqlite_path, update, 1777431000000)?
  return Ok(true)
}

ui OpsShell(state: ShellState) {
  view Window(title = "Local Ops Shell") {
    view Input(value = state.filter_text, action = "targets.filter", accessibility_label = "Filter targets")
    view Button(text = "Refresh", action = "targets.refresh")
  }
}

fn render_state(runtime: ShellRuntime, state: ShellState, correlation_id: String) -> Result<Bool, String> {
  let tree = OpsShell(state)
  let snapshot_text = encode_snapshot_text_with_revision("local_ops_console", tree, state.revision)
  host_shell_render_tree(stringify(tree))
  host_shell_publish_snapshot(snapshot_text)
  record_snapshot_receipt(runtime.config.sqlite_path,
                          runtime.config.app_id,
                          app_local_snapshot_id(correlation_id),
                          correlation_id,
                          state.revision,
                          "thin-host-bridge.snapshot.v1",
                          parse(snapshot_text)?,
                          1777431000000)?
  return Ok(true)
}

fn applied_event_text(step: ShellStep) -> String {
  return encode_event_text_with_context(step.event_kind,
                                        state_payload(step.state),
                                        step.terminal,
                                        step.correlation_id,
                                        step.state.revision)
}

fn rejected_event_text(state: ShellState, correlation_id: String, reason: String) -> String {
  return encode_event_text_with_context("ui_command_rejected",
                                        object5("filter",
                                                string_value(state.filter_text),
                                                "refresh_count",
                                                int_value(state.refresh_count),
                                                "last_action",
                                                string_value(state.last_action),
                                                "revision",
                                                int_value(state.revision),
                                                "reason",
                                                string_value(reason)),
                                        false,
                                        correlation_id,
                                        state.revision)
}

fn shell_step(state: ShellState, next_state: ShellState, terminal: Bool, event_kind: String, command: ThinHostCommand) -> ShellStep {
  return ShellStep(next_state,
                   terminal,
                   event_kind,
                   app_local_command_id(command.kind(), command.correlation_id()),
                   state.revision,
                   command.correlation_id())
}

fn refresh_step(state: ShellState, command: ThinHostCommand) -> ShellStep {
  let next_state = ShellState(state.filter_text, state.refresh_count + 1, command.kind(), state.revision + 1)
  return shell_step(state, next_state, false, "ui_action_applied", command)
}

fn filter_step(state: ShellState, command: ThinHostCommand) -> ShellStep {
  let next_state = ShellState("prod", state.refresh_count, command.kind(), state.revision + 1)
  return shell_step(state, next_state, false, "ui_action_applied", command)
}

fn quit_step(state: ShellState, command: ThinHostCommand) -> ShellStep {
  let next_state = ShellState(state.filter_text, state.refresh_count, command.kind(), state.revision + 1)
  return shell_step(state, next_state, true, "ui_shell_quit", command)
}

fn apply_command(state: ShellState, command_text: String) -> Result<ShellStep, String> {
  let command = decode_command_text(command_text)?
  if command.state_revision() != state.revision {
    return Err("stale thin-host GUI command state_revision")
  }
  if command.kind() == "targets.refresh" {
    return Ok(refresh_step(state, command))
  }
  if command.kind() == "targets.filter" {
    return Ok(filter_step(state, command))
  }
  if command.kind() == "quit" {
    return Ok(quit_step(state, command))
  }
  return Err("unknown thin-host GUI command kind")
}

fn handle_applied_step(runtime: ShellRuntime, step: ShellStep) -> Result<Bool, String> {
  host_shell_publish_event(applied_event_text(step))
  publish_app_local_accepted(runtime,
                             step.command_id,
                             step.correlation_id,
                             step.previous_revision,
                             step.event_kind,
                             "thin-host command applied")?
  render_state(runtime, step.state, step.correlation_id)?
  if step.terminal {
    publish_app_local_shutdown(runtime, step.correlation_id, step.state.revision)?
    publish_lifecycle_marker(runtime, "shutdown_clean", "normal quit", step.state.revision)?
    host_shell_end()
    return Ok(true)
  }
  return Ok(false)
}

fn handle_rejected_command(runtime: ShellRuntime, state: ShellState, command_text: String, reason: String) -> Result<Bool, String> {
  let correlation_id = command_correlation_id_or(command_text, "gui-command-rejected")
  host_shell_publish_event(rejected_event_text(state, correlation_id, reason))
  publish_app_local_rejected(runtime,
                             app_local_command_id("thin-host-command", correlation_id),
                             correlation_id,
                             state.revision,
                             reason)?
  render_state(runtime, state, correlation_id)?
  return Ok(true)
}

fn handle_command(runtime: ShellRuntime, state: ShellState, command_text: String) -> Result<ShellCommandOutcome, String> {
  match apply_command(state, command_text) {
    Ok(step) => {
      let done = handle_applied_step(runtime, step)?
      return Ok(ShellCommandOutcome(step.state, done))
    }
    Err(msg) => {
      handle_rejected_command(runtime, state, command_text, msg)?
      return Ok(ShellCommandOutcome(state, false))
    }
  }
}

fn fail_app_local(msg: String) -> Int {
  publish_app_local_error(msg)
  host_shell_end()
  return 1
}

fn fail_app_local_runtime(runtime: ShellRuntime, msg: String, revision: Int) -> Int {
  match publish_lifecycle_marker(runtime, "app_degraded", msg, revision) {
    Ok(_) => {}
    Err(marker_msg) => {
      publish_app_local_error(marker_msg)
    }
  }
  return fail_app_local(msg)
}

fn publish_startup_diagnostics(runtime: ShellRuntime) -> Result<Bool, String> {
  publish_runtime_preflight(runtime)?
  return publish_startup_recovery_policy(runtime)
}

fn publish_boot_event(state: ShellState) -> Void {
  host_shell_publish_event(encode_event_text_with_context("ui_shell_booted",
                                                          state_payload(state),
                                                          false,
                                                          "boot",
                                                          state.revision))
}

fn boot_shell(runtime: ShellRuntime, state: ShellState) -> Result<Bool, String> {
  publish_startup_diagnostics(runtime)?
  publish_lifecycle_marker(runtime, "startup_started", "host shell started", state.revision)?
  publish_boot_event(state)
  render_state(runtime, state, "boot")?
  return publish_lifecycle_marker(runtime, "app_ready", "first snapshot rendered", state.revision)
}

fn run_command_loop(runtime: ShellRuntime, state: ShellState) -> Result<ShellCommandOutcome, String> {
  while host_shell_open() {
    let command_text = host_shell_next_command_text()
    let outcome = handle_command(runtime, state, command_text)?
    state = outcome.state
    if outcome.terminal {
      return Ok(outcome)
    }
  }
  return Ok(ShellCommandOutcome(state, false))
}

fn run_shell(runtime: ShellRuntime, state: ShellState) -> Int {
  match boot_shell(runtime, state) {
    Ok(_) => {}
    Err(msg) => {
      return fail_app_local_runtime(runtime, msg, state.revision)
    }
  }
  match run_command_loop(runtime, state) {
    Ok(outcome) => {
      if outcome.terminal {
        return 0
      }
      match publish_lifecycle_marker(runtime, "shutdown_clean", "host shell closed", outcome.state.revision) {
        Ok(_) => {}
        Err(msg) => {
          return fail_app_local(msg)
        }
      }
    }
    Err(msg) => {
      return fail_app_local_runtime(runtime, msg, state.revision)
    }
  }
  host_shell_end()
  return 0
}

fn main() -> Int {
  let state = initial_state()
  host_shell_begin()
  match shell_runtime() {
    Ok(runtime) => {
      return run_shell(runtime, state)
    }
    Err(msg) => {
      return fail_app_local(msg)
    }
  }
}
