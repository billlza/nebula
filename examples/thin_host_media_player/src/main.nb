extern fn host_player_begin() -> Void
extern fn host_player_open() -> Bool
extern fn host_player_next_command_text() -> String
extern fn host_player_publish_event(event: String) -> Void
extern fn host_player_publish_snapshot(snapshot: String) -> Void
