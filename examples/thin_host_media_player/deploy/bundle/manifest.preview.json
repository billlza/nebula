  },
  "telemetry": {
    "correlation_id_source": "thin-host-bridge.command.v1.correlation_id"
  },
  "crash": {
    "crash_report_schema": "nebula.gui.preview.crash.v1",
    "last_event_correlation_id": "media-9",
    "last_state_revision": 9
  },
  "recovery": {
    "mode": "manual-preview",
    "log_path": "logs/thin-host-media-player.ndjson"
  },
  "assets": [
    {
      "path": "deploy/macos/Info.plist.example"
    },
    {
      "path": "deploy/linux/dev.nebula.thin-host-media-player.desktop.example"
    },
    {
      "path": "deploy/update/manifest.preview.json"
    }
  ]
}
