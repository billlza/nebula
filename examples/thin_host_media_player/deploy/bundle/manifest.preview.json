{
  "schema": "nebula.gui.preview.package.v1",
  "app_id": "dev.nebula.thin-host-media-player",
  "version": "0.1.0-preview",
  "channel": "preview",
  "host_api": "thin-host-shell.preview.v1",
  "entry": {
    "binary": "thin-host-media-player"
  },
  "runtime": {
    "app_core": "nebula-first",
    "wire_command_schema": "thin-host-bridge.command.v1",
    "domain_command_schema": "media-player.command.v1",
    "event_schema": "media-player.event.v1",
    "snapshot_schema": "media-player.snapshot.v1",
    "stale_command_policy": "reject-preserve-state"
  },
  "app_local_substrate": {
    "default_store": "sqlite",
    "media_store": "sqlite",
    "postgres": "preview-optional",
    "jobs": "nebula-jobs",
