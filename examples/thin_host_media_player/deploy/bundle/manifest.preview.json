  },
  "host_sidecars": {
    "file_picker": "preview-adapter",
    "codec": "native-sidecar-boundary",
    "player": "native-sidecar-boundary",
    "torrent_transport": "stub-progress-events"
  },
  "update_manifest": {
    "path": "deploy/update/manifest.preview.json",
