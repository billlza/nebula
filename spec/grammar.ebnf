// Nebula-Core + minimal tooling extensions (modules, extern, bool/control flow, tooling).
//
// Notes:
// - The syntax stays intentionally small to keep the compiler bootstrap fast.
// - `Ident "(" ... ")"` is parsed uniformly as CallExpr; typecheck rewrites to ConstructExpr
//   when `Ident` resolves to a type name (Call vs Ctor disambiguation).

Program         ::= ModuleDecl? { ImportDecl } { AnnotatedItem }
ModuleDecl      ::= "module" ModulePath
ImportDecl      ::= "import" ImportPath
ModulePath      ::= Ident { "." Ident }
ImportPath      ::= Ident [ "::" Ident ] { "." Ident }

AnnotatedItem   ::= { Annotation } Item
Annotation      ::= "@" Ident

Item            ::= Function | ExternFunction | Struct | Enum | Ui

Function        ::= "fn" Ident TypeParamList? "(" ParamList? ")" ReturnType? Block
ExternFunction  ::= "extern" "fn" Ident TypeParamList? "(" ParamList? ")" ReturnType?

ParamList       ::= Param { "," Param }
Param           ::= ("ref")? Ident ":" Type
ReturnType      ::= "->" Type

Struct          ::= "struct" Ident TypeParamList? "{" { Field } "}"
Field           ::= Ident ":" Type

Enum            ::= "enum" Ident TypeParamList? "{" Variant { Variant } "}"
Variant         ::= Ident "(" Type ")"

Ui              ::= "ui" Ident "(" ParamList? ")" UiBlock
UiBlock         ::= "{" { UiNode } "}"
UiNode          ::= UiView | UiIf | UiFor
UiView          ::= "view" Ident "(" UiPropList? ")" UiBlock?
UiPropList      ::= UiProp { "," UiProp }
UiProp          ::= Ident "=" Expr
UiIf            ::= "if" Expr UiBlock
UiFor           ::= "for" Ident "in" Expr UiBlock

Block           ::= "{" { AnnotatedStmt } "}"
AnnotatedStmt   ::= { Annotation } Stmt

Stmt            ::= LetStmt | AssignStmt | ExprStmt | ReturnStmt | RegionStmt | UnsafeStmt | IfStmt | MatchStmt | ForStmt | WhileStmt | BreakStmt | ContinueStmt

LetStmt         ::= "let" Ident "=" Expr
                  | "let" "{" StructBindingFieldList? "}" "=" Expr
StructBindingFieldList ::= StructBindingField { "," StructBindingField }
StructBindingField ::= Ident [ ":" (Ident | "_") ]
AssignStmt      ::= AssignTarget "=" Expr
                  | AssignTarget CompoundAssignOp Expr
AssignTarget    ::= Ident { "." Ident }
CompoundAssignOp ::= "+=" | "-=" | "*=" | "/="
                  | "%="
ReturnStmt      ::= "return" Expr
ExprStmt        ::= Expr
RegionStmt      ::= "region" Ident Block
UnsafeStmt      ::= "unsafe" Block
IfStmt          ::= "if" Expr Block [ "else" (IfStmt | Block) ]
MatchStmt       ::= "match" Expr "{" { MatchArm } "}"
MatchArm        ::= Pattern "=>" Block [ "," ]
Pattern         ::= "_"
                  | Bool
                  | VariantPattern
VariantPattern  ::= Ident [ "(" [ Ident | "_" | StructPatternPayload ] ")" ]
StructPatternPayload ::= "{"
                         StructBindingField
                         { "," StructBindingField }
                         [ "," ]
                         "}"

ForStmt         ::= "for" Ident "in" Expr ForRangeOp Expr Block
ForRangeOp      ::= ".." | "..<" | "..."
WhileStmt       ::= "while" Expr Block
BreakStmt       ::= "break"
ContinueStmt    ::= "continue"

Expr            ::= Literal
                  | MatchExpr
                  | Ident
                  | Call
                  | PostfixExpr
                  | Binary
                  | Unary
                  | Shared
                  | Unique
                  | Heap
                  | Promote

MatchExpr       ::= "match" Expr "{" { MatchExprArm } "}"
MatchExprArm    ::= Pattern "=>" Expr [ "," ]

PostfixExpr     ::= PostfixBase PostfixSuffix { PostfixSuffix }
PostfixBase     ::= Ident
                  | Call
                  | "(" Expr ")"
PostfixSuffix   ::= "." Ident
                  | "." Ident "(" ArgList? ")"
                  | "?"
Call            ::= Ident "(" ArgList? ")"
ArgList         ::= Expr { "," Expr }

Binary          ::= Expr Op Expr
Op              ::= "+" | "-" | "*" | "/"
                  | "%"
Unary           ::= ("+" | "-") Expr

Shared          ::= "shared" Expr
Unique          ::= "unique" Expr
Heap            ::= "heap" Expr
Promote         ::= "promote" Expr

// v0.1 semantic restriction (enforced by typecheck, not grammar):
// - ownership/representation directives are only defined on constructor sites
//   (i.e., `shared Foo(...)`, `unique Foo(...)`, `heap Foo(...)`, `promote Foo(...)`)
// - directive chains are rejected (e.g. `shared unique Foo(...)` is an error)
// v0.2.x method/field restriction:
// - rooted and temporary-base postfix chains are supported (`x.f.g`, `foo().x`, `foo().m()`)
// - assignment targets remain rooted-only (`x.f = v`, not `foo().x = v`)
// current match restriction:
// - patterns are first-level only (`_`, `Bool`, enum variants with at most one payload binder)
// current generic restriction:
// - function calls do not yet support explicit type-argument syntax (`foo<Int>(x)` is not in the
//   surface grammar yet)

Type            ::= Ident
                  | Ident "<" TypeList ">"
                  | FnType
                  | UnsafeFnType

TypeParamList   ::= "<" Ident { "," Ident } ">"

FnType          ::= "Fn" "(" TypeList? ")" "->" Type
UnsafeFnType    ::= "UnsafeFn" "(" TypeList? ")" "->" Type
TypeList        ::= Type { "," Type }

Literal         ::= Int | Float | String
                  | Bool
Bool            ::= "true" | "false"
// Numeric separators:
// - `_` is allowed between digits in Int/Float literals (e.g. `1_000`, `12_3.4_5`)
// - `_` cannot be leading/trailing or repeated
// Float scientific notation:
// - `e` / `E` exponent is supported (e.g. `1e9`, `6.02e23`, `1_2.3_4e5_6`)
// - exponent allows optional sign: `e+10`, `e-10`
// Integer base prefixes:
// - Binary: `0b` / `0B` (e.g. `0b1010_0110`)
// - Octal:  `0o` / `0O` (e.g. `0o755`)
// - Hex:    `0x` / `0X` (e.g. `0xFF_EC_10`)

Ident           ::= /[a-zA-Z_][a-zA-Z0-9_]*/
