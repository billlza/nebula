module main
import ui::headless

fn contains_schema(text: String) -> Bool {
  return text == "{\"schema\":\"nebula-ui.tree.v1\",\"component\":\"Window\",\"props\":{\"title\":\"Local Ops\"},\"children\":[{\"schema\":\"nebula-ui.tree.v1\",\"component\":\"Column\",\"props\":{\"spacing\":12},\"children\":[{\"schema\":\"nebula-ui.tree.v1\",\"component\":\"Text\",\"props\":{\"text\":\"Local Ops\"},\"children\":[]},{\"schema\":\"nebula-ui.tree.v1\",\"component\":\"Input\",\"props\":{\"value\":\"targets\",\"action\":\"targets.filter\",\"accessibility_label\":\"Filter targets\"},\"children\":[]},{\"schema\":\"nebula-ui.tree.v1\",\"component\":\"Button\",\"props\":{\"text\":\"Refresh\",\"action\":\"targets.refresh\"},\"children\":[]}]}]}"
}

@bench
fn bench_ui_snapshot_render() -> Void {
  let primary = TypedActionSlot("targets.filter", 1, "input", "Filter targets")
  let secondary = TypedActionSlot("targets.refresh", 2, "button", "Refresh")
  let model = TypedUiViewModel("Local Ops", "Local Ops", "targets", 12, primary, secondary)
  let rendered = typed_snapshot_text_unchecked(model)
  if contains_schema(rendered) == false {
    expect_eq(1, 0)
  }
}

fn main() -> Void {
  print("app-platform-ui-snapshot-render")
}
