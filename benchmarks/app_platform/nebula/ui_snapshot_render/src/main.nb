module main
import std::json
import ui::ui

struct DashboardState {
  title: String
  ready: Bool
}

ui Dashboard(state: DashboardState) {
  view Window(title = state.title) {
    view Column(spacing = 12) {
      view Text(text = state.title)
      view Button(text = "Refresh", action = "targets.refresh")
    }
  }
}

fn contains_schema(text: String) -> Bool {
  return text == stringify(Dashboard(DashboardState("Local Ops", true)))
}

@bench
fn bench_ui_snapshot_render() -> Void {
  let rendered = stringify(Dashboard(DashboardState("Local Ops", true)))
  if contains_schema(rendered) == false {
    expect_eq(1, 0)
  }
}

fn main() -> Void {
  print("app-platform-ui-snapshot-render")
}
