module main
import counter::counter_core

fn expect_text_eq(actual: String, expected: String) -> Void {
  if actual == expected {
  } else {
    expect_eq(1, 0)
  }
}

fn verify_event_text(event_text: String) -> Void {
  expect_text_eq(event_text,
                 "{\"schema\":\"thin-host-bridge.event.v1\",\"kind\":\"increment_applied\",\"payload\":{\"counter\":1,\"can_decrement\":true,\"status\":\"active\",\"last_command\":\"increment\"},\"terminal\":false,\"correlation_id\":\"cmd-increment\",\"state_revision\":1}")
}

fn verify_snapshot_text(snapshot_text: String) -> Void {
  expect_text_eq(snapshot_text,
                 "{\"schema\":\"thin-host-bridge.snapshot.v1\",\"screen\":\"counter\",\"payload\":{\"counter\":1,\"can_decrement\":true,\"status\":\"active\",\"last_command\":\"increment\"},\"state_revision\":1}")
}

@bench
fn bench_thin_host_bridge_roundtrip() -> Void {
  let state = initial_state()
  let command = increment_command_text()
  match apply_command_text(state, command) {
    Ok(step) => {
      verify_event_text(step.event_text())
      verify_snapshot_text(query_snapshot_text(step.state()))
    }
    Err(msg) => {
      print(msg)
    }
  }
}

fn main() -> Void {
  print("app-platform-thin-host-bridge-roundtrip")
}
