module main
import ui::headless

@bench
fn bench_ui_hit_test_dispatch() -> Void {
  let tree = FastPreviewTree("Local Ops", "Local Ops", "targets", "targets.filter", "Filter targets", "Refresh", "targets.refresh", 12)
  match fast_hit_test_action_code(fast_preview_layout(tree), 30, 60) {
    Ok(action_code) => {
      if action_code != 1 {
        expect_eq(1, 0)
      }
    }
    Err(_) => {
      expect_eq(1, 0)
    }
  }
}

fn main() -> Void {
  print("app-platform-ui-hit-test-dispatch")
}
