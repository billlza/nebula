module main
import std::json
import std::result
import ui::headless
import ui::ui

struct DashboardState {
  title: String
  ready: Bool
  filter: String
}

fn dashboard_column(state: DashboardState) -> View {
  return column(12,
                child3(text(state.title),
                       input(state.filter, "targets.filter", "Filter targets"),
                       button("Refresh", "targets.refresh")))
}

fn Dashboard(state: DashboardState) -> Json {
  return window(state.title, child1(dashboard_column(state))).as_json()
}

fn button_action(tree: Json) -> Result<String, String> {
  let window_children = get_value(tree, "children")?
  let column = array_get(window_children, 0)?
  let column_children = get_value(column, "children")?
  let button = array_get(column_children, 2)?
  let props = get_value(button, "props")?
  return get_string(props, "action")
}

@bench
fn bench_ui_action_roundtrip() -> Void {
  let state = DashboardState("Local Ops", true, "targets")
  match button_action(Dashboard(state)) {
    Ok(action) => {
      if action != "targets.refresh" {
        expect_eq(1, 0)
      }
    }
    Err(_) => {
      expect_eq(1, 0)
    }
  }
  match dispatch_action(Dashboard(state), "targets.filter") {
    Ok(action) => {
      if action != "nebula-ui-action-dispatched=targets.filter" {
        expect_eq(1, 0)
      }
    }
    Err(_) => {
      expect_eq(1, 0)
    }
  }
}

fn main() -> Void {
  print("app-platform-ui-action-roundtrip")
}
