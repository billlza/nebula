module main
import std::result
import ui::headless

fn local_ops_tree() -> Result<FastPreviewTree, String> {
  return fast_preview_tree("Local Ops",
                           "Local Ops",
                           "targets",
                           "targets.filter",
                           "Filter targets",
                           "Refresh",
                           "targets.refresh")
}

@bench
fn bench_ui_action_roundtrip() -> Void {
  match local_ops_tree() {
    Ok(tree) => {
      match fast_action_index(tree) {
        Ok(index) => {
          if index.first_button_action != "targets.refresh" {
            expect_eq(1, 0)
          }
          if index.first_input_action != "targets.filter" {
            expect_eq(1, 0)
          }
          match fast_dispatch_action_index(index, "targets.filter") {
            Ok(dispatched) => {
              if !dispatched {
                expect_eq(1, 0)
              }
            }
            Err(_) => {
              expect_eq(1, 0)
            }
          }
        }
        Err(_) => {
          expect_eq(1, 0)
        }
      }
    }
    Err(_) => {
      expect_eq(1, 0)
    }
  }
}

fn main() -> Void {
  print("app-platform-ui-action-roundtrip")
}
