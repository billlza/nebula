module main
import ui::headless

@bench
fn bench_ui_patch_apply() -> Void {
  let primary = TypedActionSlot("targets.filter", 1, "input", "Filter targets")
  let secondary = TypedActionSlot("targets.refresh", 2, "button", "Refresh")
  let old_model = TypedUiViewModel("Local Ops", "Local Ops", "targets", 12, primary, secondary)
  let new_model = TypedUiViewModel("Local Ops", "Local Ops", "prod", 12, primary, secondary)
  let patch_code = typed_patch_code(old_model, new_model)
  if patch_code != 111 {
    expect_eq(1, 0)
  }
}

fn main() -> Void {
  print("app-platform-ui-patch-apply")
}
