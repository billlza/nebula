module main
import counter::counter_core
import std::result

fn expect_text_eq(actual: String, expected: String) -> Void {
  if actual == expected {
  } else {
    expect_eq(1, 0)
  }
}

fn verify_snapshot_text(snapshot_text: String) -> Void {
  expect_text_eq(snapshot_text,
                 "{\"schema\":\"thin-host-bridge.snapshot.v1\",\"screen\":\"counter\",\"payload\":{\"counter\":1,\"can_decrement\":true,\"status\":\"active\",\"last_command\":\"decrement\"},\"state_revision\":3}")
}

fn state_after_sync_tape() -> Result<CounterState, String> {
  let state0 = initial_state()
  let step1 = apply_command_code_envelope(state0, command_code_at_revision(increment_command_code(), "sync-1", state0.revision()))?
  let state1 = step1.state()
  let step2 = apply_command_code_envelope(state1, command_code_at_revision(increment_command_code(), "sync-2", state1.revision()))?
  let state2 = step2.state()
  let step3 = apply_command_code_envelope(state2, command_code_at_revision(decrement_command_code(), "sync-3", state2.revision()))?
  return Ok(step3.state())
}

@bench
fn bench_state_sync_latency() -> Void {
  match state_after_sync_tape() {
    Ok(state) => {
      verify_snapshot_text(query_snapshot_text(state))
    }
    Err(msg) => {
      print(msg)
    }
  }
}

fn main() -> Void {
  print("app-platform-state-sync-latency")
}
