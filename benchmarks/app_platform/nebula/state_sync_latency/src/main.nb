module main
import counter::counter_core
import std::json

fn expect_text_eq(actual: String, expected: String) -> Void {
  if actual == expected {
  } else {
    expect_eq(1, 0)
  }
}

fn expect_payload_counter(payload: Json, expected: Int) -> Void {
  match get_int(payload, "counter") {
    Ok(counter) => {
      expect_eq(counter, expected)
    }
    Err(msg) => {
      print(msg)
    }
  }
}

fn expect_payload_status(payload: Json, expected: String) -> Void {
  match get_string(payload, "status") {
    Ok(status) => {
      expect_text_eq(status, expected)
    }
    Err(msg) => {
      print(msg)
    }
  }
}

fn expect_payload_last_command(payload: Json, expected: String) -> Void {
  match get_string(payload, "last_command") {
    Ok(last_command) => {
      expect_text_eq(last_command, expected)
    }
    Err(msg) => {
      print(msg)
    }
  }
}

fn verify_snapshot_text(snapshot_text: String) -> Void {
  match parse(snapshot_text) {
    Ok(snapshot_json) => {
      match get_value(snapshot_json, "payload") {
        Ok(payload) => {
          expect_payload_counter(payload, 1)
          expect_payload_status(payload, "active")
          expect_payload_last_command(payload, "decrement")
        }
        Err(msg) => {
          print(msg)
        }
      }
    }
    Err(msg) => {
      print(msg)
    }
  }
}

@bench
fn bench_state_sync_latency() -> Void {
  let state0 = initial_state()
  let step1 = reduce_command(state0, Increment)
  let step2 = reduce_command(step1.state(), Increment)
  let step3 = reduce_command(step2.state(), Decrement)
  verify_snapshot_text(query_snapshot_text(step3.state()))
}

fn main() -> Void {
  print("app-platform-state-sync-latency")
}
