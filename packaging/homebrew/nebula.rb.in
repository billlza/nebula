class Nebula < Formula
  desc "Nebula language compiler and tooling"
  homepage "https://github.com/@REPOSITORY@"
  version "@VERSION@"
  license "Apache-2.0"

  depends_on "llvm"

  if OS.mac? && Hardware::CPU.intel?
    url "@DARWIN_X86_64_URL@"
    sha256 "@DARWIN_X86_64_SHA256@"
  elsif OS.mac? && Hardware::CPU.arm?
    url "@DARWIN_ARM64_URL@"
    sha256 "@DARWIN_ARM64_SHA256@"
  elsif OS.linux? && Hardware::CPU.intel?
    url "@LINUX_X86_64_URL@"
    sha256 "@LINUX_X86_64_SHA256@"
  else
    odie "Nebula @VERSION@ supports Homebrew installs on macOS (Intel/Apple Silicon) and Linux x86_64 only."
  end

  def install
    libexec.install Dir["bin", "include", "share"]
    (bin/"nebula").write <<~EOS
      #!/bin/sh
      : "${CXX:=#{Formula["llvm"].opt_bin}/clang++}"
      export CXX
      exec "#{libexec}/bin/nebula" "$@"
    EOS
    chmod 0755, bin/"nebula"
  end

  def caveats
    <<~EOS
      Nebula uses #{Formula["llvm"].opt_bin}/clang++ by default when launched via Homebrew.
      Override with CXX=/path/to/clang++ if you need a different host compiler.
    EOS
  end

  test do
    assert_match "nebula v@VERSION@", shell_output("#{bin}/nebula --version")
    system "#{bin}/nebula", "new", "homebrew-smoke"
    output = shell_output("#{bin}/nebula run homebrew-smoke --run-gate none")
    assert_match "Hello from Nebula", output
  end
end
