module env
import std::result

extern fn __nebula_rt_env_has(name: String) -> Bool
extern fn __nebula_rt_env_get(name: String) -> Result<String, String>
extern fn __nebula_rt_env_or(name: String, fallback: String) -> String
extern fn __nebula_rt_env_get_int(name: String) -> Result<Int, String>
extern fn __nebula_rt_env_get_int_or(name: String, fallback: Int) -> Result<Int, String>

fn has(name: String) -> Bool {
  return __nebula_rt_env_has(name)
}

fn get(name: String) -> Result<String, String> {
  return __nebula_rt_env_get(name)
}

fn get_or_default(name: String, fallback: String) -> String {
  return __nebula_rt_env_or(name, fallback)
}

fn get_int(name: String) -> Result<Int, String> {
  return __nebula_rt_env_get_int(name)
}

fn get_int_or(name: String, fallback: Int) -> Result<Int, String> {
  return __nebula_rt_env_get_int_or(name, fallback)
}
