fn parse(text: String) -> Result<Json, String> {
  return __nebula_rt_json_parse(text)
}

fn stringify(value: Json) -> String {
  return __nebula_rt_json_stringify(value)
}

fn string_value(value: String) -> Json {
  return __nebula_rt_json_string_value(value)
}

fn int_value(value: Int) -> Json {
  return __nebula_rt_json_int_value(value)
}

fn bool_value(value: Bool) -> Json {
  return __nebula_rt_json_bool_value(value)
}

fn null_value() -> Json {
  return __nebula_rt_json_null_value()
}

fn object1(key1: String, value1: Json) -> Json {
  return __nebula_rt_json_object1(key1, value1)
}

fn object2(key1: String, value1: Json, key2: String, value2: Json) -> Json {
  return __nebula_rt_json_object2(key1, value1, key2, value2)
}

fn object3(key1: String, value1: Json, key2: String, value2: Json, key3: String, value3: Json) -> Json {
  return __nebula_rt_json_object3(key1, value1, key2, value2, key3, value3)
