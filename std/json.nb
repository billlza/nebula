fn array_builder() -> JsonArrayBuilder {
  return __nebula_rt_json_array_builder()
}

fn array_push(builder: JsonArrayBuilder, value: Json) -> JsonArrayBuilder {
  return __nebula_rt_json_array_push(builder, value)
}

fn array_build(builder: JsonArrayBuilder) -> Json {
  return __nebula_rt_json_array_build(builder)
}

fn get_string(value: Json, key: String) -> Result<String, String> {
  return __nebula_rt_json_get_string(value, key)
}

fn get_int(value: Json, key: String) -> Result<Int, String> {
  return __nebula_rt_json_get_int(value, key)
}

fn get_bool(value: Json, key: String) -> Result<Bool, String> {
  return __nebula_rt_json_get_bool(value, key)
}

fn get_value(value: Json, key: String) -> Result<Json, String> {
  return __nebula_rt_json_get_value(value, key)
}

fn as_string(value: Json) -> Result<String, String> {
  return __nebula_rt_json_as_string(value)
}

fn as_int(value: Json) -> Result<Int, String> {
  return __nebula_rt_json_as_int(value)
}

fn as_bool(value: Json) -> Result<Bool, String> {
  return __nebula_rt_json_as_bool(value)
}

fn array_len(value: Json) -> Result<Int, String> {
  return __nebula_rt_json_array_len(value)
}

fn array_get(value: Json, index: Int) -> Result<Json, String> {
  return __nebula_rt_json_array_get(value, index)
}
