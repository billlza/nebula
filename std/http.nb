}

fn request(method: Method, authority: String, path: String, content_type: String, body: Bytes) -> ClientRequest {
  return ClientRequest(method, authority, path, content_type, body)
}

fn get_request(authority: String, path: String) -> ClientRequest {
  return request(Get, authority, path, "", from_string(""))
}

fn head_request(authority: String, path: String) -> ClientRequest {
  return request(Head, authority, path, "", from_string(""))
}

fn post_request(authority: String, path: String, content_type: String, body: Bytes) -> ClientRequest {
  return request(Post, authority, path, content_type, body)
}

fn put_request(authority: String, path: String, content_type: String, body: Bytes) -> ClientRequest {
  return request(Put, authority, path, content_type, body)
}

fn delete_request(authority: String, path: String) -> ClientRequest {
  return request(Delete, authority, path, "", from_string(""))
}

