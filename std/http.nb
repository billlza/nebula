module http
import std::bytes
import std::net
import std::result
import std::task

enum Method {
  Get(Void)
  Head(Void)
  Post(Void)
  Put(Void)
  Delete(Void)
}

struct Request {
  method: Method
  path: String
  body: Bytes
}

struct Response {
  status: Int
  content_type: String
  body: Bytes
}

struct ClientRequest {
  method: Method
  authority: String
  path: String
  content_type: String
  body: Bytes
}

struct ClientResponse {
  status: Int
  content_type: String
  body: Bytes
}

struct RouteParams2 {
  first: String
  second: String
}

struct RouteParams3 {
  first: String
  second: String
  third: String
}

struct RoutePattern {}

