async fn dispatch1(request: Request,
                   first_method: Method,
                   first_path: String,
                   first_handler: Fn(Request) -> Future<Response>,
                   fallback: Response) -> Response {
  if path_matches(first_path, request) {
    if method_matches(first_method, request.method) {
      return await first_handler(request)
    }
    return method_not_allowed_text("method not allowed")
  }
  return fallback
}

async fn dispatch1_result(request: Request,
                          first_method: Method,
                          first_path: String,
                          first_handler: Fn(Request) -> Future<Result<Response, String>>,
                          fallback: Response) -> Result<Response, String> {
  if path_matches(first_path, request) {
    if method_matches(first_method, request.method) {
      return await first_handler(request)
    }
    return Ok(method_not_allowed_text("method not allowed"))
  }
  return Ok(fallback)
}

async fn dispatch2(request: Request,
                   first_method: Method,
                   first_path: String,
                   first_handler: Fn(Request) -> Future<Response>,
                   second_method: Method,
                   second_path: String,
                   second_handler: Fn(Request) -> Future<Response>,
                   fallback: Response) -> Response {
  let path_hit = false
  if path_matches(first_path, request) {
    path_hit = true
    if method_matches(first_method, request.method) {
      return await first_handler(request)
    }
  }
  if path_matches(second_path, request) {
    path_hit = true
    if method_matches(second_method, request.method) {
      return await second_handler(request)
    }
  }
  if path_hit {
    return method_not_allowed_text("method not allowed")
  }
  return fallback
}

