fn with_header(response: Response, name: String, value: String) -> Result<Response, String> {
  return __nebula_rt_http_response_with_header(response, name, value)
}

fn with_etag(response: Response, value: String) -> Result<Response, String> {
  return with_header(response, "ETag", value)
}

fn response_without_body(response: Response) -> Response {
  return __nebula_rt_http_response_without_body(response)
}

fn text_response(status: Int, body: String) -> Response {
  return response(status, "text/plain; charset=utf-8", from_string(body))
}

fn ok_text(body: String) -> Response {
  return text_response(200, body)
}

fn bad_request_text(body: String) -> Response {
  return text_response(400, body)
}

fn method_not_allowed_text(body: String) -> Response {
  return text_response(405, body)
}

fn not_found_text(body: String) -> Response {
  return text_response(404, body)
}

fn internal_error_text(body: String) -> Response {
  return text_response(500, body)
}

fn method_code(method: Method) -> Int {
  match method {
    Get => {
      return 0
    }
    Head => {
      return 1
    }
    Post => {
      return 2
    }
    Put => {
      return 3
    }
    Delete => {
      return 4
    }
  }
}

fn method_is_head(method: Method) -> Bool {
  match method {
    Get => {
      return false
    }
    Head => {
      return true
    }
    Post => {
      return false
    }
    Put => {
      return false
    }
    Delete => {
      return false
    }
  }
}

fn method_matches(expected: Method, actual: Method) -> Bool {
  if method_code(expected) == method_code(actual) {
    return true
  }
  return method_code(expected) == 0 && method_is_head(actual)
}

fn endpoint_matches(method: Method, path: String, request: Request) -> Bool {
  return method_matches(method, request.method) && path_matches(path, request)
}

fn path_matches(pattern: String, request: Request) -> Bool {
  return __nebula_rt_http_path_matches(pattern, request.path)
}

