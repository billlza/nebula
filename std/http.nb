fn TcpStream_read_request(self: TcpStream) -> Future<Result<Request, String>> {
  return __nebula_rt_http_read_request(self, 8192, 1048576)
}

fn TcpStream_read_request_limited(self: TcpStream, max_header_bytes: Int, max_body_bytes: Int) -> Future<Result<Request, String>> {
  return __nebula_rt_http_read_request(self, max_header_bytes, max_body_bytes)
}

fn Request_close_connection(self: Request) -> Bool {
  return __nebula_rt_http_request_close_connection(self)
}

fn TcpStream_write_response(self: TcpStream, response: Response) -> Future<Result<Void, String>> {
  return __nebula_rt_http_write_response(self, response)
}

