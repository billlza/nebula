async fn serve_once(listener: TcpListener, handler: Fn(Request) -> Future<Response>) -> Result<Void, String> {
  match await listener.accept() {
    Ok(stream) => {
      match await stream.read_request() {
        Ok(request) => {
          let reply = await handler(request)
          let wire_reply = reply
          if method_is_head(request.method) {
            wire_reply = response_without_body(reply)
          }
          match await stream.write_response(wire_reply) {
            Ok(_) => {
              return stream.close()
            }
            Err(msg) => {
              stream.close()
              return Err(msg)
            }
          }
        }
        Err(msg) => {
          stream.close()
          return Err(msg)
        }
      }
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

async fn serve_n(listener: TcpListener, limit: Int, handler: Fn(Request) -> Future<Response>) -> Result<Void, String> {
  if limit <= 0 {
    return Err("serve_n limit must be positive")
  }
  let served = 0
  while served < limit {
    let outcome = await serve_once(listener, handler)
    if served + 1 == limit {
      return outcome
    }
    match outcome {
      Ok(_) => {
        served += 1
      }
      Err(msg) => {
        return Err(msg)
      }
    }
  }
  return Err("serve_n fell through unexpectedly")
}

async fn serve(listener: TcpListener, handler: Fn(Request) -> Future<Response>) -> Result<Void, String> {
  while true {
    match await serve_once(listener, handler) {
      Ok(_) => {}
      Err(msg) => {
        if msg == "listener is closed" {
          return listener.close()
        }
        return Err(msg)
      }
    }
  }
  return listener.close()
}
