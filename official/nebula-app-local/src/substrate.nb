fn ensure_receipt_schema(conn: Connection) -> Result<Bool, String> {
  conn.execute0("CREATE TABLE IF NOT EXISTS app_local_runtime_receipts (receipt_id INTEGER PRIMARY KEY AUTOINCREMENT, app_id TEXT NOT NULL, receipt_kind TEXT NOT NULL, receipt_key TEXT NOT NULL, correlation_id TEXT NOT NULL, state_revision INTEGER NOT NULL, schema TEXT NOT NULL, payload TEXT NOT NULL, created_unix_ms INTEGER NOT NULL, UNIQUE(app_id, receipt_kind, receipt_key))")?
  conn.execute0("CREATE INDEX IF NOT EXISTS idx_app_local_runtime_receipts_lookup ON app_local_runtime_receipts(app_id, receipt_kind, correlation_id, state_revision)")?
  conn.execute0("CREATE INDEX IF NOT EXISTS idx_app_local_runtime_receipts_replay ON app_local_runtime_receipts(app_id, receipt_kind, receipt_id)")?
  return Ok(true)
}

fn receipt_write(app_id: String,
                 receipt_kind: String,
                 receipt_key: String,
                 correlation_id: String,
                 state_revision: Int,
                 schema: String,
                 payload: Json,
                 created_unix_ms: Int) -> AppLocalReceiptWrite {
  return AppLocalReceiptWrite(app_id,
                              receipt_kind,
                              receipt_key,
                              correlation_id,
                              state_revision,
                              schema,
                              payload,
                              created_unix_ms)
}

fn receipt_params(draft: AppLocalReceiptWrite) -> Json {
  let builder = array_builder()
  let builder2 = array_push(builder, string_value(draft.app_id))
  let builder3 = array_push(builder2, string_value(draft.receipt_kind))
  let builder4 = array_push(builder3, string_value(draft.receipt_key))
  let builder5 = array_push(builder4, string_value(draft.correlation_id))
  let builder6 = array_push(builder5, int_value(draft.state_revision))
  let builder7 = array_push(builder6, string_value(draft.schema))
  let builder8 = array_push(builder7, string_value(stringify(draft.payload)))
  let builder9 = array_push(builder8, int_value(draft.created_unix_ms))
  return array_build(builder9)
}

fn receipt_count_params(app_id: String, receipt_kind: String) -> Json {
  let builder = array_builder()
  let builder2 = array_push(builder, string_value(app_id))
  let builder3 = array_push(builder2, string_value(receipt_kind))
  return array_build(builder3)
}

fn receipt_identity_params(app_id: String, receipt_kind: String, receipt_key: String) -> Json {
  let builder = array_builder()
  let builder2 = array_push(builder, string_value(app_id))
  let builder3 = array_push(builder2, string_value(receipt_kind))
  let builder4 = array_push(builder3, string_value(receipt_key))
  return array_build(builder4)
}

fn receipt_lookup_params(app_id: String, receipt_kind: String, correlation_id: String) -> Json {
  let builder = array_builder()
  let builder2 = array_push(builder, string_value(app_id))
  let builder3 = array_push(builder2, string_value(receipt_kind))
  let builder4 = array_push(builder3, string_value(correlation_id))
  return array_build(builder4)
}

fn receipt_limit_params(app_id: String, limit: Int) -> Json {
  let builder = array_builder()
  let builder2 = array_push(builder, string_value(app_id))
  let builder3 = array_push(builder2, int_value(limit))
  return array_build(builder3)
}

fn receipt_kind_limit_params(app_id: String, receipt_kind: String, limit: Int) -> Json {
  let builder = array_builder()
  let builder2 = array_push(builder, string_value(app_id))
  let builder3 = array_push(builder2, string_value(receipt_kind))
  let builder4 = array_push(builder3, int_value(limit))
  return array_build(builder4)
}

fn receipt_replay_params(app_id: String, receipt_kind: String, after_receipt_id: Int, limit: Int) -> Json {
  let builder = array_builder()
  let builder2 = array_push(builder, string_value(app_id))
  let builder3 = array_push(builder2, string_value(receipt_kind))
  let builder4 = array_push(builder3, int_value(after_receipt_id))
  let builder5 = array_push(builder4, int_value(limit))
  return array_build(builder5)
}

fn receipt_app_params(app_id: String) -> Json {
  let builder = array_builder()
  let builder2 = array_push(builder, string_value(app_id))
  return array_build(builder2)
}

fn validate_receipt_scope(app_id: String, receipt_kind: String) -> Result<Bool, String> {
  if app_id == "" {
    return Err("app-local substrate receipt app_id is required")
  }
  if receipt_kind == "" {
    return Err("app-local substrate receipt_kind is required")
  }
  return Ok(true)
}

fn validate_replay_request(app_id: String, limit: Int) -> Result<Bool, String> {
  if app_id == "" {
    return Err("app-local substrate replay app_id is required")
  }
  if limit <= 0 {
    return Err("app-local substrate replay limit must be positive")
  }
  if limit > 500 {
    return Err("app-local substrate replay limit must be <= 500")
  }
  return Ok(true)
}

fn validate_receipt_replay_request(app_id: String, receipt_kind: String, after_receipt_id: Int, limit: Int) -> Result<Bool, String> {
  validate_receipt_scope(app_id, receipt_kind)?
  if after_receipt_id < 0 {
    return Err("app-local substrate replay after_receipt_id must be non-negative")
  }
  return validate_replay_request(app_id, limit)
}

fn validate_runtime_session_summary_request(app_id: String, runtime_session_id: String, limit: Int) -> Result<Bool, String> {
  validate_replay_request(app_id, limit)?
  if runtime_session_id == "" {
    return Err("app-local substrate runtime_session_id is required")
  }
  return Ok(true)
}

fn validate_receipt_input(draft: AppLocalReceiptWrite) -> Result<Bool, String> {
  validate_receipt_scope(draft.app_id, draft.receipt_kind)?
  if draft.receipt_key == "" {
    return Err("app-local substrate receipt_key is required")
  }
  if draft.correlation_id == "" {
    return Err("app-local substrate receipt correlation_id is required")
  }
  if draft.state_revision < 0 {
    return Err("app-local substrate receipt state_revision must be non-negative")
  }
  if draft.schema == "" {
    return Err("app-local substrate receipt schema is required")
  }
  if draft.created_unix_ms < 0 {
    return Err("app-local substrate receipt created_unix_ms must be non-negative")
  }
  return Ok(true)
}

fn initialize_receipts(path: String) -> Result<Bool, String> {
  let conn = open_receipt_store(path)?
  conn.close()?
  return Ok(true)
}

fn open_receipt_store(path: String) -> Result<Connection, String> {
  let conn = open(path)?
  ensure_receipt_schema(conn)?
  return Ok(conn)
}

fn record_receipt(path: String,
                  app_id: String,
                  receipt_kind: String,
                  receipt_key: String,
                  correlation_id: String,
                  state_revision: Int,
                  schema: String,
                  payload: Json,
                  created_unix_ms: Int) -> Result<AppLocalReceipt, String> {
  let draft = receipt_write(app_id, receipt_kind, receipt_key, correlation_id, state_revision, schema, payload, created_unix_ms)
  return record_receipt_write(path, draft)
}

fn record_receipt_write(path: String, draft: AppLocalReceiptWrite) -> Result<AppLocalReceipt, String> {
  validate_receipt_input(draft)?
  let conn = open_receipt_store(path)?
  insert_receipt(conn, draft)?
  let receipt = load_receipt_by_draft(conn, draft)?
  conn.close()?
  return Ok(receipt)
}

fn insert_receipt(conn: Connection, draft: AppLocalReceiptWrite) -> Result<Int, String> {
  return conn.execute("INSERT OR IGNORE INTO app_local_runtime_receipts(app_id, receipt_kind, receipt_key, correlation_id, state_revision, schema, payload, created_unix_ms) VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
                      receipt_params(draft))
}

fn load_receipt_by_draft(conn: Connection, draft: AppLocalReceiptWrite) -> Result<AppLocalReceipt, String> {
  return load_receipt_by_key(conn, draft.app_id, draft.receipt_kind, draft.receipt_key)
}

fn record_command_context_receipt(path: String, app_id: String, context: AppLocalCommandContext, created_unix_ms: Int) -> Result<AppLocalReceipt, String> {
  return record_receipt(path,
                        app_id,
                        "command_context",
                        context.command_id,
                        context.correlation_id,
                        context.state_revision,
                        "nebula.app-local.command-context.v1",
                        context.as_json(),
                        created_unix_ms)
}

fn record_event_receipt(path: String, app_id: String, event_value: AppLocalEvent, created_unix_ms: Int) -> Result<AppLocalReceipt, String> {
  return record_receipt(path,
                        app_id,
                        "event",
                        event_value.command_id,
                        event_value.correlation_id,
                        event_value.state_revision,
                        "nebula.app-local.event.v1",
                        event_value.as_json(),
                        created_unix_ms)
}

fn record_snapshot_receipt(path: String,
                           app_id: String,
                           receipt_key: String,
                           correlation_id: String,
                           state_revision: Int,
                           schema: String,
                           payload: Json,
                           created_unix_ms: Int) -> Result<AppLocalReceipt, String> {
  return record_receipt(path,
                        app_id,
                        "snapshot",
                        receipt_key,
                        correlation_id,
                        state_revision,
                        schema,
                        payload,
                        created_unix_ms)
}

fn record_recovery_marker_receipt(path: String, marker: AppLocalRecoveryMarker, created_unix_ms: Int) -> Result<AppLocalReceipt, String> {
  return record_receipt(path,
                        marker.app_id,
                        "recovery_marker",
                        marker.correlation_id,
                        marker.correlation_id,
                        marker.state_revision,
                        "nebula.app-local.recovery-marker.v1",
                        marker.as_json(),
                        created_unix_ms)
}

fn record_update_marker_receipt(path: String, marker: AppLocalUpdateMarker, created_unix_ms: Int) -> Result<AppLocalReceipt, String> {
  return record_receipt(path,
                        marker.app_id,
                        "update_marker",
                        marker.correlation_id,
                        marker.correlation_id,
                        marker.state_revision,
                        "nebula.app-local.update-marker.v1",
                        marker.as_json(),
                        created_unix_ms)
}

fn lifecycle_receipt_key(marker: AppLocalLifecycleMarker) -> String {
  return app_local_text_concat3(marker.runtime_session_id,
                                ":",
                                app_local_text_concat3(marker.status, ":", marker.correlation_id))
}

fn record_lifecycle_marker_receipt(path: String, marker: AppLocalLifecycleMarker, created_unix_ms: Int) -> Result<AppLocalReceipt, String> {
  return record_receipt(path,
                        marker.app_id,
                        "lifecycle_marker",
                        lifecycle_receipt_key(marker),
                        marker.correlation_id,
                        marker.state_revision,
                        "nebula.app-local.lifecycle-marker.v1",
                        marker.as_json(),
                        created_unix_ms)
}

fn runtime_session_summary(path: String,
                           app_id: String,
                           runtime_session_id: String,
                           limit: Int) -> Result<AppLocalRuntimeSessionSummary, String> {
  validate_runtime_session_summary_request(app_id, runtime_session_id, limit)?
  let lifecycle_receipts = recent_receipts_by_kind(path, app_id, "lifecycle_marker", limit)?
  return runtime_session_summary_from_lifecycle_markers(app_id, runtime_session_id, lifecycle_receipts)
}

fn latest_runtime_session_summary(path: String, app_id: String, limit: Int) -> Result<AppLocalRuntimeSessionSummary, String> {
  validate_replay_request(app_id, limit)?
  let lifecycle_receipts = recent_receipts_by_kind(path, app_id, "lifecycle_marker", limit)?
  return latest_runtime_session_summary_from_lifecycle_markers(app_id, lifecycle_receipts)
}

fn receipt_count(path: String, app_id: String, receipt_kind: String) -> Result<Int, String> {
  validate_receipt_scope(app_id, receipt_kind)?
  let conn = open_receipt_store(path)?
  let count = receipt_count_conn(conn, app_id, receipt_kind)?
  conn.close()?
  return Ok(count)
}

fn receipt_count_conn(conn: Connection, app_id: String, receipt_kind: String) -> Result<Int, String> {
  let rows = conn.query("SELECT COUNT(*) AS count FROM app_local_runtime_receipts WHERE app_id = ? AND receipt_kind = ?", receipt_count_params(app_id, receipt_kind))?
  return rows.row(0)?.get_int_at(0)
}

fn receipt_total_count_conn(conn: Connection, app_id: String) -> Result<Int, String> {
  let rows = conn.query("SELECT COUNT(*) AS count FROM app_local_runtime_receipts WHERE app_id = ?", receipt_app_params(app_id))?
  return rows.row(0)?.get_int_at(0)
}

fn load_receipt_by_key(conn: Connection, app_id: String, receipt_kind: String, receipt_key: String) -> Result<AppLocalReceipt, String> {
  let rows = conn.query("SELECT receipt_id, app_id, receipt_kind, receipt_key, correlation_id, state_revision, schema, payload, created_unix_ms FROM app_local_runtime_receipts WHERE app_id = ? AND receipt_kind = ? AND receipt_key = ? LIMIT 1",
                        receipt_identity_params(app_id, receipt_kind, receipt_key))?
  if rows.len()? == 0 {
    return Err("app-local substrate receipt not found")
  }
  return receipt_from_row(rows.row(0)?)
}

fn receipt_by_key(path: String, app_id: String, receipt_kind: String, receipt_key: String) -> Result<AppLocalReceipt, String> {
  validate_receipt_scope(app_id, receipt_kind)?
  if receipt_key == "" {
    return Err("app-local substrate receipt_key is required")
  }
  let conn = open_receipt_store(path)?
  let receipt = load_receipt_by_key(conn, app_id, receipt_kind, receipt_key)?
  conn.close()?
  return Ok(receipt)
}

fn receipt_from_row(row: Row) -> Result<AppLocalReceipt, String> {
  let identity = receipt_identity_from_row(row)?
  let data = receipt_data_from_row(row)?
  return Ok(AppLocalReceipt(identity.receipt_id,
                            identity.app_id,
                            identity.receipt_kind,
                            identity.receipt_key,
                            identity.correlation_id,
                            data.state_revision,
                            data.schema,
                            data.payload,
                            data.created_unix_ms))
}

fn receipt_identity_from_row(row: Row) -> Result<AppLocalReceiptIdentity, String> {
  return Ok(AppLocalReceiptIdentity(row.get_int_at(0)?,
                                    row.get_string_at(1)?,
                                    row.get_string_at(2)?,
                                    row.get_string_at(3)?,
                                    row.get_string_at(4)?))
}

fn receipt_data_from_row(row: Row) -> Result<AppLocalReceiptData, String> {
  return Ok(AppLocalReceiptData(row.get_int_at(5)?,
                                row.get_string_at(6)?,
                                parse(row.get_string_at(7)?)?,
                                row.get_int_at(8)?))
}

fn latest_receipt(path: String, app_id: String, receipt_kind: String, correlation_id: String) -> Result<AppLocalReceipt, String> {
  validate_receipt_scope(app_id, receipt_kind)?
  if correlation_id == "" {
    return Err("app-local substrate receipt correlation_id is required")
  }
  let conn = open_receipt_store(path)?
  let receipt = latest_receipt_conn(conn, app_id, receipt_kind, correlation_id)?
  conn.close()?
  return Ok(receipt)
}

fn latest_receipt_conn(conn: Connection, app_id: String, receipt_kind: String, correlation_id: String) -> Result<AppLocalReceipt, String> {
  let rows = conn.query("SELECT receipt_id, app_id, receipt_kind, receipt_key, correlation_id, state_revision, schema, payload, created_unix_ms FROM app_local_runtime_receipts WHERE app_id = ? AND receipt_kind = ? AND correlation_id = ? ORDER BY receipt_id DESC LIMIT 1",
                        receipt_lookup_params(app_id, receipt_kind, correlation_id))?
  if rows.len()? == 0 {
    return Err("app-local substrate receipt not found")
  }
  return receipt_from_row(rows.row(0)?)
}

fn receipt_placeholder(app_id: String) -> AppLocalReceipt {
  return AppLocalReceipt(0, app_id, "", "", "", 0, "", object1("kind", string_value("empty")), 0)
}

fn latest_app_receipt_conn(conn: Connection, app_id: String) -> Result<AppLocalReceipt, String> {
  let rows = conn.query("SELECT receipt_id, app_id, receipt_kind, receipt_key, correlation_id, state_revision, schema, payload, created_unix_ms FROM app_local_runtime_receipts WHERE app_id = ? ORDER BY receipt_id DESC LIMIT 1",
                        receipt_app_params(app_id))?
  if rows.len()? == 0 {
    return Ok(receipt_placeholder(app_id))
  }
  return receipt_from_row(rows.row(0)?)
}

fn receipts_from_rows(rows: ResultSet) -> Result<Json, String> {
  let builder = array_builder()
  let count = rows.len()?
  let index = 0
  while index < count {
    let receipt = receipt_from_row(rows.row(index)?)?
    builder = array_push(builder, receipt.as_json())
    index += 1
  }
  return Ok(array_build(builder))
}

fn recent_receipts(path: String, app_id: String, limit: Int) -> Result<Json, String> {
  validate_replay_request(app_id, limit)?
  let conn = open_receipt_store(path)?
  let receipts = recent_receipts_conn(conn, app_id, limit)?
  conn.close()?
  return Ok(receipts)
}

fn recent_receipts_conn(conn: Connection, app_id: String, limit: Int) -> Result<Json, String> {
  let rows = conn.query("SELECT receipt_id, app_id, receipt_kind, receipt_key, correlation_id, state_revision, schema, payload, created_unix_ms FROM (SELECT receipt_id, app_id, receipt_kind, receipt_key, correlation_id, state_revision, schema, payload, created_unix_ms FROM app_local_runtime_receipts WHERE app_id = ? ORDER BY receipt_id DESC LIMIT ?) ORDER BY receipt_id ASC",
                        receipt_limit_params(app_id, limit))?
  return receipts_from_rows(rows)
}

fn replay_receipts(path: String,
                   app_id: String,
                   receipt_kind: String,
                   after_receipt_id: Int,
                   limit: Int) -> Result<AppLocalReceiptReplayBatch, String> {
  validate_receipt_replay_request(app_id, receipt_kind, after_receipt_id, limit)?
  let conn = open_receipt_store(path)?
  let batch = replay_receipts_conn(conn, app_id, receipt_kind, after_receipt_id, limit)?
  conn.close()?
  return Ok(batch)
}

fn replay_receipts_conn(conn: Connection,
                        app_id: String,
                        receipt_kind: String,
                        after_receipt_id: Int,
                        limit: Int) -> Result<AppLocalReceiptReplayBatch, String> {
  let query_limit = limit + 1
  let rows = conn.query("SELECT receipt_id, app_id, receipt_kind, receipt_key, correlation_id, state_revision, schema, payload, created_unix_ms FROM app_local_runtime_receipts WHERE app_id = ? AND receipt_kind = ? AND receipt_id > ? ORDER BY receipt_id ASC LIMIT ?",
                        receipt_replay_params(app_id, receipt_kind, after_receipt_id, query_limit))?
  return replay_batch_from_rows(app_id, receipt_kind, after_receipt_id, limit, rows)
}

fn replay_batch_from_rows(app_id: String,
                          receipt_kind: String,
                          after_receipt_id: Int,
                          limit: Int,
                          rows: ResultSet) -> Result<AppLocalReceiptReplayBatch, String> {
  let cursor = replay_cursor_from_rows(rows, limit)?
  return Ok(AppLocalReceiptReplayBatch(app_id,
                                       receipt_kind,
                                       after_receipt_id,
                                       replay_next_after(cursor, after_receipt_id),
                                       limit,
                                       cursor.receipts,
                                       cursor.has_more))
}

fn replay_next_after(cursor: AppLocalReplayCursor, after_receipt_id: Int) -> Int {
  if cursor.next_after_receipt_id == 0 {
    return after_receipt_id
  }
  return cursor.next_after_receipt_id
}

fn replay_cursor_from_rows(rows: ResultSet, limit: Int) -> Result<AppLocalReplayCursor, String> {
  let builder = array_builder()
  let count = rows.len()?
  let index = 0
  let next_after_receipt_id = 0
  let has_more = false
  while index < count {
    let receipt = receipt_from_row(rows.row(index)?)?
    if index < limit {
      builder = array_push(builder, receipt.as_json())
      next_after_receipt_id = receipt.receipt_id
    } else {
      has_more = true
    }
    index += 1
  }
  return Ok(AppLocalReplayCursor(array_build(builder), next_after_receipt_id, has_more))
}

fn recent_receipts_by_kind(path: String, app_id: String, receipt_kind: String, limit: Int) -> Result<Json, String> {
  validate_receipt_scope(app_id, receipt_kind)?
  validate_replay_request(app_id, limit)?
  let conn = open_receipt_store(path)?
  let receipts = recent_receipts_by_kind_conn(conn, app_id, receipt_kind, limit)?
  conn.close()?
  return Ok(receipts)
}

fn recent_receipts_by_kind_conn(conn: Connection, app_id: String, receipt_kind: String, limit: Int) -> Result<Json, String> {
  let rows = conn.query("SELECT receipt_id, app_id, receipt_kind, receipt_key, correlation_id, state_revision, schema, payload, created_unix_ms FROM (SELECT receipt_id, app_id, receipt_kind, receipt_key, correlation_id, state_revision, schema, payload, created_unix_ms FROM app_local_runtime_receipts WHERE app_id = ? AND receipt_kind = ? ORDER BY receipt_id DESC LIMIT ?) ORDER BY receipt_id ASC",
                        receipt_kind_limit_params(app_id, receipt_kind, limit))?
  return receipts_from_rows(rows)
}

fn recent_marker_receipts_conn(conn: Connection, app_id: String, limit: Int) -> Result<Json, String> {
  let rows = conn.query("SELECT receipt_id, app_id, receipt_kind, receipt_key, correlation_id, state_revision, schema, payload, created_unix_ms FROM (SELECT receipt_id, app_id, receipt_kind, receipt_key, correlation_id, state_revision, schema, payload, created_unix_ms FROM app_local_runtime_receipts WHERE app_id = ? AND (receipt_kind = 'recovery_marker' OR receipt_kind = 'update_marker') ORDER BY receipt_id DESC LIMIT ?) ORDER BY receipt_id ASC",
                        receipt_limit_params(app_id, limit))?
  return receipts_from_rows(rows)
}

fn recovery_replay_trace(path: String, app_id: String, limit: Int) -> Result<AppLocalReplayTrace, String> {
  validate_replay_request(app_id, limit)?
  let conn = open_receipt_store(path)?
  let trace = recovery_replay_trace_conn(conn, app_id, limit)?
  conn.close()?
  return Ok(trace)
}

fn recovery_replay_trace_conn(conn: Connection, app_id: String, limit: Int) -> Result<AppLocalReplayTrace, String> {
  let latest = latest_app_receipt_conn(conn, app_id)?
  let evidence = recovery_replay_trace_evidence_conn(conn, app_id, limit)?
  return Ok(AppLocalReplayTrace(app_id,
                                latest.state_revision,
                                latest.correlation_id,
                                evidence.receipt_count,
                                evidence.receipts,
                                evidence.snapshots,
                                evidence.command_contexts,
                                evidence.events,
                                evidence.markers,
                                evidence.lifecycle_markers))
}

fn recovery_replay_trace_evidence_conn(conn: Connection, app_id: String, limit: Int) -> Result<AppLocalReplayTraceEvidence, String> {
  return Ok(AppLocalReplayTraceEvidence(receipt_total_count_conn(conn, app_id)?,
                                        recent_receipts_conn(conn, app_id, limit)?,
                                        recent_receipts_by_kind_conn(conn, app_id, "snapshot", limit)?,
                                        recent_receipts_by_kind_conn(conn, app_id, "command_context", limit)?,
                                        recent_receipts_by_kind_conn(conn, app_id, "event", limit)?,
                                        recent_marker_receipts_conn(conn, app_id, limit)?,
                                        recent_receipts_by_kind_conn(conn, app_id, "lifecycle_marker", limit)?))
}

fn startup_recovery_policy(path: String, app_id: String, limit: Int) -> Result<AppLocalStartupRecoveryPolicy, String> {
  validate_replay_request(app_id, limit)?
  let trace = recovery_replay_trace(path, app_id, limit)?
  return startup_recovery_policy_from_trace(trace)
}

fn startup_recovery_policy_from_trace(trace: AppLocalReplayTrace) -> Result<AppLocalStartupRecoveryPolicy, String> {
  let evidence = startup_recovery_evidence(trace)?
  let revision_receipt = startup_latest_revision_receipt(evidence)?
  return Ok(AppLocalStartupRecoveryPolicy(trace.app_id,
                                          receipt_json_revision(revision_receipt),
                                          receipt_json_correlation_id(revision_receipt),
                                          receipt_json_kind_or(revision_receipt, "none"),
                                          startup_revision_confidence(trace, revision_receipt),
                                          startup_recovery_recommendation(trace, evidence)?,
                                          startup_recovery_reason(trace, evidence)?,
                                          true,
                                          "app",
                                          evidence,
                                          trace))
}

fn startup_recovery_evidence(trace: AppLocalReplayTrace) -> Result<Json, String> {
  let snapshot = latest_json_receipt(trace.snapshots, trace.app_id)?
  return Ok(object4("last_snapshot",
                    snapshot,
                    "commands",
                    startup_command_evidence(trace)?,
                    "markers",
                    startup_marker_evidence(trace)?,
                    "lifecycle",
                    startup_lifecycle_evidence(trace)?))
}

fn startup_command_evidence(trace: AppLocalReplayTrace) -> Result<Json, String> {
  return Ok(object3("last_event",
                    latest_json_receipt(trace.events, trace.app_id)?,
                    "last_accepted_event",
                    latest_event_receipt_by_accepted(trace.events, trace.app_id, true)?,
                    "last_rejected_event",
                    latest_event_receipt_by_accepted(trace.events, trace.app_id, false)?))
}

fn startup_marker_evidence(trace: AppLocalReplayTrace) -> Result<Json, String> {
  return Ok(object2("last_recovery_marker",
                    latest_json_receipt_by_kind(trace.markers, trace.app_id, "recovery_marker")?,
                    "last_update_marker",
                    latest_json_receipt_by_kind(trace.markers, trace.app_id, "update_marker")?))
}

fn startup_lifecycle_evidence(trace: AppLocalReplayTrace) -> Result<Json, String> {
  let last_marker = latest_json_receipt(trace.lifecycle_markers, trace.app_id)?
  return Ok(object7("last_lifecycle_marker",
                    last_marker,
                    "last_startup_started",
                    latest_lifecycle_receipt_by_status(trace.lifecycle_markers, trace.app_id, "startup_started")?,
                    "last_app_ready",
                    latest_lifecycle_receipt_by_status(trace.lifecycle_markers, trace.app_id, "app_ready")?,
                    "last_app_degraded",
                    latest_lifecycle_receipt_by_status(trace.lifecycle_markers, trace.app_id, "app_degraded")?,
                    "last_shutdown_clean",
                    latest_lifecycle_receipt_by_status(trace.lifecycle_markers, trace.app_id, "shutdown_clean")?,
                    "previous_session_clean",
                    bool_value(receipt_lifecycle_status(last_marker) == "shutdown_clean"),
                    "last_runtime_session",
                    latest_runtime_session_summary_from_lifecycle_markers(trace.app_id, trace.lifecycle_markers)?.as_json()))
}

fn startup_recovery_recommendation(trace: AppLocalReplayTrace, evidence: Json) -> Result<String, String> {
  if trace.receipt_count == 0 {
    return Ok("clean_start")
  }
  return startup_recovery_recommendation_from_evidence(evidence)
}

fn startup_recovery_recommendation_from_evidence(evidence: Json) -> Result<String, String> {
  let marker_recommendation = startup_marker_recommendation(evidence)?
  if marker_recommendation != "" {
    return Ok(marker_recommendation)
  }
  return startup_resume_recommendation(evidence)
}

fn startup_marker_recommendation(evidence: Json) -> Result<String, String> {
  if startup_has_update_marker(evidence)? {
    return Ok("inspect_update_marker")
  }
  if startup_has_recovery_marker(evidence)? {
    return Ok("inspect_recovery_marker")
  }
  if startup_rejected_after_accepted(evidence)? {
    return Ok("inspect_rejected_command")
  }
  if startup_previous_session_incomplete(evidence)? {
    return Ok("inspect_incomplete_session")
  }
  return Ok("")
}

fn startup_resume_recommendation(evidence: Json) -> Result<String, String> {
  if startup_has_snapshot(evidence)? {
    return Ok("app_decide_from_snapshot")
  }
  if startup_has_lifecycle_marker(evidence)? {
    return Ok("app_decide_from_lifecycle")
  }
  return Ok("app_decide_from_receipts")
}

fn startup_recovery_reason(trace: AppLocalReplayTrace, evidence: Json) -> Result<String, String> {
  if trace.receipt_count == 0 {
    return Ok("no app-local receipts were found")
  }
  return startup_recovery_reason_from_evidence(evidence)
}

fn startup_recovery_reason_from_evidence(evidence: Json) -> Result<String, String> {
  let marker_reason = startup_marker_reason(evidence)?
  if marker_reason != "" {
    return Ok(marker_reason)
  }
  return startup_resume_reason(evidence)
}

fn startup_marker_reason(evidence: Json) -> Result<String, String> {
  if startup_has_update_marker(evidence)? {
    return Ok("latest startup evidence includes an update marker; app must verify or ignore it")
  }
  if startup_has_recovery_marker(evidence)? {
    return Ok("latest startup evidence includes a recovery marker; app must decide recovery action")
  }
  if startup_rejected_after_accepted(evidence)? {
    return Ok("latest command event was rejected; app should inspect the rejection before resuming")
  }
  if startup_previous_session_incomplete(evidence)? {
    return Ok("latest lifecycle marker is not shutdown_clean; app should inspect prior session before resuming")
  }
  return Ok("")
}

fn startup_resume_reason(evidence: Json) -> Result<String, String> {
  if startup_has_snapshot(evidence)? {
    return Ok("latest snapshot is available for app-owned resume logic")
  }
  if startup_has_lifecycle_marker(evidence)? {
    return Ok("lifecycle receipts exist; app should decide startup behavior from session evidence")
  }
  return Ok("receipts exist but no snapshot or marker was found; app should inspect the trace")
}

fn startup_latest_revision_receipt(evidence: Json) -> Result<Json, String> {
  let event = startup_last_event(evidence)?
  let snapshot = get_value(evidence, "last_snapshot")?
  if receipt_json_id(event) > 0 {
    return Ok(event)
  }
  if receipt_json_id(snapshot) > 0 {
    return Ok(snapshot)
  }
  return Ok(object1("receipt_id", int_value(0)))
}

fn startup_last_event(evidence: Json) -> Result<Json, String> {
  return get_value(get_value(evidence, "commands")?, "last_event")
}

fn startup_last_accepted_event(evidence: Json) -> Result<Json, String> {
  return get_value(get_value(evidence, "commands")?, "last_accepted_event")
}

fn startup_last_rejected_event(evidence: Json) -> Result<Json, String> {
  return get_value(get_value(evidence, "commands")?, "last_rejected_event")
}

fn startup_last_recovery_marker(evidence: Json) -> Result<Json, String> {
  return get_value(get_value(evidence, "markers")?, "last_recovery_marker")
}

fn startup_last_update_marker(evidence: Json) -> Result<Json, String> {
  return get_value(get_value(evidence, "markers")?, "last_update_marker")
}

fn startup_last_lifecycle_marker(evidence: Json) -> Result<Json, String> {
  return get_value(get_value(evidence, "lifecycle")?, "last_lifecycle_marker")
}

fn startup_has_snapshot(evidence: Json) -> Result<Bool, String> {
  return Ok(receipt_json_id(get_value(evidence, "last_snapshot")?) > 0)
}

fn startup_has_recovery_marker(evidence: Json) -> Result<Bool, String> {
  return Ok(receipt_json_id(startup_last_recovery_marker(evidence)?) > 0)
}

fn startup_has_update_marker(evidence: Json) -> Result<Bool, String> {
  return Ok(receipt_json_id(startup_last_update_marker(evidence)?) > 0)
}

fn startup_has_lifecycle_marker(evidence: Json) -> Result<Bool, String> {
  return Ok(receipt_json_id(startup_last_lifecycle_marker(evidence)?) > 0)
}

fn startup_previous_session_incomplete(evidence: Json) -> Result<Bool, String> {
  let marker = startup_last_lifecycle_marker(evidence)?
  if receipt_json_id(marker) == 0 {
    return Ok(false)
  }
  return Ok(receipt_lifecycle_status(marker) != "shutdown_clean")
}

fn startup_rejected_after_accepted(evidence: Json) -> Result<Bool, String> {
  let rejected = startup_last_rejected_event(evidence)?
  let accepted = startup_last_accepted_event(evidence)?
  return Ok(receipt_json_id(rejected) > receipt_json_id(accepted))
}

fn startup_revision_confidence(trace: AppLocalReplayTrace, receipt: Json) -> String {
  if trace.receipt_count == 0 || receipt_json_id(receipt) == 0 {
    return "none"
  }
  return "windowed"
}

fn receipt_json_kind_or(receipt: Json, fallback: String) -> String {
  match get_string(receipt, "receipt_kind") {
    Ok(value) => {
      return value
    }
    Err(msg) => {
      return fallback
    }
  }
}

fn receipt_json_correlation_id(receipt: Json) -> String {
  match get_string(receipt, "correlation_id") {
    Ok(value) => {
      return value
    }
    Err(msg) => {
      return ""
    }
  }
}

fn receipt_json_revision(receipt: Json) -> Int {
  match get_int(receipt, "state_revision") {
    Ok(value) => {
      return value
    }
    Err(msg) => {
      return 0
    }
  }
}

fn receipt_lifecycle_status(receipt: Json) -> String {
  match get_string(get_value_or_empty_payload(receipt), "status") {
    Ok(value) => {
      return value
    }
    Err(msg) => {
      return ""
    }
  }
}

fn receipt_lifecycle_runtime_session_id(receipt: Json) -> String {
  match get_string(get_value_or_empty_payload(receipt), "runtime_session_id") {
    Ok(value) => {
      return value
    }
    Err(msg) => {
      return ""
    }
  }
}

fn receipt_lifecycle_reason(receipt: Json) -> String {
  match get_string(get_value_or_empty_payload(receipt), "reason") {
    Ok(value) => {
      return value
    }
    Err(msg) => {
      return ""
    }
  }
}

fn get_value_or_empty_payload(receipt: Json) -> Json {
  match get_value(receipt, "payload") {
    Ok(value) => {
      return value
    }
    Err(msg) => {
      return object1("kind", string_value("empty"))
    }
  }
}

fn runtime_session_summary_placeholder(app_id: String, runtime_session_id: String) -> AppLocalRuntimeSessionSummary {
  return AppLocalRuntimeSessionSummary(app_id,
                                       runtime_session_id,
                                       0,
                                       false,
                                       false,
                                       false,
                                       false,
                                       0,
                                       0,
                                       "",
                                       "",
                                       0,
                                       "")
}

fn latest_runtime_session_summary_from_lifecycle_markers(app_id: String, receipts: Json) -> Result<AppLocalRuntimeSessionSummary, String> {
  let latest = latest_json_receipt(receipts, app_id)?
  if receipt_json_id(latest) == 0 {
    return Ok(runtime_session_summary_placeholder(app_id, ""))
  }
  return runtime_session_summary_from_lifecycle_markers(app_id, receipt_lifecycle_runtime_session_id(latest), receipts)
}

fn runtime_session_summary_from_lifecycle_markers(app_id: String,
                                                 runtime_session_id: String,
                                                 receipts: Json) -> Result<AppLocalRuntimeSessionSummary, String> {
  if runtime_session_id == "" {
    return Err("app-local substrate runtime_session_id is required")
  }
  let summary = runtime_session_summary_placeholder(app_id, runtime_session_id)
  let count = array_len(receipts)?
  let index = 0
  while index < count {
    let receipt = array_get(receipts, index)?
    summary = runtime_session_summary_accept_receipt(summary, receipt)?
    index += 1
  }
  if summary.marker_count == 0 {
    return Err("app-local substrate runtime session not found")
  }
  return Ok(summary)
}

fn runtime_session_summary_accept_receipt(summary: AppLocalRuntimeSessionSummary, receipt: Json) -> Result<AppLocalRuntimeSessionSummary, String> {
  if receipt_lifecycle_runtime_session_id(receipt) != summary.runtime_session_id {
    return Ok(summary)
  }
  return Ok(runtime_session_summary_with_receipt(summary, receipt))
}

fn runtime_session_summary_with_receipt(summary: AppLocalRuntimeSessionSummary, receipt: Json) -> AppLocalRuntimeSessionSummary {
  let status = receipt_lifecycle_status(receipt)
  return AppLocalRuntimeSessionSummary(summary.app_id,
                                       summary.runtime_session_id,
                                       summary.marker_count + 1,
                                       summary.started || status == "startup_started",
                                       summary.ready || status == "app_ready",
                                       summary.degraded || status == "app_degraded",
                                       summary.shutdown_clean || status == "shutdown_clean",
                                       runtime_session_first_receipt_id(summary, receipt),
                                       receipt_json_id(receipt),
                                       status,
                                       receipt_lifecycle_reason(receipt),
                                       receipt_json_revision(receipt),
                                       receipt_json_correlation_id(receipt))
}

fn runtime_session_first_receipt_id(summary: AppLocalRuntimeSessionSummary, receipt: Json) -> Int {
  if summary.first_receipt_id == 0 {
    return receipt_json_id(receipt)
  }
  return summary.first_receipt_id
}

fn latest_json_receipt(receipts: Json, app_id: String) -> Result<Json, String> {
  let count = array_len(receipts)?
  if count == 0 {
    return Ok(receipt_placeholder(app_id).as_json())
  }
  return array_get(receipts, count - 1)
}

fn latest_json_receipt_by_kind(receipts: Json, app_id: String, receipt_kind: String) -> Result<Json, String> {
  let count = array_len(receipts)?
  let index = 0
  let selected = receipt_placeholder(app_id).as_json()
  while index < count {
    let receipt = array_get(receipts, index)?
    if get_string(receipt, "receipt_kind")? == receipt_kind {
      selected = receipt
    }
    index += 1
  }
  return Ok(selected)
}

fn latest_event_receipt_by_accepted(receipts: Json, app_id: String, accepted: Bool) -> Result<Json, String> {
  let count = array_len(receipts)?
  let index = 0
  let selected = receipt_placeholder(app_id).as_json()
  while index < count {
    let receipt = array_get(receipts, index)?
    if event_receipt_accepted(receipt)? == accepted {
      selected = receipt
    }
    index += 1
  }
  return Ok(selected)
}

fn latest_lifecycle_receipt_by_status(receipts: Json, app_id: String, status: String) -> Result<Json, String> {
  let count = array_len(receipts)?
  let index = 0
  let selected = receipt_placeholder(app_id).as_json()
  while index < count {
    let receipt = array_get(receipts, index)?
    if receipt_lifecycle_status(receipt) == status {
      selected = receipt
    }
    index += 1
  }
  return Ok(selected)
}

fn event_receipt_accepted(receipt: Json) -> Result<Bool, String> {
  if receipt_json_id(receipt) == 0 {
    return Ok(false)
  }
  return get_bool(get_value(receipt, "payload")?, "accepted")
}

fn receipt_json_id(receipt: Json) -> Int {
  match get_int(receipt, "receipt_id") {
    Ok(value) => {
      return value
    }
    Err(msg) => {
      return 0
    }
  }
}

fn validate_background_stages(stages: Json) -> Result<Bool, String> {
  return validate_stage_graph(stages)
}

fn emit_preflight_observe(config_value: AppLocalConfig, report: AppLocalPreflight) -> Void {
  info_event(config_value.observe_service, "app_local_preflight_ok", "app-local substrate preflight passed")
  delta_counter(config_value.observe_service, "app_local_preflight", "1", 1)
  if report.data_backend == "postgres" {
    delta_counter(config_value.observe_service, "app_local_postgres_preview", "1", 1)
  }
}
