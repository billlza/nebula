module substrate
import app_config::config
import auth_pkg::jwt
import db_postgres::postgres
import jobs::graph
import observe::log
import observe::metrics
import std::json
import std::result

struct AppLocalConfig {
  app_id: String
  data_backend: String
  sqlite_path: String
  postgres_preview: Bool
  postgres_dsn: String
  auth_required: Bool
  auth_mode: String
  principal_subject: String
  observe_service: String
}

struct AppLocalPreflight {
  ok: Bool
  data_backend: String
  sqlite_path: String
  postgres_preview: Bool
  postgres_runtime_available: Bool
  auth_required: Bool
  auth_mode: String
  principal_subject: String
  diagnostic: Json
}

struct AppLocalPrincipal {
  subject: String
  role: String
  auth_mode: String
}

struct AppLocalCommandContext {
  command_id: String
  correlation_id: String
  state_revision: Int
  principal: AppLocalPrincipal
  now_unix_ms: Int
}

struct AppLocalEvent {
  event_kind: String
  command_id: String
  correlation_id: String
  state_revision: Int
  actor_subject: String
  accepted: Bool
  message: String
}

struct AppLocalRecoveryMarker {
  app_id: String
  correlation_id: String
  state_revision: Int
  status: String
  path: String
}

struct AppLocalUpdateMarker {
  app_id: String
  correlation_id: String
  state_revision: Int
  status: String
  manifest_path: String
  manifest_sha256: String
}

fn app_local_config(app_id: String,
                    data_backend: String,
                    sqlite_path: String,
                    postgres_preview: Bool,
                    postgres_dsn: String,
                    auth_required: Bool,
                    auth_mode: String,
                    principal_subject: String,
                    observe_service: String) -> Result<AppLocalConfig, String> {
  let config_value = AppLocalConfig(app_id,
                                    data_backend,
                                    sqlite_path,
                                    postgres_preview,
                                    postgres_dsn,
                                    auth_required,
                                    auth_mode,
                                    principal_subject,
                                    observe_service)
  validate_config(config_value)?
  return Ok(config_value)
}

fn config_from_env(default_app_id: String,
                   default_sqlite_path: String,
                   default_principal_subject: String,
                   default_observe_service: String) -> Result<AppLocalConfig, String> {
  let app_id = optional_env("APP_LOCAL_APP_ID", default_app_id)
  let data_backend = optional_env("APP_DATA_BACKEND", "sqlite")
  let sqlite_path = optional_env("APP_SQLITE_PATH", default_sqlite_path)
  let postgres_preview = bool_env_or("APP_POSTGRES_PREVIEW", false)?
  let postgres_dsn = optional_secret_value("APP_POSTGRES_DSN", "APP_POSTGRES_DSN_FILE")?
  let auth_required = bool_env_or("APP_AUTH_REQUIRED", false)?
  let auth_mode = optional_env("APP_AUTH_MODE", "internal")
  let principal_subject = optional_env("APP_PRINCIPAL_SUBJECT", default_principal_subject)
  let observe_service = optional_env("APP_OBSERVE_SERVICE", default_observe_service)
  return app_local_config(app_id,
                          data_backend,
                          sqlite_path,
                          postgres_preview,
                          postgres_dsn,
                          auth_required,
                          auth_mode,
                          principal_subject,
                          observe_service)
}

fn validate_data_backend(config_value: AppLocalConfig) -> Result<Bool, String> {
  if config_value.data_backend != "sqlite" && config_value.data_backend != "postgres" {
    return Err("app-local substrate data_backend must be sqlite or postgres")
  }
  if config_value.data_backend == "sqlite" && config_value.sqlite_path == "" {
    return Err("app-local substrate sqlite_path is required for sqlite backend")
  }
  return Ok(true)
}

fn validate_postgres_gate(config_value: AppLocalConfig) -> Result<Bool, String> {
  if config_value.data_backend == "postgres" {
    if !config_value.postgres_preview {
      return Err("app-local substrate postgres backend requires postgres_preview=true")
    }
    if config_value.postgres_dsn == "" {
      return Err("app-local substrate postgres backend requires postgres_dsn")
    }
    if !config_value.auth_required {
      return Err("app-local substrate postgres backend requires auth_required=true")
    }
  }
  return Ok(true)
}

fn validate_auth_mode(config_value: AppLocalConfig) -> Result<Bool, String> {
  if config_value.auth_mode != "internal" && config_value.auth_mode != "token" && config_value.auth_mode != "jwt" {
    return Err("app-local substrate auth_mode must be internal, token, or jwt")
  }
  if config_value.auth_required && config_value.principal_subject == "" {
    return Err("app-local substrate auth_required requires principal_subject")
  }
  return Ok(true)
}

fn validate_config(config_value: AppLocalConfig) -> Result<Bool, String> {
  if config_value.app_id == "" {
    return Err("app-local substrate app_id is required")
  }
  if config_value.observe_service == "" {
    return Err("app-local substrate observe_service is required")
  }
  validate_data_backend(config_value)?
  validate_postgres_gate(config_value)?
  return validate_auth_mode(config_value)
}

fn postgres_runtime_available_if_needed(config_value: AppLocalConfig) -> Result<Bool, String> {
  if config_value.data_backend != "postgres" {
    return Ok(false)
  }
  match probe_runtime() {
    Ok(available) => {
      if available {
        return Ok(true)
      }
      return Err("app-local substrate postgres runtime unavailable")
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

fn preflight_diagnostic(config_value: AppLocalConfig, postgres_runtime_available: Bool) -> Json {
  return object9("schema",
                 string_value("nebula.app-local.preflight.v1"),
                 "app_id",
                 string_value(config_value.app_id),
                 "data_backend",
                 string_value(config_value.data_backend),
                 "sqlite_path",
                 string_value(config_value.sqlite_path),
                 "postgres_preview",
                 bool_value(config_value.postgres_preview),
                 "postgres_runtime_available",
                 bool_value(postgres_runtime_available),
                 "auth_required",
                 bool_value(config_value.auth_required),
                 "auth_mode",
                 string_value(config_value.auth_mode),
                 "principal_subject",
                 string_value(config_value.principal_subject))
}

fn preflight(config_value: AppLocalConfig) -> Result<AppLocalPreflight, String> {
  validate_config(config_value)?
  let postgres_available = postgres_runtime_available_if_needed(config_value)?
  let diagnostic = preflight_diagnostic(config_value, postgres_available)
  return Ok(AppLocalPreflight(true,
                              config_value.data_backend,
                              config_value.sqlite_path,
                              config_value.postgres_preview,
                              postgres_available,
                              config_value.auth_required,
                              config_value.auth_mode,
                              config_value.principal_subject,
                              diagnostic))
}

fn AppLocalPreflight_as_json(self: AppLocalPreflight) -> Json {
  return object9("schema",
                 string_value("nebula.app-local.preflight.v1"),
                 "ok",
                 bool_value(self.ok),
                 "data_backend",
                 string_value(self.data_backend),
                 "sqlite_path",
                 string_value(self.sqlite_path),
                 "postgres_preview",
                 bool_value(self.postgres_preview),
                 "postgres_runtime_available",
                 bool_value(self.postgres_runtime_available),
                 "auth_required",
                 bool_value(self.auth_required),
                 "auth_mode",
                 string_value(self.auth_mode),
                 "principal_subject",
                 string_value(self.principal_subject))
}

fn principal(subject: String, role: String, auth_mode: String) -> Result<AppLocalPrincipal, String> {
  if subject == "" {
    return Err("app-local substrate principal subject is required")
  }
  if role == "" {
    return Err("app-local substrate principal role is required")
  }
  if auth_mode != "internal" && auth_mode != "token" && auth_mode != "jwt" {
    return Err("app-local substrate auth_mode must be internal, token, or jwt")
  }
  return Ok(AppLocalPrincipal(subject, role, auth_mode))
}

fn principal_from_claims(claims: JwtClaims, role: String) -> Result<AppLocalPrincipal, String> {
  return principal(claims.subject, role, "jwt")
}

fn AppLocalPrincipal_as_json(self: AppLocalPrincipal) -> Json {
  return object3("subject",
                 string_value(self.subject),
                 "role",
                 string_value(self.role),
                 "auth_mode",
                 string_value(self.auth_mode))
}

fn command_context(command_id: String,
                   correlation_id: String,
                   state_revision: Int,
                   principal_value: AppLocalPrincipal,
                   now_unix_ms: Int) -> Result<AppLocalCommandContext, String> {
  if command_id == "" {
    return Err("app-local substrate command_id is required")
  }
  if correlation_id == "" {
    return Err("app-local substrate correlation_id is required")
  }
  if state_revision < 0 {
    return Err("app-local substrate state_revision must be non-negative")
  }
  if now_unix_ms < 0 {
    return Err("app-local substrate now_unix_ms must be non-negative")
  }
  principal(principal_value.subject, principal_value.role, principal_value.auth_mode)?
  return Ok(AppLocalCommandContext(command_id, correlation_id, state_revision, principal_value, now_unix_ms))
}

fn AppLocalCommandContext_as_json(self: AppLocalCommandContext) -> Json {
  return object8("schema",
                 string_value("nebula.app-local.command-context.v1"),
                 "command_id",
                 string_value(self.command_id),
                 "correlation_id",
                 string_value(self.correlation_id),
                 "state_revision",
                 int_value(self.state_revision),
                 "actor_subject",
                 string_value(self.principal.subject),
                 "actor_role",
                 string_value(self.principal.role),
                 "auth_mode",
                 string_value(self.principal.auth_mode),
                 "now_unix_ms",
                 int_value(self.now_unix_ms))
}

fn next_state_revision(context: AppLocalCommandContext, accepted: Bool) -> Int {
  if accepted {
    return context.state_revision + 1
  }
  return context.state_revision
}

fn app_local_event(event_kind: String,
                   context: AppLocalCommandContext,
                   accepted: Bool,
                   message: String) -> Result<AppLocalEvent, String> {
  if event_kind == "" {
    return Err("app-local substrate event_kind is required")
  }
  return Ok(AppLocalEvent(event_kind,
                          context.command_id,
                          context.correlation_id,
                          next_state_revision(context, accepted),
                          context.principal.subject,
                          accepted,
                          message))
}

fn command_accepted_event(context: AppLocalCommandContext, event_kind: String, message: String) -> Result<AppLocalEvent, String> {
  return app_local_event(event_kind, context, true, message)
}

fn command_rejected_event(context: AppLocalCommandContext, message: String) -> Result<AppLocalEvent, String> {
  return app_local_event("command_rejected", context, false, message)
}

fn AppLocalEvent_as_json(self: AppLocalEvent) -> Json {
  return object8("schema",
                 string_value("nebula.app-local.event.v1"),
                 "event_kind",
                 string_value(self.event_kind),
                 "command_id",
                 string_value(self.command_id),
                 "correlation_id",
                 string_value(self.correlation_id),
                 "state_revision",
                 int_value(self.state_revision),
                 "actor_subject",
                 string_value(self.actor_subject),
                 "accepted",
                 bool_value(self.accepted),
                 "message",
                 string_value(self.message))
}

fn recovery_marker(app_id: String,
                   correlation_id: String,
                   state_revision: Int,
                   status: String,
                   path: String) -> Result<AppLocalRecoveryMarker, String> {
  if app_id == "" {
    return Err("app-local substrate recovery app_id is required")
  }
  if correlation_id == "" {
    return Err("app-local substrate recovery correlation_id is required")
  }
  if state_revision < 0 {
    return Err("app-local substrate recovery state_revision must be non-negative")
  }
  if status == "" {
    return Err("app-local substrate recovery status is required")
  }
  if path == "" {
    return Err("app-local substrate recovery path is required")
  }
  return Ok(AppLocalRecoveryMarker(app_id, correlation_id, state_revision, status, path))
}

fn AppLocalRecoveryMarker_as_json(self: AppLocalRecoveryMarker) -> Json {
  return object6("schema",
                 string_value("nebula.app-local.recovery-marker.v1"),
                 "app_id",
                 string_value(self.app_id),
                 "correlation_id",
                 string_value(self.correlation_id),
                 "state_revision",
                 int_value(self.state_revision),
                 "status",
                 string_value(self.status),
                 "path",
                 string_value(self.path))
}

fn update_marker(app_id: String,
                 correlation_id: String,
                 state_revision: Int,
                 status: String,
                 manifest_path: String,
                 manifest_sha256: String) -> Result<AppLocalUpdateMarker, String> {
  if app_id == "" {
    return Err("app-local substrate update app_id is required")
  }
  if correlation_id == "" {
    return Err("app-local substrate update correlation_id is required")
  }
  if state_revision < 0 {
    return Err("app-local substrate update state_revision must be non-negative")
  }
  if status == "" {
    return Err("app-local substrate update status is required")
  }
  if manifest_path == "" {
    return Err("app-local substrate update manifest_path is required")
  }
  if manifest_sha256 == "" {
    return Err("app-local substrate update manifest_sha256 is required")
  }
  return Ok(AppLocalUpdateMarker(app_id, correlation_id, state_revision, status, manifest_path, manifest_sha256))
}

fn AppLocalUpdateMarker_as_json(self: AppLocalUpdateMarker) -> Json {
  return object7("schema",
                 string_value("nebula.app-local.update-marker.v1"),
                 "app_id",
                 string_value(self.app_id),
                 "correlation_id",
                 string_value(self.correlation_id),
                 "state_revision",
                 int_value(self.state_revision),
                 "status",
                 string_value(self.status),
                 "manifest_path",
                 string_value(self.manifest_path),
                 "manifest_sha256",
                 string_value(self.manifest_sha256))
}

fn validate_background_stages(stages: Json) -> Result<Bool, String> {
  return validate_stage_graph(stages)
}

fn emit_preflight_observe(config_value: AppLocalConfig, report: AppLocalPreflight) -> Void {
  info_event(config_value.observe_service, "app_local_preflight_ok", "app-local substrate preflight passed")
  delta_counter(config_value.observe_service, "app_local_preflight", "1", 1)
  if report.data_backend == "postgres" {
    delta_counter(config_value.observe_service, "app_local_postgres_preview", "1", 1)
  }
}
