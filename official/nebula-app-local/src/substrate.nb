fn update_marker(app_id: String,
                 correlation_id: String,
                 state_revision: Int,
                 status: String,
                 manifest_path: String,
                 manifest_sha256: String) -> Result<AppLocalUpdateMarker, String> {
  if app_id == "" {
    return Err("app-local substrate update app_id is required")
  }
  if correlation_id == "" {
    return Err("app-local substrate update correlation_id is required")
  }
  if state_revision < 0 {
    return Err("app-local substrate update state_revision must be non-negative")
  }
  if status == "" {
    return Err("app-local substrate update status is required")
  }
  if manifest_path == "" {
    return Err("app-local substrate update manifest_path is required")
  }
  if manifest_sha256 == "" {
    return Err("app-local substrate update manifest_sha256 is required")
  }
  return Ok(AppLocalUpdateMarker(app_id, correlation_id, state_revision, status, manifest_path, manifest_sha256))
}

fn lifecycle_status_allowed(status: String) -> Bool {
  return status == "startup_started" ||
         status == "app_ready" ||
         status == "app_degraded" ||
         status == "shutdown_clean"
}

fn lifecycle_marker(app_id: String,
                    runtime_session_id: String,
                    correlation_id: String,
                    state_revision: Int,
                    status: String,
                    reason: String) -> Result<AppLocalLifecycleMarker, String> {
  if app_id == "" {
    return Err("app-local substrate lifecycle app_id is required")
  }
  if runtime_session_id == "" {
    return Err("app-local substrate lifecycle runtime_session_id is required")
  }
  if correlation_id == "" {
    return Err("app-local substrate lifecycle correlation_id is required")
  }
  if state_revision < 0 {
    return Err("app-local substrate lifecycle state_revision must be non-negative")
  }
  if !lifecycle_status_allowed(status) {
    return Err("app-local substrate lifecycle status must be startup_started, app_ready, app_degraded, or shutdown_clean")
  }
  if reason == "" {
    return Err("app-local substrate lifecycle reason is required")
  }
  return Ok(AppLocalLifecycleMarker(app_id, runtime_session_id, correlation_id, state_revision, status, reason))
}

