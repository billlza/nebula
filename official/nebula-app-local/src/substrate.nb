struct AppLocalConfig {
  app_id: String
  data_backend: String
  sqlite_path: String
  postgres_preview: Bool
  postgres_dsn: String
  auth_required: Bool
  auth_mode: String
  principal_subject: String
  observe_service: String
}

struct AppLocalPreflight {
  ok: Bool
  data_backend: String
  sqlite_path: String
  postgres_preview: Bool
  postgres_runtime_available: Bool
  auth_required: Bool
  auth_mode: String
  principal_subject: String
  diagnostic: Json
}

