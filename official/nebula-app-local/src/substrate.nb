fn runtime_session_last_marker_json(self: AppLocalRuntimeSessionSummary) -> Json {
  return object4("status",
                 string_value(self.last_status),
                 "reason",
                 string_value(self.last_reason),
                 "state_revision",
                 int_value(self.last_state_revision),
                 "correlation_id",
                 string_value(self.last_correlation_id))
}

fn runtime_session_completion(self: AppLocalRuntimeSessionSummary) -> String {
  if self.marker_count == 0 {
    return "none"
  }
  if self.last_status == "shutdown_clean" {
    if self.degraded {
      return "degraded_clean"
    }
    return "clean"
  }
  return "incomplete"
}

