module log
import std::json
import std::log
import std::time

fn classification(reason: String, detail: String) -> Json {
  return object2(
    "reason",
    string_value(reason),
    "detail",
    string_value(detail)
  )
}

fn lifecycle_listener_stopped_classification(reason: String) -> Json {
  if reason == "limit_reached" {
    return classification("policy", "limit_reached")
  }
  return classification("shutdown", reason)
}

fn info_event(service: String, event: String, message: String) -> Void {
  info(stringify(object4(
    "service",
    string_value(service),
    "event",
    string_value(event),
    "message",
    string_value(message),
    "unix_ms",
    int_value(unix_millis())
  )))
}

fn error_event(service: String, event: String, message: String) -> Void {
  error(stringify(object4(
    "service",
    string_value(service),
    "event",
    string_value(event),
    "message",
    string_value(message),
    "unix_ms",
    int_value(unix_millis())
  )))
}

