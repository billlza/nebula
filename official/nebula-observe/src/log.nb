fn request_started_classified(service: String,
                              request_id: Int,
                              path: String,
                              event_classification: Json) -> Void {
  info(stringify(object6(
    "service",
    string_value(service),
    "event",
    string_value("request_started"),
    "request_id",
    int_value(request_id),
    "path",
    string_value(path),
    "classification",
    event_classification,
    "unix_ms",
    int_value(unix_millis())
  )))
}

fn request_started(service: String, request_id: Int, path: String) -> Void {
  request_started_classified(service,
                             request_id,
                             path,
                             classification("request_start", "peer_request_ready"))
}

