fn lifecycle_listener_bound(service: String, bind_host: String, port: Int, message: String) -> Void {
  info(stringify(object6(
    "service",
    string_value(service),
    "event",
    string_value("listener_bound"),
    "message",
    string_value(message),
    "bind_host",
    string_value(bind_host),
    "port",
    int_value(port),
    "unix_ms",
    int_value(unix_millis())
  )))
}

fn lifecycle_drain_requested(service: String, path: String) -> Void {
  info(stringify(object6(
    "service",
    string_value(service),
    "event",
    string_value("drain_requested"),
    "path",
    string_value(path),
    "message",
    string_value("service entering draining mode"),
    "classification",
    classification("shutdown", "drain_requested"),
    "unix_ms",
    int_value(unix_millis())
  )))
}

fn lifecycle_shutdown_requested(service: String, path: String) -> Void {
  info(stringify(object6(
    "service",
