  )))
}

fn lifecycle_listener_stopped(service: String, reason: String, served_requests: Int) -> Void {
  info(stringify(object6(
    "service",
    string_value(service),
    "event",
    string_value("listener_stopped"),
    "reason",
    string_value(reason),
    "served_requests",
    int_value(served_requests),
    "classification",
    lifecycle_listener_stopped_classification(reason),
    "unix_ms",
    int_value(unix_millis())
  )))
}
