async fn handle_accepted_stream(stream: TcpStream,
                                cfg: ServiceConfig,
                                drain_cfg: DrainConfig,
                                draining_mode: Bool,
                                handler: Fn(Request) -> Future<Response>) -> Result<ConnectionOutcome, String> {
  let served = 0
  let current_draining = draining_mode
  while true {
    match advance_connection_before_read(stream, cfg, drain_cfg, served, current_draining) {
      Ok(state) => {
        served = state.request_count
        current_draining = state.draining_mode
        if state.should_stop {
          return Ok(applied_connection_outcome(state))
        }
      }
      Err(msg) => {
        return Err(msg)
      }
    }
    match await response_connection_iteration_state(stream,
                                                    cfg,
                                                    drain_cfg,
                                                    served,
                                                    current_draining,
                                                    handler) {
      Ok(state) => {
        served = state.request_count
        current_draining = state.draining_mode
        if state.should_stop {
          return Ok(applied_connection_outcome(state))
        }
      }
      Err(msg) => {
        return Err(msg)
      }
    }
  }
  return Err("handle_accepted_stream fell through unexpectedly")
}

