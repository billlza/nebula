enum ServeGoal {
  Finite(Int)
  RunForever(Void)
}

fn finite_serve_goal(limit: Int) -> ServeGoal {
  return Finite(limit)
}

fn run_forever_serve_goal() -> ServeGoal {
  return RunForever
}

fn serve_goal_invalid_message(goal: ServeGoal) -> String {
  match goal {
    Finite(limit) => {
      if limit <= 0 {
        return "serve_n limit must be positive"
      }
      return ""
    }
    RunForever => {
      return ""
    }
  }
}

fn serve_goal_reached_limit(goal: ServeGoal, served: Int) -> Bool {
  match goal {
    Finite(limit) => {
      return served >= limit
    }
    RunForever => {
      return false
    }
  }
}

fn serve_goal_complete(cfg: ServiceConfig,
                       goal: ServeGoal,
                       served: Int) -> Result<Int, String> {
  match goal {
    Finite(_) => {
      lifecycle_listener_stopped(cfg.name, "limit_reached", served)
      return Ok(served)
    }
    RunForever => {
      return Ok(served)
    }
  }
}

fn serve_goal_step_failed(cfg: ServiceConfig,
                          goal: ServeGoal,
                          served: Int,
                          msg: String) -> Result<Int, String> {
  match goal {
    Finite(_) => {
      return Err(msg)
    }
    RunForever => {
      if msg == "listener is closed" {
        lifecycle_listener_stopped(cfg.name, "listener_closed", served)
        return Ok(served)
      }
      return Err(msg)
    }
  }
}

async fn accept_stream(listener: TcpListener) -> Result<TcpStream, String> {
  return await listener.accept()
}

fn request_count_result(outcome: Result<ConnectionOutcome, String>) -> Result<Int, String> {
  match outcome {
    Ok(connection) => {
      return Ok(connection.request_count)
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

async fn serve_request_once(listener: TcpListener,
                            cfg: ServiceConfig,
                            handler: Fn(Request) -> Future<Response>) -> Result<Int, String> {
  match await accept_stream(listener) {
    Ok(stream) => {
      return request_count_result(await handle_accepted_stream(stream, cfg, disabled(), false, handler))
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

async fn serve_request_once_result(listener: TcpListener,
                                   cfg: ServiceConfig,
                                   handler: Fn(Request) -> Future<Result<Response, String>>) -> Result<Int, String> {
  match await accept_stream(listener) {
    Ok(stream) => {
      return request_count_result(await handle_accepted_stream_result(stream, cfg, disabled(), false, handler))
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

async fn serve_request_once_with_context(listener: TcpListener,
                                         cfg: ServiceConfig,
                                         handler: Fn(RequestContext, Request) -> Future<Response>) -> Result<Int, String> {
  match await accept_stream(listener) {
    Ok(stream) => {
      return request_count_result(await handle_accepted_stream_with_context(stream, cfg, disabled(), false, handler))
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

async fn serve_request_once_result_with_context(listener: TcpListener,
                                                cfg: ServiceConfig,
                                                handler: Fn(RequestContext, Request) -> Future<Result<Response, String>>) -> Result<Int, String> {
  match await accept_stream(listener) {
    Ok(stream) => {
      return request_count_result(await handle_accepted_stream_result_with_context(stream, cfg, disabled(), false, handler))
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

async fn serve_response_goal(listener: TcpListener,
                             cfg: ServiceConfig,
                             goal: ServeGoal,
                             handler: Fn(Request) -> Future<Response>) -> Result<Int, String> {
  let invalid = serve_goal_invalid_message(goal)
  if invalid != "" {
    return Err(invalid)
  }
  let served = 0
  while true {
    if serve_goal_reached_limit(goal, served) {
      return serve_goal_complete(cfg, goal, served)
    }
    match await serve_request_once(listener, cfg, handler) {
      Ok(count) => {
        served += count
      }
      Err(msg) => {
        return serve_goal_step_failed(cfg, goal, served, msg)
      }
    }
  }
  return Ok(served)
}

async fn serve_result_goal(listener: TcpListener,
                           cfg: ServiceConfig,
                           goal: ServeGoal,
                           handler: Fn(Request) -> Future<Result<Response, String>>) -> Result<Int, String> {
  let invalid = serve_goal_invalid_message(goal)
  if invalid != "" {
    return Err(invalid)
  }
  let served = 0
  while true {
    if serve_goal_reached_limit(goal, served) {
      return serve_goal_complete(cfg, goal, served)
    }
    match await serve_request_once_result(listener, cfg, handler) {
      Ok(count) => {
        served += count
      }
      Err(msg) => {
        return serve_goal_step_failed(cfg, goal, served, msg)
      }
    }
  }
  return Ok(served)
}

