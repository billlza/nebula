async fn response_connection_iteration_state(stream: TcpStream,
                                             cfg: ServiceConfig,
                                             drain_cfg: DrainConfig,
                                             served: Int,
                                             current_draining: Bool,
                                             handler: Fn(Request) -> Future<Response>) -> Result<ConnectionLoopState, String> {
  match await read_connection_request(stream, cfg, served) {
    Ok(outcome) => {
      match outcome {
        Ready(ready) => {
          return await ready_response_connection_state(stream,
                                                      cfg,
                                                      drain_cfg,
                                                      served,
                                                      current_draining,
                                                      ready.request,
                                                      ready.span,
                                                      handler)
        }
        _ => {
          return await non_ready_connection_state(stream, cfg, served, current_draining, outcome)
        }
      }
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

