struct DrainServeState {
  served: Int
  draining_mode: Bool
  should_stop: Bool
}

enum DrainAcceptResolution {
  AcceptedStream(TcpStream)
  Completed(DrainServeState)
}

fn continue_drain_serve_state(served: Int, draining_mode: Bool) -> DrainServeState {
  return DrainServeState(served, draining_mode, false)
}

fn stop_drain_serve_state(served: Int, draining_mode: Bool) -> DrainServeState {
  return DrainServeState(served, draining_mode, true)
}

fn advance_listener_draining_mode_if_needed(cfg: ServiceConfig,
                                            drain_cfg: DrainConfig,
                                            draining_mode: Bool) -> Result<Bool, String> {
  if draining_mode {
    return Ok(true)
  }
  return next_draining_mode(cfg, drain_cfg, draining_mode)
}

fn stop_drained_listener(listener: TcpListener,
                         cfg: ServiceConfig,
                         served: Int,
                         draining_mode: Bool) -> DrainServeState {
  listener.close()
  lifecycle_listener_stopped(cfg.name, "drained", served)
  return stop_drain_serve_state(served, draining_mode)
}

fn idle_drain_serve_state(listener: TcpListener,
                          cfg: ServiceConfig,
                          drain_cfg: DrainConfig,
                          served: Int,
                          draining_mode: Bool) -> Result<DrainServeState, String> {
  if !draining_mode {
    match next_draining_mode(cfg, drain_cfg, draining_mode) {
      Ok(next_mode) => {
        return Ok(continue_drain_serve_state(served, next_mode))
      }
      Err(msg) => {
        return Err(msg)
      }
    }
  }
  return Ok(stop_drained_listener(listener, cfg, served, draining_mode))
}

fn listener_closed_drain_serve_state(cfg: ServiceConfig,
                                     served: Int,
                                     draining_mode: Bool) -> DrainServeState {
  lifecycle_listener_stopped(cfg.name, "listener_closed", served)
  return stop_drain_serve_state(served, draining_mode)
}

fn continue_drain_serve_state_from_connection(served: Int,
                                              connection: ConnectionOutcome) -> DrainServeState {
  return continue_drain_serve_state(served + connection.request_count, connection.draining_mode)
}

fn drain_serve_state_from_connection_result(served: Int,
                                            outcome: Result<ConnectionOutcome, String>) -> Result<DrainServeState, String> {
  match outcome {
    Ok(connection) => {
      return Ok(continue_drain_serve_state_from_connection(served, connection))
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

async fn drain_accept_resolution(listener: TcpListener,
                                 cfg: ServiceConfig,
                                 drain_cfg: DrainConfig,
                                 served: Int,
                                 draining_mode: Bool) -> Result<DrainAcceptResolution, String> {
  match await accept_next(listener, drain_cfg) {
    Ok(outcome) => {
      match outcome {
        Accepted(stream) => {
          return Ok(AcceptedStream(stream))
        }
        Idle => {
          match idle_drain_serve_state(listener, cfg, drain_cfg, served, draining_mode) {
            Ok(state) => {
              return Ok(Completed(state))
            }
            Err(msg) => {
              return Err(msg)
            }
          }
        }
      }
    }
    Err(msg) => {
      if msg == "listener is closed" {
        return Ok(Completed(listener_closed_drain_serve_state(cfg, served, draining_mode)))
      }
      return Err(msg)
    }
  }
}

async fn response_drain_serve_iteration_state(listener: TcpListener,
                                              cfg: ServiceConfig,
                                              drain_cfg: DrainConfig,
                                              served: Int,
                                              draining_mode: Bool,
                                              handler: Fn(RequestContext, Request) -> Future<Response>) -> Result<DrainServeState, String> {
  match await drain_accept_resolution(listener, cfg, drain_cfg, served, draining_mode) {
    Ok(resolution) => {
      match resolution {
        AcceptedStream(stream) => {
          return drain_serve_state_from_connection_result(
            served,
            await handle_accepted_stream_with_context(stream, cfg, drain_cfg, draining_mode, handler)
          )
        }
        Completed(state) => {
          return Ok(state)
        }
      }
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

async fn result_drain_serve_iteration_state(listener: TcpListener,
                                            cfg: ServiceConfig,
                                            drain_cfg: DrainConfig,
                                            served: Int,
                                            draining_mode: Bool,
                                            handler: Fn(RequestContext, Request) -> Future<Result<Response, String>>) -> Result<DrainServeState, String> {
  match await drain_accept_resolution(listener, cfg, drain_cfg, served, draining_mode) {
    Ok(resolution) => {
      match resolution {
        AcceptedStream(stream) => {
          return drain_serve_state_from_connection_result(
            served,
            await handle_accepted_stream_result_with_context(stream,
                                                             cfg,
                                                             drain_cfg,
                                                             draining_mode,
                                                             handler)
          )
        }
        Completed(state) => {
          return Ok(state)
        }
      }
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}

async fn serve_requests_until_drained(listener: TcpListener,
                                      cfg: ServiceConfig,
                                      drain_cfg: DrainConfig,
                                      handler: Fn(RequestContext, Request) -> Future<Response>) -> Result<Int, String> {
  let served = 0
  let draining_mode = false
  while true {
    match advance_listener_draining_mode_if_needed(cfg, drain_cfg, draining_mode) {
      Ok(next_mode) => {
        draining_mode = next_mode
      }
      Err(msg) => {
        return Err(msg)
      }
    }
    match await response_drain_serve_iteration_state(listener,
                                                     cfg,
                                                     drain_cfg,
                                                     served,
                                                     draining_mode,
                                                     handler) {
      Ok(state) => {
        served = state.served
        draining_mode = state.draining_mode
        if state.should_stop {
          return Ok(state.served)
        }
      }
      Err(msg) => {
        return Err(msg)
      }
    }
  }
  return Ok(served)
}

async fn serve_requests_result_until_drained(listener: TcpListener,
                                             cfg: ServiceConfig,
                                             drain_cfg: DrainConfig,
                                             handler: Fn(RequestContext, Request) -> Future<Result<Response, String>>) -> Result<Int, String> {
  let served = 0
  let draining_mode = false
  while true {
    match advance_listener_draining_mode_if_needed(cfg, drain_cfg, draining_mode) {
      Ok(next_mode) => {
        draining_mode = next_mode
      }
      Err(msg) => {
        return Err(msg)
      }
    }
    match await result_drain_serve_iteration_state(listener,
                                                   cfg,
                                                   drain_cfg,
                                                   served,
                                                   draining_mode,
                                                   handler) {
      Ok(state) => {
        served = state.served
        draining_mode = state.draining_mode
        if state.should_stop {
          return Ok(state.served)
        }
      }
      Err(msg) => {
        return Err(msg)
      }
    }
  }
  return Ok(served)
}
