module drain
import std::env
import std::fs
import std::result

struct DrainConfig {
  sentinel_path: String
  shutdown_path: String
  poll_interval_ms: Int
}

fn drain_config(sentinel_path: String,
                shutdown_path: String,
                poll_interval_ms: Int) -> DrainConfig {
  return DrainConfig(sentinel_path, shutdown_path, poll_interval_ms)
}

fn disabled() -> DrainConfig {
  return drain_config("", "", 250)
}

fn sentinel_file(path: String) -> DrainConfig {
  return drain_config(path, "", 250)
}

fn shutdown_file(path: String) -> DrainConfig {
  return drain_config("", path, 250)
}

fn with_poll_interval(base: DrainConfig, poll_interval_ms: Int) -> DrainConfig {
  return drain_config(base.sentinel_path, base.shutdown_path, poll_interval_ms)
}

fn with_shutdown_file(base: DrainConfig, shutdown_path: String) -> DrainConfig {
  return drain_config(base.sentinel_path, shutdown_path, base.poll_interval_ms)
}

fn DrainConfig_enabled(self: DrainConfig) -> Bool {
  return self.sentinel_path != "" || self.shutdown_path != ""
}

fn requested(self: DrainConfig) -> Result<Bool, String> {
  if !self.enabled() {
    return Ok(false)
  }
  return exists(self.sentinel_path)
}

fn shutdown_requested(self: DrainConfig) -> Result<Bool, String> {
  if self.shutdown_path == "" {
    return Ok(false)
  }
  return exists(self.shutdown_path)
}

fn from_env() -> Result<DrainConfig, String> {
  let sentinel = get_or_default("NEBULA_DRAIN_FILE", "")
  let shutdown_path = get_or_default("NEBULA_SHUTDOWN_FILE", "")
  let base = disabled()
  if sentinel != "" {
    base = sentinel_file(sentinel)
  }
  if shutdown_path != "" {
    base = with_shutdown_file(base, shutdown_path)
  }
  match get_int_or("NEBULA_DRAIN_POLL_MS", base.poll_interval_ms) {
    Ok(poll_interval_ms) => {
      if poll_interval_ms <= 0 {
        return Err("NEBULA_DRAIN_POLL_MS must be positive")
      }
      return Ok(with_poll_interval(base, poll_interval_ms))
    }
    Err(msg) => {
      return Err(msg)
    }
  }
}
