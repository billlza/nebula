module routing
import context
import std::http
import std::result
import std::task

async fn dispatch_ctx1(ctx: RequestContext,
                       request: Request,
                       first_method: Method,
                       first_path: String,
                       first_handler: Fn(RequestContext, Request) -> Future<Response>,
                       fallback: Response) -> Response {
  if path_matches(first_path, request) {
    if method_matches(first_method, request.method) {
      return await first_handler(ctx, request)
    }
    return method_not_allowed_text("method not allowed")
  }
  return fallback
}

async fn dispatch_ctx1_result(ctx: RequestContext,
                              request: Request,
                              first_method: Method,
                              first_path: String,
                              first_handler: Fn(RequestContext, Request) -> Future<Result<Response, String>>,
                              fallback: Response) -> Result<Response, String> {
  if path_matches(first_path, request) {
    if method_matches(first_method, request.method) {
      return await first_handler(ctx, request)
    }
    return Ok(method_not_allowed_text("method not allowed"))
  }
  return Ok(fallback)
}

async fn dispatch_ctx2(ctx: RequestContext,
                       request: Request,
                       first_method: Method,
                       first_path: String,
                       first_handler: Fn(RequestContext, Request) -> Future<Response>,
                       second_method: Method,
                       second_path: String,
                       second_handler: Fn(RequestContext, Request) -> Future<Response>,
                       fallback: Response) -> Response {
  let path_hit = false
  if path_matches(first_path, request) {
    path_hit = true
    if method_matches(first_method, request.method) {
      return await first_handler(ctx, request)
    }
  }
  if path_matches(second_path, request) {
