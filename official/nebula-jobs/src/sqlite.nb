module sqlite
import contracts
import db_sqlite::sqlite
import std::bytes
import std::json
import std::result
import stage_state
import validate

fn sqlite_text_concat(lhs: String, rhs: String) -> String {
  return to_string(concat(from_string(lhs), from_string(rhs)))
}

struct JobDefinitionLookup {
  found: Bool
  definition: JobDefinition
}

struct JobRunLookup {
  found: Bool
  run: JobRun
}

struct StageSelection {
  found: Bool
  stage: JobStageRun
}

struct OutboxLookup {
  found: Bool
  message: OutboxMessage
}

struct DefinitionRowCore {
  name: String
  trigger_kind: String
  event_kind: String
  stages: Json
}

struct DefinitionRowMeta {
  revision_id: Int
  updated_by: String
  updated_unix_ms: Int
}

